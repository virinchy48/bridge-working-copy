<mvc:View
    controllerName="nhvr.bridgemanagement.controller.AnalyticsDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page id="analyticsDashboardPage"
          title="{i18n>analytics.title}"
          showNavButton="true"
          navButtonPress="onNavBack">

        <customHeader>
            <OverflowToolbar>
                <OverflowToolbarButton icon="sap-icon://nav-back" tooltip="Back to Home" press="onNavBack" type="Transparent"/>
                <Title text="{i18n>analytics.title}" />
                <ToolbarSpacer />
                <!-- Date range picker -->
                <Label text="{i18n>analytics.period}" />
                <Select id="periodSelect" change="onPeriodChange" selectedKey="30d">
                    <core:Item key="7d" text="{i18n>analytics.last7days}" />
                    <core:Item key="30d" text="{i18n>analytics.last30days}" />
                    <core:Item key="90d" text="{i18n>analytics.last90days}" />
                    <core:Item key="365d" text="{i18n>analytics.lastYear}" />
                </Select>
                <Button icon="sap-icon://refresh" press="onRefresh" tooltip="{i18n>analytics.refresh}" />
            </OverflowToolbar>
        </customHeader>

        <content>
            <IconTabBar id="analyticsTabBar" selectedKey="overview" class="sapUiNoContentPadding">
              <items>

                <!-- ════════ TAB 1: Overview ════════ -->
                <IconTabFilter key="overview" text="{i18n>analytics.overview}" icon="sap-icon://home">
                    <VBox class="sapUiSmallMargin">

                        <!-- KPI Tiles Row -->
                        <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
                            <GenericTile id="kpiUsers" header="{i18n>analytics.kpi.uniqueUsers}"
                                         class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <TileContent>
                                    <NumericContent value="{ana>/kpis/uniqueUsers}" icon="sap-icon://person-placeholder" withMargin="false" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile id="kpiSessions" header="{i18n>analytics.kpi.sessions}"
                                         class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <TileContent>
                                    <NumericContent value="{ana>/kpis/totalSessions}" icon="sap-icon://visits" withMargin="false" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile id="kpiEvents" header="{i18n>analytics.kpi.events}"
                                         class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                                <TileContent>
                                    <NumericContent value="{ana>/kpis/totalEvents}" icon="sap-icon://action" withMargin="false" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile id="kpiErrors" header="{i18n>analytics.kpi.errors}"
                                         class="sapUiSmallMarginEnd sapUiSmallMarginBottom"
                                         state="{= ${ana>/kpis/totalErrors} > 0 ? 'Failed' : 'Loaded'}">
                                <TileContent>
                                    <NumericContent value="{ana>/kpis/totalErrors}" icon="sap-icon://alert" withMargin="false" />
                                </TileContent>
                            </GenericTile>
                            <GenericTile id="kpiAvgSession" header="{i18n>analytics.kpi.avgSession}"
                                         class="sapUiSmallMarginBottom">
                                <TileContent>
                                    <NumericContent value="{ana>/kpis/avgSessionMin}" scale="min" icon="sap-icon://time-entry-request" withMargin="false" />
                                </TileContent>
                            </GenericTile>
                        </HBox>

                        <!-- Top Pages Table -->
                        <Panel headerText="{i18n>analytics.topPages}" class="sapUiSmallMarginBottom">
                            <Table id="topRoutesTable"
                                   items="{ana>/topRoutes}"
                                   growing="false"
                                   sticky="ColumnHeaders">
                                <columns>
                                    <Column><Text text="{i18n>analytics.col.rank}" /></Column>
                                    <Column><Text text="{i18n>analytics.col.route}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>analytics.col.views}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <Text text="{ana>rank}" />
                                        <Text text="{ana>targetRoute}" />
                                        <ObjectNumber number="{ana>cnt}" emphasized="false" />
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>

                        <!-- Top Actions Table -->
                        <Panel headerText="{i18n>analytics.topActions}">
                            <Table id="topActionsTable"
                                   items="{ana>/topActions}"
                                   growing="false"
                                   sticky="ColumnHeaders">
                                <columns>
                                    <Column><Text text="{i18n>analytics.col.rank}" /></Column>
                                    <Column><Text text="{i18n>analytics.col.action}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>analytics.col.count}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <Text text="{ana>rank}" />
                                        <Text text="{ana>eventType}" />
                                        <ObjectNumber number="{ana>cnt}" emphasized="false" />
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 2: Feature Adoption ════════ -->
                <IconTabFilter key="adoption" text="{i18n>analytics.adoption}" icon="sap-icon://trend-up">
                    <VBox class="sapUiSmallMargin">
                        <Table id="adoptionTable"
                               items="{ana>/features}"
                               growing="true"
                               growingThreshold="20"
                               sticky="ColumnHeaders">
                            <columns>
                                <Column><Text text="{i18n>analytics.col.feature}" /></Column>
                                <Column><Text text="{i18n>analytics.col.category}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.count}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.users}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.trend}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <Text text="{ana>eventType}" />
                                    <Text text="{ana>category}" />
                                    <ObjectNumber number="{ana>count}" emphasized="false" />
                                    <ObjectNumber number="{ana>uniqueUsers}" emphasized="false" />
                                    <ObjectStatus
                                        text="{ana>trendPct}%"
                                        state="{= ${ana>trend} === 'up' ? 'Success' : ${ana>trend} === 'down' ? 'Error' : 'None'}"
                                        icon="{= ${ana>trend} === 'up' ? 'sap-icon://trend-up' : ${ana>trend} === 'down' ? 'sap-icon://trend-down' : 'sap-icon://less'}" />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 3: Underused Features ════════ -->
                <IconTabFilter key="underused" text="{i18n>analytics.underused}" icon="sap-icon://warning2">
                    <VBox class="sapUiSmallMargin">
                        <MessageStrip
                            text="{i18n>analytics.underused.info}"
                            type="Information"
                            showIcon="true"
                            class="sapUiSmallMarginBottom" />
                        <Table id="underusedTable"
                               items="{ana>/underused}"
                               growing="false"
                               sticky="ColumnHeaders">
                            <columns>
                                <Column><Text text="{i18n>analytics.col.route}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.views}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.users}" /></Column>
                                <Column><Text text="{i18n>analytics.col.status}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem highlight="{= ${ana>pageViews} === 0 ? 'Error' : 'Warning'}">
                                    <Text text="{ana>route}" />
                                    <ObjectNumber number="{ana>pageViews}" emphasized="false" />
                                    <ObjectNumber number="{ana>uniqueUsers}" emphasized="false" />
                                    <ObjectStatus
                                        text="{= ${ana>pageViews} === 0 ? 'Never used' : 'Low usage'}"
                                        state="{= ${ana>pageViews} === 0 ? 'Error' : 'Warning'}" />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 4: Workflow Funnels ════════ -->
                <IconTabFilter key="funnels" text="{i18n>analytics.funnels}" icon="sap-icon://process">
                    <VBox class="sapUiSmallMargin">
                        <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                            <Label text="{i18n>analytics.workflowType}" class="sapUiSmallMarginEnd" />
                            <Select id="workflowTypeSelect" change="onWorkflowTypeChange">
                                <core:Item key="" text="{i18n>analytics.all}" />
                                <core:Item key="mass_upload" text="Mass Upload" />
                                <core:Item key="bridge_create" text="Bridge Create" />
                                <core:Item key="inspection" text="Inspection" />
                            </Select>
                        </HBox>
                        <!-- Funnel Summary -->
                        <HBox justifyContent="SpaceBetween" wrap="Wrap" class="sapUiSmallMarginBottom">
                            <ObjectStatus title="{i18n>analytics.funnel.total}" text="{ana>/funnel/summary/total}" />
                            <ObjectStatus title="{i18n>analytics.funnel.completed}" text="{ana>/funnel/summary/completedCount}" state="Success" />
                            <ObjectStatus title="{i18n>analytics.funnel.abandoned}" text="{ana>/funnel/summary/abandonedCount}" state="Error" />
                            <ObjectStatus title="{i18n>analytics.funnel.completionRate}" text="{ana>/funnel/summary/completionRate}%" state="Information" />
                        </HBox>
                        <!-- Steps Table -->
                        <Table id="funnelStepsTable"
                               items="{ana>/funnel/steps}"
                               sticky="ColumnHeaders">
                            <columns>
                                <Column><Text text="{i18n>analytics.col.step}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.reached}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.reachedPct}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.dropoff}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem highlight="{= ${ana>dropoff} > 5 ? 'Warning' : 'None'}">
                                    <Text text="Step {ana>step}" />
                                    <ObjectNumber number="{ana>reached}" emphasized="false" />
                                    <ObjectNumber number="{ana>reachedPct}" unit="%" emphasized="false" />
                                    <ObjectNumber number="{ana>dropoff}"
                                                  state="{= ${ana>dropoff} > 5 ? 'Error' : 'None'}" />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 5: Errors ════════ -->
                <IconTabFilter key="errors" text="{i18n>analytics.errors}" icon="sap-icon://alert"
                               iconColor="Negative">
                    <VBox class="sapUiSmallMargin">
                        <!-- Spikes alert -->
                        <MessageStrip
                            visible="{ana>/hasSpikes}"
                            text="{i18n>analytics.errors.spikesDetected}"
                            type="Error"
                            showIcon="true"
                            class="sapUiSmallMarginBottom" />

                        <!-- Error Trends Table -->
                        <Table id="errorTrendsTable"
                               items="{ana>/errorTrends}"
                               growing="true"
                               growingThreshold="30"
                               sticky="ColumnHeaders">
                            <columns>
                                <Column><Text text="{i18n>analytics.col.date}" /></Column>
                                <Column><Text text="{i18n>analytics.col.errorType}" /></Column>
                                <Column><Text text="{i18n>analytics.col.errorCode}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.count}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <Text text="{ana>dt}" />
                                    <Text text="{ana>eventType}" />
                                    <Text text="{ana>errorCode}" />
                                    <ObjectNumber number="{ana>cnt}" emphasized="false" />
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Spikes Table -->
                        <Panel headerText="{i18n>analytics.errors.spikes}"
                               visible="{ana>/hasSpikes}"
                               class="sapUiSmallMarginTop">
                            <Table items="{ana>/errorSpikes}">
                                <columns>
                                    <Column><Text text="{i18n>analytics.col.date}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>analytics.col.count}" /></Column>
                                    <Column hAlign="End"><Text text="{i18n>analytics.col.avg7d}" /></Column>
                                    <Column><Text text="{i18n>analytics.col.severity}" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem highlight="Error">
                                        <Text text="{ana>date}" />
                                        <ObjectNumber number="{ana>count}" state="Error" />
                                        <ObjectNumber number="{ana>avg7d}" emphasized="false" />
                                        <ObjectStatus text="{ana>severity}" state="Error" />
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Panel>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 6: Performance ════════ -->
                <IconTabFilter key="performance" text="{i18n>analytics.performance}" icon="sap-icon://performance">
                    <VBox class="sapUiSmallMargin">
                        <Table id="performanceTable"
                               items="{ana>/hotspots}"
                               growing="false"
                               sticky="ColumnHeaders">
                            <columns>
                                <Column><Text text="{i18n>analytics.col.route}" /></Column>
                                <Column><Text text="{i18n>analytics.col.action}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.avgMs}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.maxMs}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.samples}" /></Column>
                                <Column hAlign="End"><Text text="{i18n>analytics.col.regression}" /></Column>
                            </columns>
                            <items>
                                <ColumnListItem highlight="{= ${ana>regressed} ? 'Error' : 'None'}">
                                    <Text text="{ana>targetRoute}" />
                                    <Text text="{ana>eventType}" />
                                    <ObjectNumber number="{ana>avgMs}" unit="ms" state="{= ${ana>avgMs} > 5000 ? 'Error' : ${ana>avgMs} > 3000 ? 'Warning' : 'Success'}" />
                                    <ObjectNumber number="{ana>maxMs}" unit="ms" emphasized="false" />
                                    <ObjectNumber number="{ana>cnt}" emphasized="false" />
                                    <ObjectStatus
                                        text="{= ${ana>regressionPct} > 0 ? '+' + ${ana>regressionPct} + '%' : ${ana>regressionPct} + '%'}"
                                        state="{= ${ana>regressed} ? 'Error' : ${ana>regressionPct} &lt; -10 ? 'Success' : 'None'}" />
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ════════ TAB 7: Configuration ════════ -->
                <IconTabFilter key="config" text="{i18n>analytics.config}" icon="sap-icon://action-settings">
                    <VBox class="sapUiSmallMargin">
                        <Panel headerText="{i18n>analytics.config.general}">
                            <VBox class="sapUiSmallMargin">
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.enabled}" width="12rem" />
                                    <Switch id="cfgEnabled" state="{cfg>/enabled}" change="onConfigChange" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.sampleRate}" width="12rem" />
                                    <Slider id="cfgSampleRate" value="{cfg>/sampleRatePct}" min="0" max="100" step="5"
                                            enableTickmarks="true" change="onConfigChange" width="20rem" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.flushInterval}" width="12rem" />
                                    <Select id="cfgFlushInterval" selectedKey="{cfg>/flushIntervalMs}" change="onConfigChange">
                                        <core:Item key="10000" text="10 seconds" />
                                        <core:Item key="30000" text="30 seconds" />
                                        <core:Item key="60000" text="1 minute" />
                                    </Select>
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.rateLimit}" width="12rem" />
                                    <Input id="cfgRateLimit" value="{cfg>/rateLimitPerMin}" type="Number" width="8rem" change="onConfigChange" />
                                </HBox>
                            </VBox>
                        </Panel>

                        <Panel headerText="{i18n>analytics.config.retention}" class="sapUiSmallMarginTop">
                            <VBox class="sapUiSmallMargin">
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.rawRetention}" width="12rem" />
                                    <Input id="cfgRawRetention" value="{cfg>/retentionDays}" type="Number" width="8rem" change="onConfigChange" />
                                    <Label text="days" class="sapUiSmallMarginBegin" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.dailyRetention}" width="12rem" />
                                    <Input id="cfgDailyRetention" value="{cfg>/dailyRetentionDays}" type="Number" width="8rem" change="onConfigChange" />
                                    <Label text="days" class="sapUiSmallMarginBegin" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.weeklyRetention}" width="12rem" />
                                    <Input id="cfgWeeklyRetention" value="{cfg>/weeklyRetentionDays}" type="Number" width="8rem" change="onConfigChange" />
                                    <Label text="days" class="sapUiSmallMarginBegin" />
                                </HBox>
                                <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Label text="{i18n>analytics.config.monthlyRetention}" width="12rem" />
                                    <Input id="cfgMonthlyRetention" value="{cfg>/monthlyRetentionDays}" type="Number" width="8rem" change="onConfigChange" />
                                    <Label text="days" class="sapUiSmallMarginBegin" />
                                </HBox>
                            </VBox>
                        </Panel>

                        <HBox class="sapUiSmallMarginTop" justifyContent="SpaceBetween">
                            <Button text="{i18n>analytics.config.save}" type="Emphasized" press="onSaveConfig" />
                            <HBox>
                                <Button text="{i18n>analytics.config.runRollup}" press="onRunRollup" type="Accept" class="sapUiSmallMarginEnd" />
                                <Button text="{i18n>analytics.config.runPurge}" press="onRunPurge" type="Reject" />
                            </HBox>
                        </HBox>
                    </VBox>
                </IconTabFilter>

              </items>
            </IconTabBar>
        </content>
    </Page>
</mvc:View>
