<!-- ============================================================
     LicenseConfig.view.xml
     Multi-tenant capability licensing configuration page.
     Layout: left tenant list | center capability toggles | right role matrix
     Access: Admin role only
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.LicenseConfig"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:table="sap.ui.table"
    displayBlock="true">

    <Page
        id="licenseConfigPage"
        title="Licence &amp; Capability Configuration"
        showNavButton="true"
        navButtonPress="onNavBack"
        class="nhvrAdminPage">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" type="Transparent" press="onNavBack"/>
                    <Title text="Licence &amp; Capability Configuration" level="H3"
                        class="sapUiSmallMarginBegin"/>
                </contentLeft>
                <contentRight>
                    <Button id="btnNewTenant"
                        text="New Client"
                        icon="sap-icon://add"
                        type="Emphasized"
                        press="onNewTenant"
                        class="sapUiSmallMarginEnd"/>
                    <Button icon="sap-icon://sys-help" type="Transparent"
                        press="onOpenHelp" tooltip="Help"/>
                </contentRight>
            </Bar>
        </customHeader>

        <!-- ── Training Banner ─────────────────────────────────── -->
        <MessageStrip id="trainingBanner" text="TRAINING ENVIRONMENT — changes here affect the demo dataset only"
            type="Warning" showIcon="true" visible="false" class="sapUiSmallMargin"/>

        <content>
            <!-- ══════════════════════════════════════════════════
                 MAIN LAYOUT: Tenant List (left) | Config Panel (right)
                 ══════════════════════════════════════════════════ -->
            <HBox height="calc(100vh - 120px)" class="nhvrLicenseLayout">

                <!-- ── LEFT PANE: Tenant / Client List ─────────── -->
                <VBox width="280px" class="nhvrLicenseTenantPanel sapUiNoContentPadding">
                    <Toolbar class="nhvrLicensePanelHeader">
                        <Title text="Client Organisations" level="H5"/>
                        <ToolbarSpacer/>
                        <Button icon="sap-icon://refresh" type="Transparent"
                            press="onRefreshTenants" tooltip="Refresh list"/>
                    </Toolbar>
                    <List id="tenantList"
                        mode="SingleSelectMaster"
                        selectionChange="onTenantSelect"
                        noDataText="No client organisations found"
                        items="{licenseModel>/tenants}"
                        class="nhvrLicenseTenantList">
                        <items>
                            <ObjectListItem
                                title="{licenseModel>displayName}"
                                intro="{licenseModel>tenantCode}"
                                number="{licenseModel>licenseStatus}"
                                numberState="{= ${licenseModel>licenseStatus} === 'ACTIVE' ? 'Success'
                                               : ${licenseModel>licenseStatus} === 'TRIAL' ? 'Warning'
                                               : 'Error' }"
                                type="Active">
                                <attributes>
                                    <ObjectAttribute
                                        title="Jurisdiction"
                                        text="{licenseModel>jurisdiction}"/>
                                </attributes>
                                <firstStatus>
                                    <ObjectStatus
                                        text="{= ${licenseModel>isActive} ? 'Active' : 'Inactive'}"
                                        state="{= ${licenseModel>isActive} ? 'Success' : 'Error'}"/>
                                </firstStatus>
                            </ObjectListItem>
                        </items>
                    </List>
                </VBox>

                <!-- ── CENTER PANE: Tenant Detail + Capability Grid ─ -->
                <VBox class="nhvrLicenseCenterPanel sapUiNoContentPadding" width="100%">

                    <!-- No selection placeholder -->
                    <VBox id="noTenantSelected" class="nhvrEmptyState sapUiLargeMarginTop" visible="true">
                        <core:Icon src="sap-icon://org-chart" size="3rem" color="#8396A8"
                            class="sapUiSmallMarginBottom"/>
                        <Title text="Select a client organisation" level="H5"
                            class="sapUiSmallMarginBottom"/>
                        <Text text="Choose a client from the left panel to view and configure its licensed capabilities."
                            textAlign="Center" class="nhvrSubText"/>
                    </VBox>

                    <!-- Tenant detail + capabilities (shown when tenant selected) -->
                    <VBox id="tenantDetailPanel" visible="false" class="sapUiSmallMargin">

                        <!-- ── Tenant Detail Form ─────────────────── -->
                        <Panel id="tenantFormPanel" class="nhvrLicenseCard sapUiSmallMarginBottom"
                            headerText="Client Details" expandable="true" expanded="true">
                            <content>
                                <form:SimpleForm editable="true" layout="ResponsiveGridLayout"
                                    labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                    emptySpanL="0" emptySpanM="0"
                                    columnsL="2" columnsM="2">
                                    <form:content>
                                        <Label text="Client Code" required="true"/>
                                        <Input id="tfTenantCode" value="{licenseModel>/selectedTenant/tenantCode}"
                                            placeholder="e.g. NSW_RMS" maxLength="50"/>

                                        <Label text="Organisation Name" required="true"/>
                                        <Input id="tfDisplayName" value="{licenseModel>/selectedTenant/displayName}"
                                            placeholder="Full legal name" maxLength="200"/>

                                        <Label text="Short Name"/>
                                        <Input id="tfShortName" value="{licenseModel>/selectedTenant/shortName}"
                                            maxLength="50"/>

                                        <Label text="Jurisdiction"/>
                                        <Select id="selJurisdiction"
                                            selectedKey="{licenseModel>/selectedTenant/jurisdiction}"/>

                                        <Label text="Licence Status"/>
                                        <Select id="selLicenseStatus"
                                            selectedKey="{licenseModel>/selectedTenant/licenseStatus}">
                                            <core:Item key="ACTIVE"    text="Active"/>
                                            <core:Item key="TRIAL"     text="Trial"/>
                                            <core:Item key="SUSPENDED" text="Suspended"/>
                                            <core:Item key="EXPIRED"   text="Expired"/>
                                        </Select>

                                        <Label text="Licence Start"/>
                                        <DatePicker id="dpLicenseStart"
                                            value="{licenseModel>/selectedTenant/licenseStartDate}"
                                            valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                                        <Label text="Licence Expiry"/>
                                        <DatePicker id="dpLicenseEnd"
                                            value="{licenseModel>/selectedTenant/licenseEndDate}"
                                            valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                                        <Label text="Max Users"/>
                                        <Input id="tfMaxUsers" value="{licenseModel>/selectedTenant/maxUsers}"
                                            type="Number"/>

                                        <Label text="Contact Email"/>
                                        <Input id="tfContactEmail" value="{licenseModel>/selectedTenant/contactEmail}"
                                            type="Email" maxLength="200"/>

                                        <Label text="Contact Name"/>
                                        <Input id="tfContactName" value="{licenseModel>/selectedTenant/contactName}"
                                            maxLength="200"/>

                                        <Label text="Notes"/>
                                        <TextArea id="tfNotes" value="{licenseModel>/selectedTenant/notes}"
                                            rows="2" maxLength="1000" growing="true"/>
                                    </form:content>
                                </form:SimpleForm>
                                <HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginEnd">
                                    <Button text="Save Client Details" icon="sap-icon://save"
                                        type="Emphasized" press="onSaveTenantDetails"
                                        class="sapUiSmallMarginEnd"/>
                                    <Button text="Deactivate" icon="sap-icon://locked"
                                        type="Negative" press="onDeactivateTenant"/>
                                </HBox>
                            </content>
                        </Panel>

                        <!-- ── Capability Grid ────────────────────── -->
                        <Panel class="nhvrLicenseCard" headerText="Licensed Capabilities" expandable="false">
                            <headerToolbar>
                                <Toolbar>
                                    <Title text="Licensed Capabilities" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Button text="Save Capabilities" icon="sap-icon://save"
                                        type="Emphasized" press="onSaveCapabilities"/>
                                    <Button text="Enable All" icon="sap-icon://accept"
                                        type="Transparent" press="onEnableAllCapabilities"
                                        class="sapUiSmallMarginBegin"/>
                                </Toolbar>
                            </headerToolbar>
                            <content>
                                <!-- Category tabs -->
                                <IconTabBar id="capabilityTabBar" expandable="false"
                                    select="onCapabilityTabChange" class="nhvrCapTabBar">
                                    <items>
                                        <IconTabFilter text="All" key="ALL" icon="sap-icon://grid"/>
                                        <IconTabFilter text="Core" key="CORE" icon="sap-icon://home"/>
                                        <IconTabFilter text="Inspection" key="INSPECTION" icon="sap-icon://inspect"/>
                                        <IconTabFilter text="Compliance" key="COMPLIANCE" icon="sap-icon://permission"/>
                                        <IconTabFilter text="Analytics" key="ANALYTICS" icon="sap-icon://bar-chart"/>
                                        <IconTabFilter text="Admin" key="ADMIN" icon="sap-icon://settings"/>
                                        <IconTabFilter text="Integration" key="INTEGRATION" icon="sap-icon://it-system"/>
                                    </items>
                                </IconTabBar>

                                <!-- Capability card grid -->
                                <VBox id="capabilityGrid" class="nhvrCapabilityGrid sapUiSmallMarginTop">
                                    <!-- Rendered dynamically by _renderCapabilityGrid() -->
                                </VBox>
                            </content>
                        </Panel>
                    </VBox>
                </VBox>

            </HBox>
        </content>

        <!-- ── Role Matrix Dialog ─────────────────────────────── -->
        <dependents>
            <Dialog id="roleMatrixDialog"
                title="Role Access Matrix"
                contentWidth="640px"
                resizable="true" draggable="true">
                <customHeader>
                    <Bar>
                        <contentLeft>
                            <core:Icon src="sap-icon://role" size="1.1rem" color="#1065B4"
                                class="sapUiSmallMarginEnd"/>
                            <Title id="roleMatrixTitle" text="Role Access — " level="H4"/>
                        </contentLeft>
                        <contentRight>
                            <Button icon="sap-icon://decline" type="Transparent"
                                press="onCloseRoleMatrix"/>
                        </contentRight>
                    </Bar>
                </customHeader>
                <content>
                    <VBox class="sapUiSmallMargin">
                        <Text id="roleMatrixDesc" text="" wrapping="true"
                            class="nhvrSubText sapUiSmallMarginBottom"/>

                        <Table id="roleMatrixTable"
                            mode="None"
                            class="nhvrRoleMatrixTable">
                            <columns>
                                <Column width="140px"><Text text="Role"/></Column>
                                <Column hAlign="Center" width="80px"><Text text="View"/></Column>
                                <Column hAlign="Center" width="80px"><Text text="Edit"/></Column>
                                <Column hAlign="Center" width="80px"><Text text="Admin"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{licenseModel>roleLabel}"/>
                                        <CheckBox selected="{licenseModel>canView}"
                                            select="onRoleMatrixChange"/>
                                        <CheckBox selected="{licenseModel>canEdit}"
                                            select="onRoleMatrixChange"/>
                                        <CheckBox selected="{licenseModel>canAdmin}"
                                            select="onRoleMatrixChange"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </content>
                <buttons>
                    <Button text="Save Role Matrix" type="Emphasized"
                        press="onSaveRoleMatrix" icon="sap-icon://save"/>
                    <Button text="Cancel" type="Transparent" press="onCloseRoleMatrix"/>
                </buttons>
            </Dialog>

            <!-- ── New Tenant Dialog ──────────────────────────── -->
            <Dialog id="newTenantDialog"
                title="Add New Client Organisation"
                contentWidth="520px">
                <content>
                    <form:SimpleForm editable="true" layout="ResponsiveGridLayout"
                        class="sapUiSmallMargin"
                        labelSpanL="4" labelSpanM="4" labelSpanS="12"
                        emptySpanL="0" emptySpanM="0"
                        columnsL="1" columnsM="1">
                        <form:content>
                            <Label text="Client Code" required="true"/>
                            <Input id="newTenantCode" placeholder="e.g. QLD_TMR" maxLength="50"/>

                            <Label text="Organisation Name" required="true"/>
                            <Input id="newTenantName" placeholder="Full legal name" maxLength="200"/>

                            <Label text="Short Name"/>
                            <Input id="newTenantShort" maxLength="50"/>

                            <Label text="Jurisdiction"/>
                            <Select id="newTenantJurisdiction"/>

                            <Label text="Licence Type"/>
                            <Select id="newTenantLicenseStatus">
                                <core:Item key="ACTIVE" text="Active"/>
                                <core:Item key="TRIAL"  text="Trial"/>
                            </Select>

                            <Label text="Licence Start"/>
                            <DatePicker id="newTenantLicenseStart"
                                valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                            <Label text="Licence Expiry"/>
                            <DatePicker id="newTenantLicenseEnd"
                                valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                            <Label text="Contact Email"/>
                            <Input id="newTenantEmail" type="Email" maxLength="200"/>

                            <Label text="Contact Name"/>
                            <Input id="newTenantContact" maxLength="200"/>

                            <Label text="Pre-select capabilities"/>
                            <Select id="newTenantPreset">
                                <core:Item key="FULL"     text="Full Access (all capabilities)"/>
                                <core:Item key="STANDARD" text="Standard (Core + Inspections + Defects)"/>
                                <core:Item key="CORE"     text="Core Only (Bridge Registry + Map + Reports)"/>
                                <core:Item key="NONE"     text="None (configure manually)"/>
                            </Select>
                        </form:content>
                    </form:SimpleForm>
                </content>
                <buttons>
                    <Button text="Create Client" type="Emphasized"
                        icon="sap-icon://accept" press="onConfirmNewTenant"/>
                    <Button text="Cancel" type="Transparent" press="onCancelNewTenant"/>
                </buttons>
            </Dialog>
        </dependents>

    </Page>
</mvc:View>
