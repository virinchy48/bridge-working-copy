<!-- ============================================================
     NHVR Bridges List View — Bridge Asset Registry
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.Bridges"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:vm="sap.m"
    xmlns:unified="sap.ui.unified"
    xmlns:ui5table="sap.ui.table"
    displayBlock="true">

    <f:DynamicPage id="bridgesPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Bridge Asset Registry" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Bridges" level="H2"/>
                </f:snappedHeading>
                <f:actions>
                    <Button id="btnAddBridge" text="Add Bridge" icon="sap-icon://add" press="onAddBridge" type="Emphasized"/>
                    <Button text="Go" icon="sap-icon://search" press="onSearch" type="Default"/>
                    <Button text="Refresh" icon="sap-icon://refresh" press="onRefresh" type="Transparent"/>
                    <Button icon="sap-icon://hint" type="Transparent" press="onInfoPressBridges"
                        tooltip="Column and field guide"/>
                    <Button text="Home" icon="sap-icon://home" press="onNavHome" type="Transparent"/>
                </f:actions>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Bridges"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <!-- ── Filter Bar ──────────────────────────── -->
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom" alignItems="Center">
                    <!-- Row 1: Search + State + Condition + PostingStatus -->
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Search" design="Bold" labelFor="searchField"/>
                        <SearchField id="searchField" width="240px" placeholder="Bridge ID, name, route…" search="onSearch" liveChange="onLiveSearch"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="State" design="Bold" labelFor="filterState"/>
                        <Select id="filterState" change="onFilterChange" width="120px">
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Condition" design="Bold" labelFor="filterCondition"/>
                        <Select id="filterCondition" change="onFilterChange" width="130px">
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Status" design="Bold" labelFor="filterPosting"/>
                        <Select id="filterPosting" change="onFilterChange" width="150px">
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Scour Risk" design="Bold" labelFor="filterScour"/>
                        <Select id="filterScour" change="onFilterChange" width="130px">
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="NHVR Assessed" design="Bold" labelFor="filterNhvr"/>
                        <Select id="filterNhvr" change="onFilterChange" width="150px">
                            <core:Item key="ALL" text="All"/>
                            <core:Item key="YES" text="NHVR Assessed"/>
                            <core:Item key="NO"  text="Not Assessed"/>
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Freight Route" design="Bold" labelFor="filterFreight"/>
                        <Select id="filterFreight" change="onFilterChange" width="150px">
                            <core:Item key="ALL" text="All"/>
                            <core:Item key="YES" text="Freight Route"/>
                            <core:Item key="NO"  text="Not Freight"/>
                        </Select>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Risk Band" design="Bold" labelFor="filterRiskBand"/>
                        <Select id="filterRiskBand" change="onFilterChange" width="130px">
                        </Select>
                    </VBox>
                    <VBox alignItems="End" class="sapUiSmallMarginTop">
                        <Button text="Clear Filters" icon="sap-icon://clear-filter" press="onClearFilters" type="Transparent"/>
                    </VBox>
                </HBox>

                <!-- ── Advanced Filter Panel (AND/OR builder) ──── -->
                <Panel id="advFilterPanel" expandable="true" expanded="false"
                    headerText="Advanced Filter — Slice &amp; Dice Bridge Data"
                    class="sapUiSmallMarginTop">
                    <content>
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

                            <!-- Logic operator selection -->
                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                <Label text="Logic:" design="Bold" class="sapUiTinyMarginEnd"/>
                                <SegmentedButton id="advLogicMode" selectionChange="onAdvLogicChange">
                                    <items>
                                        <SegmentedButtonItem key="AND" text="AND (all must match)" icon="sap-icon://combine"/>
                                        <SegmentedButtonItem key="OR"  text="OR (any must match)"  icon="sap-icon://split"/>
                                    </items>
                                </SegmentedButton>
                                <Button text="Save as Preset" icon="sap-icon://save"
                                    press="onSaveFilterPreset" type="Transparent" class="sapUiSmallMarginBegin"/>
                            </HBox>

                            <!-- Dynamic criteria rows — each row is: [field] [operator] [value] [remove] -->
                            <VBox id="advFilterCriteria"/>

                            <HBox class="sapUiSmallMarginTop" alignItems="Center">
                                <Button text="+ Add Criteria" icon="sap-icon://add"
                                    press="onAddFilterCriteria" type="Ghost" class="sapUiTinyMarginEnd"/>
                                <Button text="Apply" icon="sap-icon://filter"
                                    press="onApplyAdvancedFilter" type="Emphasized" class="sapUiTinyMarginEnd"/>
                                <Button text="Clear" icon="sap-icon://clear-filter"
                                    press="onClearAdvancedFilter" type="Transparent"/>
                            </HBox>

                            <!-- Saved presets strip -->
                            <HBox id="filterPresetsBox" class="sapUiSmallMarginTop" wrap="Wrap" visible="false">
                                <Label text="Saved Presets:" design="Bold" class="sapUiTinyMarginEnd sapUiTinyMarginTop"/>
                            </HBox>
                        </VBox>
                    </content>
                </Panel>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="nhvrApp">

                <!-- ── Variant Management Bar ──────────────────── -->
                <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop">
                    <Label text="View:" design="Bold" class="sapUiTinyMarginEnd"/>
                    <VariantManagement id="bridgeVariantMgmt"
                        save="onVariantSave"
                        manage="onVariantManage"
                        select="onVariantSelect"
                        class="sapUiTinyMarginEnd"/>
                </HBox>

                <!-- ── Dashboard Drill-Down Context Banner ──────── -->
                <MessageStrip id="dashFilterStrip" text="" type="Information" showIcon="true"
                    showCloseButton="true" visible="false"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"
                    close="onDashFilterDismiss"/>

                <!-- ── Map Selection Filter Banner ──────────────── -->
                <MessageStrip id="mapFilterBanner"
                    text="Map selection active"
                    type="Information" showIcon="true" showCloseButton="true"
                    visible="false" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"
                    close="onClearMapFilter"/>

                <!-- ── KPI Summary ──────────────────────────────── -->
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop sapUiSmallMarginBottom">
                    <ObjectStatus id="kpiTotal"    text="— Total"          state="None"    class="sapUiSmallMarginEnd"/>
                    <ObjectStatus id="kpiClosed"   text="— Closed"         state="Error"   class="sapUiSmallMarginEnd"/>
                    <ObjectStatus id="kpiPosted"   text="— Posted"         state="Warning" class="sapUiSmallMarginEnd"/>
                    <ObjectStatus id="kpiCritical" text="— Critical"       state="Error"   class="sapUiSmallMarginEnd"/>
                    <ObjectStatus id="kpiScour"    text="— High Scour Risk" state="Error"  class="sapUiSmallMarginEnd"/>
                    <ObjectStatus id="kpiNhvr"     text="— NHVR Assessed"  state="Success" class="sapUiSmallMarginEnd"/>
                </HBox>

                <!-- ── Active Filter Chips ─────────────────────── -->
                <HBox id="activeFilterChipBar" visible="false" class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom" alignItems="Center">
                    <items>
                        <Text text="Active filters:" class="sapUiSmallMarginEnd" wrapping="false"/>
                        <Tokenizer id="activeFilterBox"/>
                        <Text id="activeFilterCount" text="" class="sapUiSmallMarginBegin"/>
                        <Button text="Clear all" type="Transparent" press="onClearFilters" class="sapUiTinyMarginBegin"/>
                    </items>
                </HBox>

                <!-- ── Skeleton Loading Strip ───────────────────────── -->
                <VBox id="bridgeSkeletonLoader" visible="false"
                    class="nhvrSkeletonBox sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                    <HBox class="nhvrSkeletonRow nhvrSkeletonRowH36 sapUiTinyMarginBottom"/>
                    <HBox class="nhvrSkeletonRow nhvrSkeletonRowH28 nhvrSkeletonRowW85 sapUiTinyMarginBottom"/>
                    <HBox class="nhvrSkeletonRow nhvrSkeletonRowH28 nhvrSkeletonRowW70 sapUiTinyMarginBottom"/>
                    <HBox class="nhvrSkeletonRow nhvrSkeletonRowH28 nhvrSkeletonRowW90 sapUiTinyMarginBottom"/>
                    <HBox class="nhvrSkeletonRow nhvrSkeletonRowH28 nhvrSkeletonRowW75 sapUiTinyMarginBottom"/>
                </VBox>

                <!-- ── Bridge Table (sap.ui.table.Table — ALV Grid style) ── -->
                <ui5table:Table id="bridgeTable"
                    rows="{bridges>/items}"
                    selectionMode="MultiToggle"
                    rowSelectionChange="onSelectionChange"
                    cellClick="onBridgeCellClick"
                    alternateRowColors="true"
                    visibleRowCountMode="Auto"
                    minAutoRowCount="10"
                    fixedColumnCount="2"
                    enableSelectAll="true"
                    columnSelect="onBridgeColumnSort"
                    class="nhvrGridTable sapUiSmallMarginBeginEnd">
                    <ui5table:noData>
                        <VBox alignItems="Center" class="sapUiMediumMarginTop sapUiMediumMarginBottom">
                            <core:Icon src="sap-icon://filter" size="3rem" color="#8396A8" class="sapUiSmallMarginBottom"/>
                            <Title text="No bridges found" level="H3" class="sapUiSmallMarginBottom"/>
                            <Text text="No bridges match your current filters." class="nhvrSubText"/>
                            <Text text="Try adjusting your search criteria or clearing the filters." class="nhvrSubText sapUiTinyMarginBottom"/>
                            <Button text="Clear All Filters" icon="sap-icon://clear-filter"
                                press="onClearFilters" type="Emphasized" class="sapUiSmallMarginTop"/>
                        </VBox>
                    </ui5table:noData>

                    <ui5table:extension>
                        <OverflowToolbar>
                            <!-- Record count (ALV-style, updated dynamically) -->
                            <Text id="alvRecordCount" text="" class="nhvrSubText"/>
                            <ToolbarSeparator/>
                            <Title id="tableTitle" text="Bridges" level="H3"/>
                            <ToolbarSpacer/>
                            <Button id="btnViewOnMap" icon="sap-icon://map-2" text="View on Map"
                                press="onViewOnMap" type="Emphasized" visible="false"/>
                            <!-- ALV-consistent action group -->
                            <Button icon="sap-icon://sort" text="Sort"
                                press="onAlvSort" type="Transparent" tooltip="Sort options"/>
                            <Button id="btnTableSettings" icon="sap-icon://action-settings"
                                text="Columns" press="onOpenTableSettings"
                                type="Transparent" tooltip="Personalise columns and sort order"/>
                            <ToolbarSeparator/>
                            <Button id="btnExportBridges" icon="sap-icon://excel-attachment"
                                text="Excel" press="onAlvExportExcel"
                                type="Transparent" tooltip="Export current filtered results to Excel (.xlsx)"/>
                            <Button id="btnExportCsv" text="CSV" icon="sap-icon://download"
                                press="onAlvExportCsv" type="Transparent" tooltip="Export to CSV with all fields"/>
                            <Button icon="sap-icon://pdf-attachment" text="Print"
                                press="onAlvExportPdf" type="Transparent" tooltip="Print or save as PDF"/>
                            <ToolbarSeparator/>
                            <Button icon="sap-icon://refresh" text="Refresh"
                                press="onAlvRefresh" type="Transparent" tooltip="Refresh data from server"/>
                            <Button icon="sap-icon://map-2" text="Map" press="onNavToMap" type="Transparent"/>
                            <Button icon="sap-icon://bar-chart" text="Reports" press="onNavToReports" type="Transparent"/>
                            <Button id="btnDownloadTemplate" text="Template" icon="sap-icon://attachment"
                                press="onDownloadBridgeTemplate" type="Transparent" tooltip="Download CSV upload template"
                                visible="{ui>/canTemplate}"/>
                            <Button id="btnBulkUpload" text="Upload" icon="sap-icon://upload"
                                press="onOpenBulkUpload" type="Transparent" tooltip="Bulk upload bridges from CSV"
                                visible="{ui>/canUpload}"/>
                        </OverflowToolbar>
                    </ui5table:extension>

                    <ui5table:columns>
                        <!-- Columns built programmatically in _buildBridgeColumns() -->
                    </ui5table:columns>
                </ui5table:Table>

                <!-- ── Load More Bar ───────────────────────────── -->
                <HBox id="loadMoreBar" justifyContent="Center" alignItems="Center"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom" visible="true">
                    <Button id="btnLoadMore" text="Load More" icon="sap-icon://add"
                        press="onLoadMoreBridges" type="Emphasized" visible="false"/>
                    <Text id="loadMoreInfo" text="" class="sapUiSmallMarginBegin"/>
                </HBox>

            </VBox>
        </f:content>
    </f:DynamicPage>

    <!-- ── Sort Dialog ────────────────────────────────────── -->
    <ViewSettingsDialog id="sortDialog" confirm="onSortConfirm">
        <sortItems>
            <ViewSettingsItem key="bridgeId" text="Bridge ID" selected="true"/>
            <ViewSettingsItem key="name" text="Name"/>
            <ViewSettingsItem key="state" text="State"/>
            <ViewSettingsItem key="condition" text="Condition"/>
            <ViewSettingsItem key="conditionRating" text="Rating"/>
            <ViewSettingsItem key="postingStatus" text="Status"/>
            <ViewSettingsItem key="yearBuilt" text="Year Built"/>
            <ViewSettingsItem key="scourRisk" text="Scour Risk"/>
            <ViewSettingsItem key="inspectionDate" text="Inspection Date"/>
        </sortItems>
    </ViewSettingsDialog>

    <!-- ── Table Settings Dialog — redesigned for end users ──── -->
    <Dialog id="columnPickerDialog" title="Choose Your Columns"
        contentWidth="560px" contentHeight="82vh"
        verticalScrolling="false" draggable="true" resizable="true">
        <content>

            <!-- 1. What does this screen do? -->
            <MessageStrip
                text="Tick the columns you want to see in the Bridge list. Your selection is remembered between sessions."
                type="Information" showIcon="true" showCloseButton="false"
                class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiTinyMarginBottom"/>

            <!-- 2. Quick Presets — one click applies a named set of columns -->
            <VBox class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom">
                <Label text="Quick presets — click to apply instantly:" design="Bold"
                    class="sapUiTinyMarginBottom"/>
                <HBox wrap="Wrap">
                    <Button id="btnPresetEssential"    text="Essential"
                        icon="sap-icon://filter"      press="onPresetEssential"
                        type="Ghost" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        tooltip="Bridge ID, Name, State, Condition, Status — the core columns"/>
                    <Button id="btnPresetInspection"   text="Inspection View"
                        icon="sap-icon://inspect"     press="onPresetInspection"
                        type="Ghost" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        tooltip="Adds inspection dates, condition rating and scour risk"/>
                    <Button id="btnPresetRestrictions" text="Load &amp; Permits"
                        icon="sap-icon://alert"       press="onPresetRestrictions"
                        type="Ghost" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        tooltip="Adds load rating, NHVR approval class and clearance height"/>
                    <Button id="btnPresetFullDetail"   text="All Columns"
                        icon="sap-icon://table-view"  press="onPresetFullDetail"
                        type="Ghost" class="sapUiTinyMarginBottom"
                        tooltip="Show all 47 columns — useful for export and reporting"/>
                </HBox>
            </VBox>

            <!-- 3. Search + Category filter + Show/Hide All -->
            <HBox alignItems="Center" wrap="Wrap"
                class="sapUiSmallMarginBeginEnd sapUiTinyMarginTop sapUiTinyMarginBottom">
                <SearchField id="colPickerSearch" liveChange="onColPickerSearch"
                    placeholder="Find a column… e.g. weight, condition, date"
                    width="210px" class="sapUiTinyMarginEnd"/>
                <Label text="Category:" class="sapUiTinyMarginEnd" labelFor="colSectionSelect"/>
                <Select id="colSectionSelect" width="200px" change="onColSectionFilter"
                    class="sapUiTinyMarginEnd"
                    tooltip="Show columns from one category only">
                    <core:Item key="" text="All categories"/>
                    <core:Item key="Identity &amp; Registration"       text="Identity &amp; Registration"/>
                    <core:Item key="Physical &amp; Geometric"          text="Physical &amp; Geometric"/>
                    <core:Item key="Load Capacity, Safety &amp; NHVR"  text="Load Capacity, Safety &amp; NHVR"/>
                    <core:Item key="Inspection, Condition &amp; Health" text="Inspection, Condition &amp; Health"/>
                    <core:Item key="Risk, Criticality &amp; Resilience" text="Risk, Criticality &amp; Resilience"/>
                    <core:Item key="Financial &amp; Investment"         text="Financial &amp; Investment"/>
                    <core:Item key="Geospatial &amp; Governance"        text="Geospatial &amp; Governance"/>
                </Select>
                <Button text="Show All" press="onColPickerSelectAll" type="Ghost"
                    class="sapUiTinyMarginEnd"
                    tooltip="Tick all columns in the current category view"/>
                <Button text="Hide All" press="onColPickerDeselectAll" type="Ghost"
                    tooltip="Untick all optional columns"/>
            </HBox>

            <!-- 4. Status row: column count + Saved Layouts management -->
            <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom">
                <Text id="colPickerStats" text="— columns selected" class="nhvrSubText"/>
                <ToolbarSpacer/>
                <Label text="Saved layout:" class="sapUiTinyMarginEnd nhvrSubText"
                    labelFor="colVariantSelect"/>
                <Select id="colVariantSelect" width="145px" change="onVariantSelected"
                    tooltip="Load a previously saved column layout"/>
                <Button icon="sap-icon://save" type="Ghost" press="onSaveVariant"
                    class="sapUiTinyMarginBegin"
                    tooltip="Save the current column selection with a name so you can reuse it"/>
                <Button icon="sap-icon://delete" type="Ghost" press="onDeleteVariant"
                    class="sapUiTinyMarginBegin"
                    tooltip="Delete the selected saved layout"/>
            </HBox>

            <!-- 5. Column checklist (scrollable) -->
            <ScrollContainer height="calc(82vh - 310px)" vertical="true" horizontal="false">
                <List id="columnPickerList" mode="MultiSelect" includeItemInSelection="true"
                    selectionChange="onColPickerSelectionChange"
                    footerText="Bridge ID is always shown — it cannot be hidden."/>
            </ScrollContainer>

        </content>
        <buttons>
            <Button text="Apply" type="Emphasized" press="onApplyColumnPicker"/>
            <Button text="Reset to Defaults" type="Transparent" press="onResetColumnPicker"
                tooltip="Restore the default set of columns"/>
            <Button text="Cancel" press="onCloseColumnPicker"/>
        </buttons>
    </Dialog>

    <!-- ── Bridge ID Value Help Dialog (for Advanced Filter) ──── -->
    <Dialog id="bridgePickerDialog" title="Select a Bridge"
        contentWidth="480px" contentHeight="65vh"
        verticalScrolling="false" draggable="true">
        <subHeader>
            <Bar>
                <contentMiddle>
                    <SearchField id="bridgePickerSearch"
                        placeholder="Type Bridge ID or name to search…"
                        width="100%" search="onBridgePickerSearch"
                        liveChange="onBridgePickerSearch"/>
                </contentMiddle>
            </Bar>
        </subHeader>
        <content>
            <ScrollContainer height="calc(65vh - 120px)" vertical="true" horizontal="false">
                <List id="bridgePickerList" mode="SingleSelectMaster"
                    selectionChange="onBridgePickerSelect"
                    noDataText="Type to search for a bridge…">
                </List>
            </ScrollContainer>
        </content>
        <beginButton>
            <Button text="Select" type="Emphasized" press="onBridgePickerConfirm"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onBridgePickerCancel"/>
        </endButton>
    </Dialog>

    <!-- ── CSV Export Dialog ─────────────────────────────────── -->
    <Dialog id="csvExportDialog" title="Export Bridges to CSV" contentWidth="360px">
        <content>
            <VBox class="sapUiSmallMargin">
                <RadioButtonGroup id="csvExportScope" columns="1" selectedIndex="0">
                    <buttons>
                        <RadioButton id="rbVisibleCols" text="Export visible columns"/>
                        <RadioButton id="rbAllCols" text="Export all 47 columns"/>
                    </buttons>
                </RadioButtonGroup>
                <CheckBox id="cbIncludeHelpRow" text="Include help row (for templates)" selected="false" class="sapUiSmallMarginTop"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Download CSV" type="Emphasized" icon="sap-icon://download" press="onExportCsvDownload"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseCsvExportDialog"/>
        </endButton>
    </Dialog>

    <!-- ── Save Variant Name Dialog ─────────────────────────── -->
    <!-- sap.m.MessageBox.prompt does not exist in SAP UI5 — use a proper Dialog with Input -->
    <Dialog id="saveVariantDialog"
        title="Save Column Variant"
        contentWidth="380px"
        draggable="true">
        <content>
            <VBox class="sapUiSmallMarginTopBottom sapUiSmallMarginBeginEnd">
                <Label text="Variant Name" required="true" class="sapUiTinyMarginBottom" labelFor="variantNameInput"/>
                <Input id="variantNameInput"
                    placeholder="e.g. Inspection View, Compact, NSW Bridges…"
                    maxLength="60"
                    width="100%"
                    valueLiveUpdate="true"
                    liveChange="onVariantNameLiveChange"
                    submit="onConfirmSaveVariant"/>
                <Text
                    text="Saves the current column selection. You can reload it anytime from the Variant dropdown."
                    class="nhvrSubText sapUiTinyMarginTop"/>
            </VBox>
        </content>
        <beginButton>
            <Button id="btnConfirmSaveVariant"
                text="Save"
                type="Emphasized"
                enabled="false"
                press="onConfirmSaveVariant"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelSaveVariant"/>
        </endButton>
    </Dialog>

    <!-- ── Bulk Upload Wizard Dialog ─────────────────────────── -->
    <Dialog id="bulkUploadDialog" title="Bulk Bridge Upload" contentWidth="700px" contentHeight="500px" resizable="true" draggable="true">
        <content>
            <Wizard id="bulkUploadWizard" class="sapUiNoContentPadding">
                <!-- Step 1: Download Template -->
                <WizardStep id="wStepTemplate" title="Download Template" icon="sap-icon://attachment">
                    <VBox class="sapUiMediumMargin">
                        <Title text="Step 1 — Download the bridge upload template" level="H3" class="sapUiSmallMarginBottom"/>
                        <Text text="Fill in the CSV template with your bridge data, then return here to upload. The template includes all 47 bridge fields with help text and examples." class="sapUiSmallMarginBottom" wrapping="true"/>
                        <HBox class="sapUiSmallMarginBottom">
                            <Button text="All fields template (47 columns)" icon="sap-icon://download" press="onDownloadBridgeTemplate" type="Emphasized" class="sapUiSmallMarginEnd"/>
                            <Button text="Required fields only" icon="sap-icon://download" press="onDownloadRequiredTemplate" type="Ghost"/>
                        </HBox>
                        <Text text="Once you have filled in the template, click Next to upload." wrapping="true"/>
                    </VBox>
                </WizardStep>
                <!-- Step 2: Upload File -->
                <WizardStep id="wStepUpload" title="Upload File" icon="sap-icon://upload">
                    <VBox class="sapUiMediumMargin">
                        <Title text="Step 2 — Select your CSV file" level="H3" class="sapUiSmallMarginBottom"/>
                        <Text text="Select a CSV file exported from Excel. The file must match the template format." class="sapUiSmallMarginBottom" wrapping="true"/>
                        <unified:FileUploader id="bulkFileUploader" fileType="csv" change="onBulkFileChange"
                            style="Emphasized" buttonText="Browse CSV"
                            placeholder="No file selected" width="100%"/>
                        <MessageStrip id="uploadFileInfo" visible="false" type="Information" text="" showIcon="true" class="sapUiSmallMarginTop"/>
                    </VBox>
                </WizardStep>
                <!-- Step 3: Validate -->
                <WizardStep id="wStepValidate" title="Validate" icon="sap-icon://message-success">
                    <VBox class="sapUiMediumMargin">
                        <Title text="Step 3 — Validation results" level="H3" class="sapUiSmallMarginBottom"/>
                        <MessageStrip id="validationSummary" text="Ready to validate" type="Information" showIcon="true" class="sapUiSmallMarginBottom"/>
                        <Table id="validationErrorTable" visible="false" noDataText="No errors — all rows valid" class="sapUiSmallMarginTop">
                            <columns>
                                <Column width="60px"><Text text="Row"/></Column>
                                <Column width="120px"><Text text="Field"/></Column>
                                <Column><Text text="Error"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem type="Inactive">
                                    <cells>
                                        <Text text="{bulk>row}"/>
                                        <Text text="{bulk>field}"/>
                                        <Text text="{bulk>message}" wrapping="true"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </WizardStep>
                <!-- Step 4: Import -->
                <WizardStep id="wStepImport" title="Import" icon="sap-icon://process">
                    <VBox class="sapUiMediumMargin">
                        <Title text="Step 4 — Import results" level="H3" class="sapUiSmallMarginBottom"/>
                        <MessageStrip id="importResultMsg" text="Ready to import. Click Import to proceed." type="Information" showIcon="true" class="sapUiSmallMarginBottom"/>
                        <Button id="btnConfirmImport" text="Import" icon="sap-icon://accept" type="Emphasized" press="onBulkImportConfirm" class="sapUiSmallMarginBottom"/>
                        <BusyIndicator id="importBusy" visible="false"/>
                        <VBox id="importResultDetail" visible="false">
                            <ObjectStatus text="Created: {bulk>/created}" state="Success"/>
                            <ObjectStatus text="Updated: {bulk>/updated}" state="Warning"/>
                            <ObjectStatus text="Failed: {bulk>/failed}" state="Error"/>
                        </VBox>
                    </VBox>
                </WizardStep>
            </Wizard>
        </content>
        <endButton>
            <Button text="Close" press="onBulkUploadClose"/>
        </endButton>
    </Dialog>

</mvc:View>
