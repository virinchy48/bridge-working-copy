<!-- ============================================================
     Integration Configuration Dialog Fragment
     Allows users to configure S/4HANA, BANC and ESRI connections
     ============================================================ -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout">

    <Dialog id="integrationConfigDialog"
        title="Integration Configuration"
        contentWidth="640px"
        resizable="true"
        draggable="true">

        <content>
            <IconTabBar id="configTabBar" class="sapUiNoContentPadding">
                <items>
                <!-- ── S/4HANA Config tab ────────────────────────── -->
                <IconTabFilter icon="sap-icon://system-second-call" text="S/4HANA">
                    <form:SimpleForm editable="true" layout="ColumnLayout" columnsL="2" columnsM="1">
                        <form:content>
                            <Label text="Active" design="Bold"/>
                            <Switch id="s4ActiveSwitch" state="{cfgModel>/s4/isActive}"
                                change="onS4ActiveChange"/>

                            <Label text="Base URL" design="Bold" required="true"/>
                            <Input id="s4BaseUrl" value="{cfgModel>/s4/baseUrl}"
                                placeholder="https://your-s4.example.com"/>

                            <Label text="Username" design="Bold"/>
                            <Input id="s4Username" value="{cfgModel>/s4/username}"/>

                            <Label text="Password" design="Bold"/>
                            <Input id="s4Password" type="Password"
                                value="{cfgModel>/s4/_password}" placeholder="(unchanged)"/>

                            <Label text="SAP Client" design="Bold"/>
                            <Input id="s4Client" value="{cfgModel>/s4/s4Client}"
                                placeholder="100"/>

                            <Label text="Maintenance Plant" design="Bold"/>
                            <Input id="s4Plant" value="{cfgModel>/s4/s4MaintenancePlant}"
                                placeholder="AU01"/>

                            <Label text="Equipment Class" design="Bold"/>
                            <Input id="s4EquipClass" value="{cfgModel>/s4/s4EquipClass}"
                                placeholder="BRIDGE_INFRA"/>

                            <Label text="Equipment Category" design="Bold"/>
                            <Input id="s4EquipCat" value="{cfgModel>/s4/s4EquipCategory}"
                                placeholder="M"/>

                            <Label text="Work Center" design="Bold"/>
                            <Input id="s4WorkCenter" value="{cfgModel>/s4/workCenter}"
                                placeholder="BRMAINT"/>
                        </form:content>
                    </form:SimpleForm>
                    <HBox class="sapUiSmallMarginTop sapUiSmallMarginBegin">
                        <Button text="Test S/4HANA Connection"
                            icon="sap-icon://ping"
                            press="onTestS4Connection"
                            type="Transparent"/>
                    </HBox>
                </IconTabFilter>

                <!-- ── BANC Config tab ───────────────────────────── -->
                <IconTabFilter icon="sap-icon://database" text="BANC">
                    <form:SimpleForm editable="true" layout="ColumnLayout" columnsL="2" columnsM="1">
                        <form:content>
                            <Label text="Active" design="Bold"/>
                            <Switch id="bancActiveSwitch" state="{cfgModel>/banc/isActive}"
                                change="onBancActiveChange"/>

                            <Label text="State Code" design="Bold" required="true"/>
                            <Select id="bancStateCode" selectedKey="{cfgModel>/banc/bancStateCode}">
                                <core:Item key="NSW" text="New South Wales (NSW)"/>
                                <core:Item key="VIC" text="Victoria (VIC)"/>
                                <core:Item key="QLD" text="Queensland (QLD)"/>
                                <core:Item key="SA"  text="South Australia (SA)"/>
                                <core:Item key="WA"  text="Western Australia (WA)"/>
                                <core:Item key="TAS" text="Tasmania (TAS)"/>
                                <core:Item key="NT"  text="Northern Territory (NT)"/>
                                <core:Item key="ACT" text="ACT"/>
                            </Select>

                            <Label text="Agency Code" design="Bold" required="true"/>
                            <Input id="bancAgencyCode" value="{cfgModel>/banc/bancAgencyCode}"
                                placeholder="NHVR"/>

                            <Label text="Include Inspections"/>
                            <Switch id="bancInclInsp" state="{cfgModel>/banc/includeInspections}"/>

                            <Label text="Include Defects"/>
                            <Switch id="bancInclDef" state="{cfgModel>/banc/includeDefects}"/>
                        </form:content>
                    </form:SimpleForm>
                    <MessageStrip type="Information" showIcon="true" class="sapUiSmallMargin"
                        text="BANC uses CSV file export (no live API endpoint). Files are generated for state submission via the Austroads data exchange portal."/>
                </IconTabFilter>

                <!-- ── ESRI Config tab ───────────────────────────── -->
                <IconTabFilter icon="sap-icon://map" text="ArcGIS">
                    <form:SimpleForm editable="true" layout="ColumnLayout" columnsL="2" columnsM="1">
                        <form:content>
                            <Label text="Active" design="Bold"/>
                            <Switch id="esriActiveSwitch" state="{cfgModel>/esri/isActive}"
                                change="onEsriActiveChange"/>

                            <Label text="Feature Service URL" design="Bold" required="true"/>
                            <Input id="esriBaseUrl" value="{cfgModel>/esri/baseUrl}"
                                placeholder="https://services.arcgis.com/…/FeatureServer"/>

                            <Label text="Layer ID" design="Bold"/>
                            <Input id="esriLayerId" value="{cfgModel>/esri/esriLayerId}"
                                placeholder="0" type="Number"/>

                            <Label text="Auth Token" design="Bold"/>
                            <Input id="esriToken" type="Password"
                                value="{cfgModel>/esri/_token}" placeholder="(unchanged)"/>

                            <Label text="Token URL (optional)"/>
                            <Input id="esriTokenUrl" value="{cfgModel>/esri/tokenUrl}"
                                placeholder="https://www.arcgis.com/sharing/rest/generateToken"/>

                            <Label text="Username (for token gen)"/>
                            <Input id="esriUsername" value="{cfgModel>/esri/username}"/>

                            <Label text="Password"/>
                            <Input id="esriPassword" type="Password"
                                value="{cfgModel>/esri/_password}" placeholder="(unchanged)"/>
                        </form:content>
                    </form:SimpleForm>
                    <HBox class="sapUiSmallMarginTop sapUiSmallMarginBegin">
                        <Button text="Test ArcGIS Connection"
                            icon="sap-icon://ping"
                            press="onTestEsriConnection"
                            type="Transparent"/>
                    </HBox>
                </IconTabFilter>
                </items>
            </IconTabBar>
        </content>

        <beginButton>
            <Button text="Save Configuration"
                type="Emphasized"
                press="onSaveIntegrationConfig"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseConfigDialog"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
