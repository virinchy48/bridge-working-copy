<!-- ============================================================
     NHVR Inspection Dashboard — Inspection Orders & Due Dates
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.InspectionDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="inspDashPage" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Inspection Dashboard" level="H1"/>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Inspection Dashboard"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button text="New Inspection Order" icon="sap-icon://add" type="Emphasized"
                        press="onCreateOrder"/>
                    <Button id="btnExportInspections" text="Export Excel" icon="sap-icon://excel-attachment"
                        type="Transparent" press="onExportInspections"
                        tooltip="Export inspection orders to Excel (.xlsx)"/>
                    <Button icon="sap-icon://hint" type="Transparent" press="onInfoPressInspDash"
                        tooltip="Inspection dashboard guide"/>
                    <Button text="Refresh" icon="sap-icon://refresh" type="Transparent"
                        press="onRefresh"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- Header KPI Strip -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Total Orders" design="Bold"/>
                        <ObjectStatus id="kpiTotal" text="—" state="None"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Planned" design="Bold"/>
                        <ObjectStatus id="kpiPlanned" text="—" state="None"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="In Progress" design="Bold"/>
                        <ObjectStatus id="kpiInProgress" text="—" state="Warning"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Pending Review" design="Bold"/>
                        <ObjectStatus id="kpiPendingReview" text="—" state="Warning"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Completed" design="Bold"/>
                        <ObjectStatus id="kpiCompleted" text="—" state="Success"/>
                    </VBox>
                    <VBox>
                        <Label text="Inspections Due (90 days)" design="Bold"/>
                        <ObjectStatus id="kpiDue" text="—" state="Error"/>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <IconTabBar id="inspTabs" selectedKey="orders" expandable="false"
                class="nhvrApp">
                <items>

                    <!-- TAB 1: All Inspection Orders -->
                    <IconTabFilter key="orders" text="All Orders" icon="sap-icon://factory">
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Title text="Inspection Orders" level="H4"/>
                                <HBox alignItems="Center">
                                    <Select id="statusFilter" change="onStatusFilter" width="170px" class="sapUiSmallMarginEnd">
                                        <core:Item key="" text="All Statuses"/>
                                        <core:Item key="PLANNED"        text="Planned"/>
                                        <core:Item key="IN_PROGRESS"    text="In Progress"/>
                                        <core:Item key="PENDING_REVIEW" text="Pending Review"/>
                                        <core:Item key="COMPLETED"      text="Completed"/>
                                        <core:Item key="CANCELLED"      text="Cancelled"/>
                                    </Select>
                                    <Select id="typeFilter" change="onTypeFilter" width="150px" class="sapUiSmallMarginEnd">
                                        <core:Item key="" text="All Types"/>
                                        <core:Item key="ROUTINE"    text="Routine"/>
                                        <core:Item key="SPECIAL"    text="Special"/>
                                        <core:Item key="PRINCIPAL"  text="Principal"/>
                                        <core:Item key="UNDERWATER" text="Underwater"/>
                                        <core:Item key="POST_EVENT" text="Post-Event"/>
                                    </Select>
                                    <ToolbarSeparator/>
                                    <MenuButton id="inspViewsMenuBtn" text="Saved Views" icon="sap-icon://filter" class="sapUiSmallMarginEnd">
                                        <menu>
                                            <Menu id="inspViewsMenu"/>
                                        </menu>
                                    </MenuButton>
                                    <Button text="Save View" icon="sap-icon://save" press="onSaveInspectionView" tooltip="Save current filters as a named view"/>
                                </HBox>
                            </HBox>
                            <Table id="ordersTable"
                                items="{insp>/orders}"
                                noDataText="No inspection orders found"
                                fixedLayout="false"
                                alternateRowColors="true"
                                sticky="ColumnHeaders,HeaderToolbar"
                                growing="true" growingThreshold="50">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Text id="alvRecordCount" text="" class="nhvrSubText"/>
                                        <ToolbarSeparator/>
                                        <Title id="tableTitle" text="Inspection Orders" level="H3"/>
                                        <ToolbarSpacer/>
                                        <Button text="New Order" icon="sap-icon://add" press="onCreateInspectionOrder" type="Emphasized"/>
                                        <ToolbarSeparator/>
                                        <Button icon="sap-icon://sort" text="Sort" press="onAlvSort" type="Transparent" tooltip="Sort options"/>
                                        <Button icon="sap-icon://table-column" text="Columns" press="onColumnChooser" type="Transparent"/>
                                        <ToolbarSeparator/>
                                        <Button icon="sap-icon://excel-attachment" text="Excel" press="onAlvExportExcel" type="Transparent" tooltip="Export to Excel"/>
                                        <Button icon="sap-icon://download" text="CSV" press="onAlvExportCsv" type="Transparent" tooltip="Export to CSV"/>
                                        <Button icon="sap-icon://pdf-attachment" text="Print" press="onAlvExportPdf" type="Transparent" tooltip="Print"/>
                                        <ToolbarSeparator/>
                                        <Button icon="sap-icon://refresh" text="Refresh" press="onAlvRefresh" type="Transparent" tooltip="Refresh"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column id="iColOrder" width="140px"><Text text="Order No."/></Column>
                                    <Column id="iColBridge" width="180px"><Text text="Bridge"/></Column>
                                    <Column id="iColType" width="110px"><Text text="Type"/></Column>
                                    <Column id="iColStatus" width="120px" hAlign="Center"><Text text="Status"/></Column>
                                    <Column id="iColPlanned" width="110px" minScreenWidth="Tablet" demandPopin="true"><Text text="Planned Date"/></Column>
                                    <Column id="iColInspector" width="150px" minScreenWidth="Tablet" demandPopin="true"><Text text="Inspector"/></Column>
                                    <Column id="iColRating" width="90px" hAlign="Center" minScreenWidth="Desktop" demandPopin="true"><Text text="Rating"/></Column>
                                    <Column id="iColAdequacy" width="140px" hAlign="Center" minScreenWidth="Desktop" demandPopin="true"><Text text="Struct. Adequacy"/></Column>
                                    <Column id="iColNextDue" width="110px" minScreenWidth="Desktop" demandPopin="true"><Text text="Next Due"/></Column>
                                    <Column id="iColActions" width="160px" hAlign="Center"><Text text="Actions"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem
                                        highlight="{= ${insp>status} === 'PENDING_REVIEW' ? 'Warning' : ${insp>status} === 'IN_PROGRESS' ? 'Information' : ${insp>status} === 'CANCELLED' ? 'Error' : 'None'}"
                                        press="onOrderPress" type="Navigation" vAlign="Middle">
                                        <cells>
                                            <Link text="{insp>orderNumber}" press="onOrderNumberPress" wrapping="false"
                                                tooltip="Open inspection order {insp>orderNumber}"/>
                                            <VBox>
                                                <Text text="{insp>bridgeName}" wrapping="true"/>
                                                <Link text="{insp>bridgeId}" press="onBridgeIdPress"
                                                    class="sapUiTinyFont" wrapping="false"
                                                    tooltip="Open bridge detail for {insp>bridgeId}"/>
                                            </VBox>
                                            <ObjectStatus text="{insp>inspectionType}"
                                                state="{= ${insp>inspectionType} === 'PRINCIPAL' ? 'Warning' : ${insp>inspectionType} === 'UNDERWATER' ? 'Error' : 'None'}"/>
                                            <ObjectStatus text="{insp>status}"
                                                state="{= ${insp>status} === 'COMPLETED' ? 'Success' : ${insp>status} === 'PENDING_REVIEW' ? 'Information' : ${insp>status} === 'IN_PROGRESS' ? 'Warning' : ${insp>status} === 'CANCELLED' ? 'Error' : 'None'}"/>
                                            <Text text="{insp>plannedDate}" wrapping="true"/>
                                            <Text text="{insp>inspector}" wrapping="true"/>
                                            <ObjectStatus text="{insp>overallConditionRating}"
                                                state="{= ${insp>overallConditionRating} >= 7 ? 'Success' : ${insp>overallConditionRating} >= 5 ? 'Warning' : ${insp>overallConditionRating} > 0 ? 'Error' : 'None'}"/>
                                            <ObjectStatus text="{insp>structuralAdequacy}"
                                                state="{= ${insp>structuralAdequacy} === 'ADEQUATE' ? 'Success' : ${insp>structuralAdequacy} === 'MARGINAL' ? 'Warning' : ${insp>structuralAdequacy} === 'INADEQUATE' ? 'Error' : 'None'}"/>
                                            <Text text="{insp>nextInspectionDue}" wrapping="true"/>
                                            <HBox>
                                                <Button icon="sap-icon://begin" tooltip="Start Inspection" type="Transparent"
                                                    press="onStartInspection"
                                                    visible="{= ${insp>status} === 'PLANNED'}"/>
                                                <Button icon="sap-icon://accept" tooltip="Complete Inspection" type="Transparent"
                                                    press="onCompleteInspection"
                                                    visible="{= ${insp>status} === 'IN_PROGRESS'}"/>
                                                <Button icon="sap-icon://inspection" tooltip="Review Inspection" type="Transparent"
                                                    press="onApproveInspection"
                                                    visible="{= ${insp>status} === 'PENDING_REVIEW'}"/>
                                                <Button icon="sap-icon://cancel" tooltip="Cancel Order" type="Transparent"
                                                    press="onCancelInspectionOrder"
                                                    visible="{= ${insp>status} === 'PLANNED' || ${insp>status} === 'IN_PROGRESS'}"/>
                                                <Button icon="sap-icon://edit" tooltip="Edit Order" type="Transparent"
                                                    press="onEditInspectionOrder"
                                                    visible="{= ${insp>status} !== 'COMPLETED' &amp;&amp; ${insp>status} !== 'CANCELLED'}"/>
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                    <!-- TAB 2: Inspections Due -->
                    <IconTabFilter key="due" text="Inspections Due" icon="sap-icon://alert" iconColor="Negative">
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Title text="Bridges Requiring Inspection" level="H4"/>
                                <HBox alignItems="Center">
                                    <Label text="Look-ahead (days):" class="sapUiSmallMarginEnd"/>
                                    <Select id="daysFilter" change="onDaysFilter" width="120px">
                                        <core:Item key="30"  text="30 days"/>
                                        <core:Item key="90"  text="90 days"/>
                                        <core:Item key="180" text="180 days"/>
                                        <core:Item key="365" text="12 months"/>
                                    </Select>
                                </HBox>
                            </HBox>
                            <Table id="dueTable"
                                items="{insp>/due}"
                                noDataText="No inspections due in this period"
                                fixedLayout="false"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                growing="true" growingThreshold="50">
                                <columns>
                                    <Column width="130px"><Text text="Bridge ID"/></Column>
                                    <Column width="200px"><Text text="Bridge Name"/></Column>
                                    <Column width="110px" minScreenWidth="Tablet" demandPopin="true"><Text text="Region"/></Column>
                                    <Column width="120px" minScreenWidth="Tablet" demandPopin="true"><Text text="Last Inspection"/></Column>
                                    <Column width="110px"><Text text="Next Due"/></Column>
                                    <Column width="130px" hAlign="Center"><Text text="Days Overdue"/></Column>
                                    <Column width="110px" minScreenWidth="Desktop" demandPopin="true"><Text text="Type"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem
                                        highlight="{= ${insp>daysOverdue} > 0 ? 'Error' : 'Warning'}"
                                        press="onDueBridgePress" type="Navigation" vAlign="Middle">
                                        <cells>
                                            <Link text="{insp>bridgeId}" press="onBridgeIdPress"
                                                wrapping="false"
                                                tooltip="Open bridge detail for {insp>bridgeId}"/>
                                            <Text text="{insp>bridgeName}" wrapping="true"/>
                                            <Text text="{insp>region}" wrapping="true"/>
                                            <Text text="{insp>lastInspection}" wrapping="true"/>
                                            <Text text="{insp>nextDue}" wrapping="true"/>
                                            <ObjectStatus
                                                text="{= ${insp>daysOverdue} > 0 ? ${insp>daysOverdue} + ' days overdue' : 'Due soon'}"
                                                state="{= ${insp>daysOverdue} > 0 ? 'Error' : 'Warning'}"/>
                                            <Text text="{insp>inspectionType}" wrapping="true"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                    <!-- TAB 3: Pending Reviews (Phase 5.3) -->
                    <IconTabFilter key="reviews" text="Pending Reviews ({insp>/pendingReviewCount})"
                        icon="sap-icon://inspection" iconColor="Critical"
                        visible="{= ${appConfig>/role} === 'ADMIN' || ${appConfig>/role} === 'BRIDGE_MANAGER'}">
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Title text="Inspections Awaiting Review" level="H4"/>
                                <Button text="Refresh" icon="sap-icon://refresh" type="Transparent"
                                    press="onRefresh"/>
                            </HBox>
                            <Table id="pendingReviewsTable"
                                items="{insp>/pendingReviews}"
                                noDataText="No inspections pending review"
                                fixedLayout="false"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                                growing="true" growingThreshold="50">
                                <columns>
                                    <Column width="140px"><Text text="Order No."/></Column>
                                    <Column width="180px"><Text text="Bridge"/></Column>
                                    <Column width="140px"><Text text="Inspector"/></Column>
                                    <Column width="100px" hAlign="Center"><Text text="Condition Rating"/></Column>
                                    <Column width="130px"><Text text="Submitted"/></Column>
                                    <Column width="260px" hAlign="Center"><Text text="Actions"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem highlight="Warning" vAlign="Middle">
                                        <cells>
                                            <ObjectIdentifier title="{insp>orderNumber}"/>
                                            <VBox>
                                                <Text text="{insp>bridgeName}" wrapping="true"/>
                                                <Link text="{insp>bridgeId}" press="onBridgeIdPress"
                                                    class="sapUiTinyFont" wrapping="false"
                                                    tooltip="Open bridge detail for {insp>bridgeId}"/>
                                            </VBox>
                                            <Text text="{insp>inspector}" wrapping="true"/>
                                            <ObjectNumber number="{insp>overallConditionRating}" unit="/10"
                                                state="{= ${insp>overallConditionRating} >= 7 ? 'Success' : ${insp>overallConditionRating} >= 5 ? 'Warning' : 'Error'}"/>
                                            <Text text="{insp>completedAt}" wrapping="true"/>
                                            <HBox>
                                                <Button text="Approve" icon="sap-icon://accept" type="Accept"
                                                    press="onApproveInspection" class="sapUiTinyMarginEnd"/>
                                                <Button text="Reject" icon="sap-icon://decline" type="Reject"
                                                    press="onRejectInspection" class="sapUiTinyMarginEnd"/>
                                                <Button text="Needs Revision" icon="sap-icon://edit" type="Transparent"
                                                    press="onNeedsRevisionInspection"/>
                                            </HBox>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </IconTabFilter>

                </items>
            </IconTabBar>
        </f:content>
    </f:DynamicPage>

    <!-- ── Column Chooser Dialog (Orders Table) ───────────── -->
    <Dialog id="inspOrderColumnChooserDialog" title="Show / Hide Columns" contentWidth="300px">
        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <CheckBox id="iglColPlanned"   text="Planned Date"     selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="iglColInspector" text="Inspector"        selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="iglColRating"    text="Rating"           selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="iglColAdequacy"  text="Struct. Adequacy" selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="iglColNextDue"   text="Next Due"         selected="true"  class="sapUiTinyMarginBottom"/>
            </VBox>
        </content>
        <buttons>
            <Button text="Apply" type="Emphasized" press="onApplyOrderColumns"/>
            <Button text="Close" press="onCloseOrderColumnChooser" type="Transparent"/>
        </buttons>
    </Dialog>

</mvc:View>
