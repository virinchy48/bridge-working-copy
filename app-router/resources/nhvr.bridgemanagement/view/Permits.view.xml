<mvc:View
    controllerName="nhvr.bridgemanagement.controller.Permits"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fl="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="permitsPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Vehicle Permits" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Permits" level="H2"/>
                </f:snappedHeading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press=".onNavHome"/>
                        <Link text="Vehicle Permits"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button text="New Permit Assessment" type="Emphasized" icon="sap-icon://add" press=".onNewPermit"/>
                    <Button id="btnExportPermits" text="Export Excel" icon="sap-icon://excel-attachment"
                        press=".onExportCSV" type="Transparent"
                        tooltip="Export permits to Excel (.xlsx)"/>
                    <Button icon="sap-icon://hint" type="Transparent" press=".onInfoPressPermits"
                        tooltip="Permit types and status guide"/>
                    <Button text="Home" icon="sap-icon://home" press=".onNavHome" type="Transparent"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
        <VBox class="nhvrApp">
            <!-- KPI Strip -->
            <HBox class="sapUiSmallMargin" wrap="Wrap" justifyContent="SpaceBetween">
                <GenericTile class="sapUiSmallMarginEnd sapUiSmallMarginBottom" header="Total Permits" subheader="All statuses">
                    <tileContent>
                        <TileContent>
                            <content>
                                <NumericContent value="{permits>/totalCount}" icon="sap-icon://document" withMargin="false"/>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <GenericTile class="sapUiSmallMarginEnd sapUiSmallMarginBottom" header="Approved" subheader="Active permits"
                    frameType="TwoByOne">
                    <tileContent>
                        <TileContent>
                            <content>
                                <NumericContent value="{permits>/approvedCount}" icon="sap-icon://accept" valueColor="Good" withMargin="false"/>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <GenericTile class="sapUiSmallMarginEnd sapUiSmallMarginBottom" header="Pending Review" subheader="Awaiting decision">
                    <tileContent>
                        <TileContent>
                            <content>
                                <NumericContent value="{permits>/pendingCount}" icon="sap-icon://appointment-2" valueColor="Critical" withMargin="false"/>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
                <GenericTile class="sapUiSmallMarginEnd sapUiSmallMarginBottom" header="Denied / Expired" subheader="Inactive permits">
                    <tileContent>
                        <TileContent>
                            <content>
                                <NumericContent value="{permits>/deniedCount}" icon="sap-icon://cancel" valueColor="Error" withMargin="false"/>
                            </content>
                        </TileContent>
                    </tileContent>
                </GenericTile>
            </HBox>

            <!-- Filter Bar -->
            <VBox class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginBottom">
                <HBox wrap="Wrap" alignItems="Center">
                    <SearchField id="permitSearchField" width="18rem" placeholder="Search permits..." liveChange=".onPermitSearch" class="sapUiSmallMarginEnd"/>
                    <Label text="Status:" class="sapUiSmallMarginEnd"/>
                    <Select id="permitStatusFilter" width="10rem" change=".onPermitFilter" class="sapUiSmallMarginEnd">
                    </Select>
                    <Label text="Type:" class="sapUiSmallMarginEnd"/>
                    <Select id="permitTypeFilter" width="10rem" change=".onPermitFilter" class="sapUiSmallMarginEnd">
                    </Select>
                    <Button text="Clear" icon="sap-icon://clear-filter" press=".onClearPermitFilters" class="sapUiSmallMarginEnd"/>
                    <ToolbarSeparator/>
                    <MenuButton id="permitViewsMenuBtn" text="Saved Views" icon="sap-icon://filter" class="sapUiSmallMarginEnd">
                        <menu>
                            <Menu id="permitViewsMenu"/>
                        </menu>
                    </MenuButton>
                    <Button text="Save View" icon="sap-icon://save" press=".onSavePermitView" tooltip="Save current search + filters as a named view"/>
                </HBox>
            </VBox>

            <!-- Permits Table -->
            <Table
                id="permitsTable"
                items="{permits>/items}"
                growing="true"
                growingThreshold="25"
                alternateRowColors="true"
                sticky="ColumnHeaders,HeaderToolbar"
                noDataText="No permits match the current filters"
                busyIndicatorDelay="0"
                busy="{permits>/loading}">

                <headerToolbar>
                    <OverflowToolbar>
                        <Text id="alvRecordCount" text="" class="nhvrSubText"/>
                        <ToolbarSeparator/>
                        <Title id="tableTitle" text="Permits Register" level="H3"/>
                        <ToolbarSpacer/>
                        <Button text="New Permit" icon="sap-icon://add" press=".onNewPermit" type="Emphasized"
                            visible="{ui>/canCreatePermit}"/>
                        <ToolbarSeparator/>
                        <Button icon="sap-icon://sort" text="Sort" press=".onAlvSort" type="Transparent"/>
                        <ToolbarSeparator/>
                        <Button icon="sap-icon://excel-attachment" text="Excel" press=".onAlvExportExcel" type="Transparent"/>
                        <Button icon="sap-icon://download" text="CSV" press=".onAlvExportCsv" type="Transparent"/>
                        <Button icon="sap-icon://pdf-attachment" text="Print" press=".onAlvExportPdf" type="Transparent"/>
                        <ToolbarSeparator/>
                        <Button icon="sap-icon://refresh" text="Refresh" press=".onAlvRefresh" type="Transparent"/>
                    </OverflowToolbar>
                </headerToolbar>

                <columns>
                    <Column width="8rem"><Text text="Permit ID"/></Column>
                    <Column><Text text="Bridge"/></Column>
                    <Column><Text text="Vehicle Type"/></Column>
                    <Column width="7rem"><Text text="GVM (t)"/></Column>
                    <Column width="7rem"><Text text="Type"/></Column>
                    <Column width="9rem"><Text text="Status"/></Column>
                    <Column width="7rem"><Text text="All Checks"/></Column>
                    <Column width="9rem"><Text text="Expires"/></Column>
                    <Column width="10rem"><Text text="Actions"/></Column>
                </columns>

                <items>
                    <ColumnListItem type="Navigation" press=".onPermitRowPress">
                        <cells>
                            <VBox>
                                <Link text="{permits>permitId}" press=".onPermitIdLinkPress" wrapping="false"
                                    tooltip="Open permit detail for {permits>permitId}"/>
                                <Text text="{path:'permits>permitType', formatter:'.formatPermitType'}" class="sapUiTinyFont nhvrSubText"/>
                            </VBox>
                            <VBox>
                                <Text text="{permits>bridgeName}" wrapping="false"/>
                                <Link text="{permits>bridgeId}" press="onBridgeIdPress" wrapping="false"/>
                            </VBox>
                            <VBox>
                                <Text text="{permits>vehicleTypeName}" wrapping="false"/>
                                <ObjectStatus text="{permits>vehicleTypeClass}" state="None"/>
                            </VBox>
                            <Text text="{path:'permits>assessedGVM_t', formatter:'.formatDecimal'}"/>
                            <Text text="{path:'permits>permitType', formatter:'.formatPermitType'}"/>
                            <ObjectStatus
                                text="{path:'permits>permitStatus', formatter:'.formatStatus'}"
                                state="{path:'permits>permitStatus', formatter:'.formatStatusState'}"/>
                            <ObjectStatus
                                text="{path:'permits>allChecksPassed', formatter:'.formatChecks'}"
                                state="{path:'permits>allChecksPassed', formatter:'.formatChecksState'}"/>
                            <Text text="{path:'permits>expiryDate', formatter:'.formatDate'}"/>
                            <HBox>
                                <Button icon="sap-icon://detail-view" tooltip="View Details" press=".onViewPermit" type="Transparent"/>
                                <Button icon="sap-icon://edit" tooltip="Edit" press=".onEditPermit" type="Transparent"
                                    enabled="{path:'permits>permitStatus', formatter:'.canEdit'}"/>
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </VBox>
        </f:content>
    </f:DynamicPage>

    <!-- ═══════════════════════════════════════════════════════════════════════
         NEW PERMIT WIZARD DIALOG
    ═══════════════════════════════════════════════════════════════════════ -->
    <Dialog id="newPermitDialog" title="New Vehicle Permit Assessment" contentWidth="52rem" draggable="true" resizable="true">
        <content>
            <IconTabBar id="permitWizardTabs" selectedKey="step1" expanded="true" backgroundDesign="Transparent">

                    <!-- Step 1: Bridge & Vehicle Selection -->
                    <items>
                        <IconTabFilter key="step1" text="1. Bridge &amp; Vehicle" icon="sap-icon://navigation-right-arrow">
                            <content>
                                <fl:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" columnsXL="2" columnsL="2" class="sapUiSmallMargin">
                                    <fl:title><core:Title text="Bridge Selection"/></fl:title>

                                    <Label text="Bridge *" required="true"/>
                                    <Select id="permitBridgeSelect" width="100%" change=".onPermitBridgeChanged">
                                        <items>
                                            <core:Item key="" text="— Select a bridge —"/>
                                        </items>
                                    </Select>

                                    <Label text="Vehicle Type *" required="true"/>
                                    <Select id="permitVehicleTypeSelect" width="100%" change=".onPermitVehicleTypeChanged">
                                        <items>
                                            <core:Item key="" text="— Select vehicle type —"/>
                                        </items>
                                    </Select>

                                    <Label text="Permit Type *" required="true"/>
                                    <Select id="permitTypeSelect" width="100%">
                                    </Select>

                                    <Label text="Applicant Name *" required="true"/>
                                    <Input id="permitApplicantName" placeholder="e.g. Linfox Pty Ltd"/>

                                    <Label text="Applicant ABN"/>
                                    <Input id="permitApplicantABN" placeholder="e.g. 12 345 678 901"/>

                                    <fl:title><core:Title text="Vehicle Dimensions"/></fl:title>

                                    <Label text="Gross Vehicle Mass (t) *" required="true"/>
                                    <Input id="permitGVM" type="Number" placeholder="e.g. 42.5"/>

                                    <Label text="Gross Combined Mass (t)"/>
                                    <Input id="permitGCM" type="Number" placeholder="e.g. 68.0"/>

                                    <Label text="Vehicle Height (m) *" required="true"/>
                                    <Input id="permitHeight" type="Number" placeholder="e.g. 4.3"/>

                                    <Label text="Vehicle Width (m) *" required="true"/>
                                    <Input id="permitWidth" type="Number" placeholder="e.g. 2.5"/>

                                    <Label text="Vehicle Length (m)"/>
                                    <Input id="permitLength" type="Number" placeholder="e.g. 19.0"/>

                                    <Label text="Crossing Speed (km/h)"/>
                                    <Input id="permitSpeed" type="Number" placeholder="e.g. 80" value="80"/>
                                </fl:SimpleForm>
                            </content>
                        </IconTabFilter>

                        <!-- Step 2: Assessment Results -->
                        <IconTabFilter key="step2" text="2. Assessment" icon="sap-icon://decision" enabled="{permit>/assessmentDone}">
                            <content>
                                <VBox class="sapUiSmallMargin">
                                    <!-- Overall Result Banner -->
                                    <MessageStrip
                                        id="assessmentResultBanner"
                                        text="{permit>/recommendedAction}"
                                        type="{path:'permit>/eligible', formatter:'.formatEligibleMsgType'}"
                                        showIcon="true"
                                        class="sapUiSmallMarginBottom"/>

                                    <!-- Results Grid -->
                                    <HBox wrap="Wrap">
                                        <!-- Mass Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Mass Check"
                                                text="{path:'permit>/massCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/massCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="Required: {permit>/massCheckRequired} t" class="sapUiTinyMarginTop"/>
                                            <Text text="Available: {permit>/massCheckAvailable} t"/>
                                            <Text text="Margin: {permit>/massCheckMargin} t"/>
                                            <Text text="{permit>/massCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                        <!-- Clearance Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Vertical Clearance"
                                                text="{path:'permit>/clearanceCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/clearanceCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="Required: {permit>/clearanceCheckRequired} m" class="sapUiTinyMarginTop"/>
                                            <Text text="Available: {permit>/clearanceCheckAvailable} m"/>
                                            <Text text="Margin: {permit>/clearanceCheckMargin} m"/>
                                            <Text text="{permit>/clearanceCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                        <!-- Width Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Width / Carriageway"
                                                text="{path:'permit>/widthCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/widthCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="Available: {permit>/widthCheckAvailable} m" class="sapUiTinyMarginTop"/>
                                            <Text text="Margin: {permit>/widthCheckMargin} m"/>
                                            <Text text="{permit>/widthCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                        <!-- Length Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Length / Approach"
                                                text="{path:'permit>/lengthCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/lengthCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="{permit>/lengthCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                        <!-- Fatigue Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Fatigue Life"
                                                text="{path:'permit>/fatigueCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/fatigueCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="Remaining: {permit>/fatigueRemaining} yrs" class="sapUiTinyMarginTop"/>
                                            <Text text="{permit>/fatigueCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                        <!-- Scour Check -->
                                        <VBox class="sapUiSmallMarginEnd sapUiSmallMarginBottom" width="14rem">
                                            <ObjectStatus
                                                title="Scour Risk"
                                                text="{path:'permit>/scourCheckPassed', formatter:'.formatCheckText'}"
                                                state="{path:'permit>/scourCheckPassed', formatter:'.formatCheckState'}"
                                                active="false"/>
                                            <Text text="Safety Margin: {permit>/scourCheckMargin} m" class="sapUiTinyMarginTop"/>
                                            <Text text="{permit>/scourCheckNote}" class="sapUiTinyMarginTop" wrapping="true"/>
                                        </VBox>
                                    </HBox>

                                    <!-- Warnings / Conditions -->
                                    <Panel headerText="Conditions &amp; Warnings" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                                        <content>
                                            <Text text="{permit>/conditionsList}" wrapping="true" class="sapUiSmallMargin"/>
                                            <Text text="{permit>/warningsList}" wrapping="true" class="sapUiSmallMarginBegin sapUiSmallMarginBottom"/>
                                        </content>
                                    </Panel>
                                </VBox>
                            </content>
                        </IconTabFilter>

                        <!-- Step 3: Approval Details -->
                        <IconTabFilter key="step3" text="3. Approval" icon="sap-icon://along-stacked-chart" enabled="{permit>/assessmentDone}">
                            <content>
                                <fl:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" columnsXL="2" columnsL="2" class="sapUiSmallMargin">
                                    <fl:title><core:Title text="Permit Decision"/></fl:title>

                                    <Label text="Decision *" required="true"/>
                                    <Select id="permitDecision" width="100%">
                                        <items>
                                            <core:Item key="APPROVED" text="Approve"/>
                                            <core:Item key="APPROVED_WITH_CONDITIONS" text="Approve with Conditions"/>
                                            <core:Item key="DENIED" text="Deny"/>
                                            <core:Item key="PENDING" text="Pending (save for review)"/>
                                        </items>
                                    </Select>

                                    <Label text="Assessed By"/>
                                    <Input id="permitAssessedBy" placeholder="e.g. J. Smith CPEng NER-00412"/>

                                    <Label text="Effective From *" required="true"/>
                                    <DatePicker id="permitEffectiveFrom" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                                    <Label text="Expiry Date *" required="true"/>
                                    <DatePicker id="permitExpiryDate" valueFormat="yyyy-MM-dd" displayFormat="dd MMM yyyy"/>

                                    <Label text="Conditions / Notes"/>
                                    <TextArea id="permitConditions" rows="4" growing="true" placeholder="e.g. Speed limit 40km/h when crossing. Single direction crossing only."/>

                                    <Label text="Permit Reference"/>
                                    <Input id="permitReference" placeholder="e.g. NHVR-2024-NSW-001234"/>
                                </fl:SimpleForm>
                            </content>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
        </content>
        <buttons>
            <Button id="btnRunAssessment" text="Run Assessment →" type="Emphasized" press=".onRunAssessment"/>
            <Button id="btnSavePermit" text="Save Permit" type="Accept" press=".onSavePermit" enabled="{permit>/assessmentDone}"/>
            <Button text="Cancel" press=".onCancelPermit" type="Transparent"/>
        </buttons>
    </Dialog>

    <!-- ═══════════════════════════════════════════════════════════════════════
         PERMIT DETAIL DIALOG
    ═══════════════════════════════════════════════════════════════════════ -->
    <Dialog id="permitDetailDialog" title="Permit Details" contentWidth="40rem" draggable="true" resizable="true">
        <content>
            <fl:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4" labelSpanM="4" class="sapUiSmallMargin">
                <fl:title><core:Title text="Identification"/></fl:title>
                <Label text="Permit ID"/><Text text="{permitDetail>/permitId}"/>
                <Label text="Bridge"/><Text text="{permitDetail>/bridgeName}"/>
                <Label text="Vehicle Type"/><Text text="{permitDetail>/vehicleTypeName}"/>
                <Label text="Vehicle Class"/><Text text="{permitDetail>/vehicleTypeClass}"/>

                <fl:title><core:Title text="Assessment"/></fl:title>
                <Label text="Assessed GVM (t)"/><Text text="{permitDetail>/assessedGVM_t}"/>
                <Label text="Assessed Height (m)"/><Text text="{permitDetail>/assessedHeight_m}"/>
                <Label text="Assessed Width (m)"/><Text text="{permitDetail>/assessedWidth_m}"/>
                <Label text="All Checks Passed"/>
                <ObjectStatus
                    text="{path:'permitDetail>/allChecksPassed', formatter:'.formatChecks'}"
                    state="{path:'permitDetail>/allChecksPassed', formatter:'.formatChecksState'}"/>

                <fl:title><core:Title text="Decision"/></fl:title>
                <Label text="Status"/>
                <ObjectStatus
                    text="{path:'permitDetail>/permitStatus', formatter:'.formatStatus'}"
                    state="{path:'permitDetail>/permitStatus', formatter:'.formatStatusState'}"/>
                <Label text="Permit Type"/><Text text="{path:'permitDetail>/permitType', formatter:'.formatPermitType'}"/>
                <Label text="Assessed By"/><Text text="{permitDetail>/assessedBy}"/>
                <Label text="Effective From"/><Text text="{path:'permitDetail>/effectiveFrom', formatter:'.formatDate'}"/>
                <Label text="Expiry Date"/><Text text="{path:'permitDetail>/expiryDate', formatter:'.formatDate'}"/>
                <Label text="Conditions"/><Text text="{permitDetail>/conditions}" wrapping="true"/>
            </fl:SimpleForm>
        </content>
        <beginButton>
            <Button text="Close" press=".onClosePermitDetail"/>
        </beginButton>
    </Dialog>

</mvc:View>
