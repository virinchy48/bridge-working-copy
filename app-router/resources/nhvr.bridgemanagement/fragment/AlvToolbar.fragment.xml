<!-- ============================================================
     NHVR ALV-Style Export Toolbar — include in any list view
     Usage in view: <core:Fragment fragmentName="nhvr.bridgemanagement.fragment.AlvToolbar" type="XML"/>

     Required controller methods:
       onAlvExportExcel()  — export visible rows to Excel
       onAlvExportCsv()    — export all rows to CSV
       onAlvExportPdf()    — print/PDF current view
       onAlvFilterPanel()  — toggle filter panel (optional)
     ============================================================ -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <OverflowToolbar id="alvToolbar" style="Clear" class="nhvrAlvToolbar">
        <!-- Left: record count info -->
        <Text id="alvRecordCount" text="" class="nhvrSubText sapUiSmallMarginEnd"/>
        <ToolbarSeparator/>
        <ToolbarSpacer/>

        <!-- Right: consistent action buttons matching SAP ALV Grid -->
        <Button icon="sap-icon://filter" text="Filter"
            press="onAlvFilterPanel" type="Transparent"
            tooltip="Show/hide filter panel"/>
        <Button icon="sap-icon://sort" text="Sort"
            press="onAlvSort" type="Transparent"
            tooltip="Sort options"/>
        <Button icon="sap-icon://action-settings" text="Columns"
            press="onOpenTableSettings" type="Transparent"
            tooltip="Choose which columns to display"/>
        <ToolbarSeparator/>
        <Button id="alvBtnExcel" icon="sap-icon://excel-attachment" text="Excel"
            press="onAlvExportExcel" type="Transparent"
            tooltip="Export current view to Excel (.xlsx)"/>
        <Button id="alvBtnCsv" icon="sap-icon://download" text="CSV"
            press="onAlvExportCsv" type="Transparent"
            tooltip="Export all data to CSV"/>
        <Button id="alvBtnPdf" icon="sap-icon://pdf-attachment" text="Print"
            press="onAlvExportPdf" type="Transparent"
            tooltip="Print or save as PDF"/>
        <ToolbarSeparator/>
        <Button icon="sap-icon://refresh" text="Refresh"
            press="onAlvRefresh" type="Transparent"
            tooltip="Refresh data from server"/>
    </OverflowToolbar>

</core:FragmentDefinition>
