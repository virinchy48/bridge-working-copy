<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <!--
        ScreenGuide.fragment.xml — Dismissible contextual help strip
        Persisted to localStorage via key: nhvr.guide.<screenId>
        Required model: screenGuide JSONModel
          screenGuide/text      — help text to display
          screenGuide/visible   — boolean (false once dismissed)
          screenGuide/type      — "Information" | "Warning" | "Success" (default Information)
        Controller must implement: onScreenGuideDismiss(oEvent)
    -->
    <MessageStrip
        class="nhvrScreenGuide"
        text="{screenGuide>/text}"
        type="{= ${screenGuide>/type} || 'Information' }"
        showIcon="true"
        showCloseButton="true"
        visible="{screenGuide>/visible}"
        close=".onScreenGuideDismiss"/>
</core:FragmentDefinition>
