<!-- ============================================================
     NHVR Mass Edit — Preview / Diff Dialog
     Shows old vs new values before committing changes
     ============================================================ -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="massEditPreviewDialog"
        title="Preview Changes — Review Before Saving"
        contentWidth="800px"
        contentHeight="500px"
        resizable="true"
        draggable="true">

        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

                <MessageStrip
                    text="Review the changes below. Click Confirm to save, or Cancel to go back and edit."
                    type="Warning" showIcon="true" class="sapUiSmallMarginBottom"/>

                <!-- One panel per modified bridge -->
                <List items="{preview>/rows}" noDataText="No changes detected">
                    <CustomListItem>
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                <ObjectStatus
                                    text="{= ${preview>isNew} ? 'NEW' : 'MODIFIED'}"
                                    state="{= ${preview>isNew} ? 'Success' : 'Warning'}"
                                    inverted="true" class="sapUiTinyMarginEnd"/>
                                <Title text="{preview>bridgeId} — {preview>name}" level="H4"/>
                            </HBox>

                            <!-- Changes table per row -->
                            <Table items="{preview>changes}" fixedLayout="true"
                                noDataText="No field changes detected"
                                class="sapUiTinyMarginStart">
                                <columns>
                                    <Column width="180px"><Text text="Field"/></Column>
                                    <Column><Text text="Old Value"/></Column>
                                    <Column><Text text="New Value"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{preview>field}" class="sapUiSmallPaddingBegin"/>
                                            <ObjectStatus text="{preview>oldValue}" state="Error"/>
                                            <ObjectStatus text="{preview>newValue}" state="Success"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </CustomListItem>
                </List>

            </VBox>
        </content>

        <buttons>
            <Button text="Confirm &amp; Save" icon="sap-icon://accept"
                type="Emphasized" press="onPreviewConfirm"/>
            <Button text="Cancel — Go Back" icon="sap-icon://decline"
                type="Transparent" press="onPreviewCancel"/>
        </buttons>

    </Dialog>

</core:FragmentDefinition>
