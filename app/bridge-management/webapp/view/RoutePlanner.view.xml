<!-- ============================================================
     NHVR Route Planner — MapLibre GL, ORS HGV Routing,
     Waypoints, Vehicle Profile, Export, Assessment
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.RoutePlanner"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    displayBlock="true">

    <f:DynamicPage id="rpPage" toggleHeaderOnTitleClick="false" headerExpanded="true">

        <!-- ── Page Title ── -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="🗺 Route Planner" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Route Planner" level="H2"/>
                </f:snappedHeading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavBack"/>
                        <Link text="Route Planner"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button id="rpSettingsBtn" icon="sap-icon://action-settings" press="onOpenSettings"
                        tooltip="API Key Settings" type="Transparent"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ── Sticky Header ── -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

                    <!-- LEFT COLUMN: Origin / Destination / Waypoints -->
                    <VBox width="320px" class="sapUiSmallMarginEnd">
                        <Label text="📍 From" design="Bold"/>
                        <Input id="rpOriginInput"
                            placeholder="e.g. Brisbane CBD, QLD"
                            liveChange="onOriginLiveChange"
                            suggest="onOriginSuggest"
                            showSuggestion="true"
                            filterSuggests="false"
                            suggestionItemSelected="onOriginSuggestionSelected"
                            class="sapUiTinyMarginBottom">
                            <suggestionItems/>
                        </Input>

                        <Label text="📍 To" design="Bold"/>
                        <Input id="rpDestInput"
                            placeholder="e.g. Sydney CBD, NSW"
                            liveChange="onDestLiveChange"
                            suggest="onDestSuggest"
                            showSuggestion="true"
                            filterSuggests="false"
                            suggestionItemSelected="onDestSuggestionSelected"
                            class="sapUiTinyMarginBottom">
                            <suggestionItems/>
                        </Input>

                        <Button id="rpAddWaypointBtn"
                            text="+ Add waypoint"
                            type="Transparent"
                            press="onAddWaypoint"
                            icon="sap-icon://add"
                            class="sapUiTinyMarginBottom"/>

                        <!-- Waypoints added programmatically -->
                        <VBox id="rpWaypointContainer"/>
                    </VBox>

                    <!-- RIGHT COLUMN: Engine + Vehicle Profile -->
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Routing Engine" design="Bold"/>
                        <Select id="rpEngineSelect" change="onEngineChange" width="220px">
                            <items>
                                <core:Item key="ors"      text="🚛 OpenRouteService (HGV)"/>
                                <core:Item key="osrm"     text="⚡ OSRM (Fast, basic)"/>
                                <core:Item key="valhalla" text="🗺 Valhalla (Truck)"/>
                            </items>
                        </Select>

                        <Label text="Vehicle Profile" design="Bold" class="sapUiSmallMarginTop"/>
                        <Panel id="rpVehiclePanel" expandable="true" expanded="true" headerText="🚛 Vehicle Configuration">
                            <content>
                                <form:SimpleForm layout="ResponsiveGridLayout"
                                    columnsL="2" columnsM="2"
                                    labelSpanL="4" labelSpanM="4"
                                    emptySpanL="0" emptySpanM="0">
                                    <Label text="Gross Mass (t)"/>
                                    <Input id="rpGVM" value="" placeholder="e.g. 42.5" width="110px" type="Number"/>
                                    <Label text="Height (m)"/>
                                    <Input id="rpHeight" value="" placeholder="e.g. 4.3" width="110px" type="Number"/>
                                    <Label text="Width (m)"/>
                                    <Input id="rpWidth" value="" placeholder="e.g. 2.5" width="110px" type="Number"/>
                                    <Label text="Length (m)"/>
                                    <Input id="rpLength" value="" placeholder="e.g. 19" width="110px" type="Number"/>
                                    <Label text="Axle Load (t)"/>
                                    <Input id="rpAxleLoad" value="" placeholder="e.g. 11" width="110px" type="Number"/>
                                    <Label text="GCM (t)"/>
                                    <Input id="rpGCM" value="" placeholder="e.g. 68" width="110px" type="Number"/>
                                    <Label text="Speed (km/h)"/>
                                    <Input id="rpSpeed" value="80" width="110px" type="Number"/>
                                    <Label text="Vehicle Class"/>
                                    <Select id="rpVehicleClass" width="150px">
                                        <items>
                                            <core:Item key="GENERAL"    text="General"/>
                                            <core:Item key="B_DOUBLE"   text="B-Double"/>
                                            <core:Item key="ROAD_TRAIN" text="Road Train"/>
                                            <core:Item key="PBS"        text="PBS Vehicle"/>
                                            <core:Item key="OVERSIZE"   text="Oversize"/>
                                        </items>
                                    </Select>
                                </form:SimpleForm>
                            </content>
                        </Panel>

                        <HBox alignItems="Center" class="sapUiSmallMarginTop">
                            <Button id="rpFindRoutesBtn"
                                text="🔍 Find Routes"
                                type="Emphasized"
                                press="onFindRoutes"
                                icon="sap-icon://search"/>
                            <Button text="💾 Save Profile"
                                type="Default"
                                press="onSaveVehicleProfile"
                                icon="sap-icon://save"
                                class="sapUiSmallMarginBegin"/>
                            <Button text="↩ Clear"
                                type="Transparent"
                                press="onClearRoute"
                                class="sapUiSmallMarginBegin"/>
                        </HBox>
                    </VBox>

                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ── Page Content ── -->
        <f:content>
            <VBox class="nhvrApp">

                <!-- Status Strips -->
                <MessageStrip id="rpBusy"
                    text="Finding routes…"
                    type="Information"
                    visible="false"
                    showIcon="true"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>

                <MessageStrip id="rpApiKeyWarning"
                    text="No ORS API key configured. Using OSRM fallback. Click ⚙ to add your free OpenRouteService API key for HGV routing."
                    type="Warning"
                    visible="false"
                    showIcon="true"
                    class="sapUiSmallMarginBeginEnd"/>

                <!-- ── Map Panel ── -->
                <Panel id="rpMapPanel"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Map" level="H4"/>
                            <ToolbarSpacer/>
                            <SegmentedButton id="rpBaseMapSwitch"
                                selectionChange="onRpBaseMapChange"
                                selectedKey="streets">
                                <items>
                                    <SegmentedButtonItem key="streets"   text="Streets"/>
                                    <SegmentedButtonItem key="satellite" text="Satellite"/>
                                    <SegmentedButtonItem key="topo"      text="Topo"/>
                                </items>
                            </SegmentedButton>
                            <ToolbarSeparator/>
                            <ToggleButton id="rpBridgeLayerBtn"
                                text="Bridges"
                                pressed="true"
                                press="onRpLayerToggle"
                                icon="sap-icon://building"/>
                            <ToggleButton id="rpRouteLayerBtn"
                                text="Routes"
                                pressed="true"
                                press="onRpLayerToggle"
                                icon="sap-icon://map-2"/>
                            <ToggleButton id="rpTrafficLayerBtn"
                                text="Traffic"
                                pressed="false"
                                press="onRpLayerToggle"
                                icon="sap-icon://Car"/>
                            <ToolbarSeparator/>
                            <Button icon="sap-icon://target-group"
                                tooltip="Fit to content"
                                press="onFitRpMap"
                                type="Transparent"/>
                            <Button id="rpDrawBtn"
                                icon="sap-icon://edit"
                                tooltip="Draw area / polygon"
                                press="onDrawToggle"
                                type="Transparent"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <core:HTML id="rpMapHolder"
                            content="&lt;div id='nhvr-rp-map' style='width:100%;height:500px;min-height:400px;'&gt;&lt;/div&gt;"
                            afterRendering="onRpMapHolderRendered"
                            preferDOM="true"/>
                    </content>
                </Panel>

                <!-- ── Route Alternatives Panel ── -->
                <Panel id="rpRoutesPanel"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"
                    visible="false"
                    headerText="Route Alternatives">
                    <content>
                        <List id="rpRouteList"
                            selectionChange="onRouteSelected"
                            mode="SingleSelectMaster"
                            growing="false"
                            noDataText="No routes found. Enter origin and destination and click Find Routes.">
                        </List>
                    </content>
                </Panel>

                <!-- ── Assess Bar ── -->
                <Toolbar id="rpAssessBar"
                    class="sapUiSmallMarginBeginEnd"
                    visible="false">
                    <Title text="Selected route ready for bridge assessment" level="H5" class="sapUiSmallMarginEnd"/>
                    <ToolbarSpacer/>
                    <Button id="rpAssessBtn"
                        text="🏗 Assess Bridges"
                        type="Emphasized"
                        press="onAssessSelectedRoute"
                        icon="sap-icon://inspection"/>
                    <Button text="📥 Export GPX"
                        press="onExportGPX"
                        type="Transparent"
                        icon="sap-icon://download"
                        class="sapUiSmallMarginBegin"/>
                    <Button text="📋 Export CSV"
                        press="onExportRouteCSV"
                        type="Transparent"
                        icon="sap-icon://excel-attachment"
                        class="sapUiSmallMarginBegin"/>
                </Toolbar>

                <!-- ── Assessment Results Panel ── -->
                <Panel id="rpResultsPanel"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"
                    visible="false">
                    <headerToolbar>
                        <Toolbar>
                            <Title id="rpResultsTitle" text="Assessment Results" level="H4"/>
                            <ToolbarSpacer/>
                            <ObjectStatus id="rpVerdictStatus" text="" state="None"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">

                            <MessageStrip id="rpVerdictStrip"
                                text=""
                                type="Information"
                                visible="true"
                                showIcon="true"
                                class="sapUiSmallMarginBottom"/>

                            <!-- KPI Tiles -->
                            <HBox wrap="Wrap" class="sapUiSmallMarginBottom">
                                <GenericTile id="rpKpiTotal"
                                    header="Total Bridges"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent>
                                            <content>
                                                <NumericContent id="rpKpiTotalVal" value="0" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                                <GenericTile id="rpKpiPass"
                                    header="✅ Clear"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent>
                                            <content>
                                                <NumericContent id="rpKpiPassVal" value="0" valueColor="Good" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                                <GenericTile id="rpKpiWarn"
                                    header="⚠ Conditions"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent>
                                            <content>
                                                <NumericContent id="rpKpiWarnVal" value="0" valueColor="Critical" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                                <GenericTile id="rpKpiFail"
                                    header="❌ Blocked"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent>
                                            <content>
                                                <NumericContent id="rpKpiFailVal" value="0" valueColor="Error" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                                <GenericTile id="rpKpiMass"
                                    header="Mass Margin"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent unit="t">
                                            <content>
                                                <NumericContent id="rpKpiMassVal" value="—" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                                <GenericTile id="rpKpiClear"
                                    header="Clearance Margin"
                                    frameType="OneByOne"
                                    class="nhvrKpiTileSmall sapUiTinyMargin">
                                    <tileContent>
                                        <TileContent unit="m">
                                            <content>
                                                <NumericContent id="rpKpiClearVal" value="—" withMargin="false"/>
                                            </content>
                                        </TileContent>
                                    </tileContent>
                                </GenericTile>
                            </HBox>

                            <Text id="rpProximityNote" text="" class="sapUiTinyMarginBottom"/>

                            <!-- Bridge Conflict Table -->
                            <Title text="Bridge Details" level="H5" class="sapUiTinyMarginBottom"/>
                            <Table id="rpBridgeTable"
                                items="{rpBridges>/bridges}"
                                growing="true"
                                growingThreshold="50"
                                fixedLayout="false"
                                noDataText="No bridges assessed yet.">
                                <headerToolbar>
                                    <Toolbar>
                                        <Text text="Bridges on Route"/>
                                        <ToolbarSpacer/>
                                        <Select id="rpRoadCategoryFilter"
                                            change="onRoadCategoryFilter"
                                            width="160px">
                                            <items>
                                                <core:Item key=""                  text="All Road Classes"/>
                                                <core:Item key="National Highway"  text="National Highway"/>
                                                <core:Item key="State Highway"     text="State Highway"/>
                                                <core:Item key="Regional Road"     text="Regional Road"/>
                                                <core:Item key="Council Road"      text="Council Road"/>
                                            </items>
                                        </Select>
                                    </Toolbar>
                                </headerToolbar>
                                <columns>
                                    <Column width="110px"><Text text="Bridge ID"/></Column>
                                    <Column><Text text="Name"/></Column>
                                    <Column width="100px"><Text text="Road/Route"/></Column>
                                    <Column width="80px" hAlign="Center"><Text text="Verdict"/></Column>
                                    <Column width="80px" hAlign="Center"><Text text="Mass Limit"/></Column>
                                    <Column width="80px" hAlign="Center"><Text text="Clearance"/></Column>
                                    <Column width="80px" hAlign="Center"><Text text="Proximity"/></Column>
                                    <Column><Text text="Issues / Warnings"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem
                                        type="Active"
                                        press="onBridgeRowPress"
                                        highlight="{= ${rpBridges>verdict} === 'FAIL' ? 'Error' : ${rpBridges>verdict} === 'CONDITIONS' ? 'Warning' : ${rpBridges>verdict} === 'PASS' ? 'Success' : 'None'}">
                                        <cells>
                                            <Link text="{rpBridges>bridgeId}" press="onBridgeRowPress"/>
                                            <Text text="{rpBridges>name}" maxLines="1" wrapping="false"/>
                                            <Text text="{rpBridges>roadRoute}" maxLines="1" wrapping="false"/>
                                            <ObjectStatus
                                                text="{rpBridges>verdict}"
                                                state="{path:'rpBridges>verdict', formatter:'.fmtVerdictState'}"/>
                                            <Text text="{path:'rpBridges>effectiveMassLimit_t', formatter:'.fmtOptNum'}"/>
                                            <Text text="{path:'rpBridges>effectiveClearance_m', formatter:'.fmtMetres'}"/>
                                            <Text text="{rpBridges>proximityM}"/>
                                            <Text text="{path:'rpBridges>', formatter:'.fmtIssuesWarnings'}" maxLines="2" wrapping="true"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>

                        </VBox>
                    </content>
                </Panel>

            </VBox>
        </f:content>

    </f:DynamicPage>

    <!-- ── Settings Dialog ── -->
    <Dialog id="rpSettingsDialog" title="Route Planner Settings" contentWidth="400px">
        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                <Title text="OpenRouteService API Key" level="H5"/>
                <Text text="Get a free API key at https://openrouteservice.org — enables HGV-specific routing with height/weight restrictions."
                    wrapping="true"
                    class="sapUiTinyMarginBottom"/>
                <Input id="rpOrsApiKeyInput"
                    placeholder="Enter your ORS API key..."
                    width="100%"/>
                <Text text="Your API key is stored in browser localStorage only and never sent to the server."
                    wrapping="true"
                    class="sapUiTinyMarginTop"/>
                <Title text="HERE Maps API Key (Optional)" level="H5" class="sapUiSmallMarginTop"/>
                <Text text="For premium HGV routing with live traffic. Leave blank to use ORS/OSRM."
                    wrapping="true"
                    class="sapUiTinyMarginBottom"/>
                <Input id="rpHereApiKeyInput"
                    placeholder="Enter HERE API key..."
                    width="100%"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveSettings"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" type="Transparent" press="onCloseSettings"/>
        </endButton>
    </Dialog>

</mvc:View>
