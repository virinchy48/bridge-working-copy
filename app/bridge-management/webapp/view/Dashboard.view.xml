<!-- ============================================================
     NHVR Command Dashboard — Asset Command Centre
     Uses core:HTML to embed a custom command dashboard
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">

    <f:DynamicPage id="dashPage" toggleHeaderOnTitleClick="false" fitContent="true">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Asset Command Dashboard" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Asset Command Dashboard" level="H2"/>
                </f:snappedHeading>
                <f:actions>
                    <Button icon="sap-icon://hint" type="Transparent" press="onInfoPressDashboard"
                        tooltip="KPI definitions and dashboard guide"/>
                    <Button text="Refresh" icon="sap-icon://refresh" press="onRefresh" type="Transparent"/>
                </f:actions>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Dashboard"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <core:HTML id="dashboardRoot"
                content="&lt;div id='nhvr-cmd-dashboard' class='nhvr-cmd-dash'&gt;&lt;div class='cmd-wrap' style='text-align:center;padding:60px 20px;color:var(--mu)'&gt;Loading dashboard...&lt;/div&gt;&lt;/div&gt;"
                preferDOM="true"
                sanitizeContent="false"/>
        </f:content>
    </f:DynamicPage>
</mvc:View>
