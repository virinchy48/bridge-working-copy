<!-- ============================================================
     NHVR Bridge Defects — All-Bridges Defect Register
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.Defects"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    displayBlock="true">

    <f:DynamicPage id="defectsPage" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Defect Register" level="H1"/>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Defect Register"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button id="btnExportDefects" text="Export Excel" icon="sap-icon://excel-attachment" type="Transparent" press="onExportCsv" tooltip="Export defect register to Excel (.xlsx)"/>
                    <Button icon="sap-icon://hint" type="Transparent" press="onInfoPressDefects"
                        tooltip="Defect severity levels, status workflow, and field guide"/>
                    <Button text="Refresh" icon="sap-icon://refresh" type="Transparent" press="onRefresh"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- Header KPI Strip -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Total Defects" design="Bold"/>
                        <ObjectStatus id="kpiTotal" text="—" state="None"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Open" design="Bold"/>
                        <ObjectStatus id="kpiOpen" text="—" state="Error"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Critical" design="Bold"/>
                        <ObjectStatus id="kpiCritical" text="—" state="Error"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="High Severity" design="Bold"/>
                        <ObjectStatus id="kpiHigh" text="—" state="Warning"/>
                    </VBox>
                    <VBox>
                        <Label text="Est. Repair Cost" design="Bold"/>
                        <ObjectStatus id="kpiCost" text="—" state="None"/>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <!-- Filters -->
                <HBox wrap="Wrap" alignItems="Center" class="sapUiSmallMarginBottom">
                    <Select id="statusFilter" change="onFilter" width="150px" class="sapUiSmallMarginEnd">
                    </Select>
                    <Select id="severityFilter" change="onFilter" width="150px" class="sapUiSmallMarginEnd">
                    </Select>
                    <Select id="categoryFilter" change="onFilter" width="160px" class="sapUiSmallMarginEnd">
                    </Select>
                    <Select id="priorityFilter" change="onFilter" width="150px" class="sapUiSmallMarginEnd">
                    </Select>
                    <ToolbarSeparator/>
                    <MenuButton id="defectViewsMenuBtn" text="Saved Views" icon="sap-icon://filter" class="sapUiSmallMarginEnd">
                        <menu>
                            <Menu id="defectViewsMenu"/>
                        </menu>
                    </MenuButton>
                    <Button text="Save View" icon="sap-icon://save" press="onSaveDefectView" tooltip="Save current filters as a named view"/>
                </HBox>

                <Table id="defectsTable"
                    items="{defects>/defects}"
                    noDataText="No defects found matching the filters"
                    fixedLayout="false"
                    alternateRowColors="true"
                    sticky="ColumnHeaders,HeaderToolbar"
                    growing="true" growingThreshold="50">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Text id="alvRecordCount" text="" class="nhvrSubText"/>
                            <ToolbarSeparator/>
                            <Title id="tableTitle" text="Defects Register" level="H3"/>
                            <ToolbarSpacer/>
                            <Button text="Raise Defect" icon="sap-icon://add" press="onRaiseDefect" type="Emphasized"/>
                            <ToolbarSeparator/>
                            <!-- Create Work Order button removed in cut-down BIS variant. -->
                            <Button id="btnAiClassify" text="AI Classify" icon="sap-icon://ai"
                                type="Default" press="onAiClassifyDefect" enabled="false"
                                tooltip="Run AI defect classification on the selected defect"/>
                            <ToolbarSeparator/>
                            <Button icon="sap-icon://sort" text="Sort" press="onAlvSort" type="Transparent" tooltip="Sort"/>
                            <ToolbarSeparator/>
                            <Button icon="sap-icon://excel-attachment" text="Excel" press="onAlvExportExcel" type="Transparent"/>
                            <Button icon="sap-icon://download" text="CSV" press="onAlvExportCsv" type="Transparent"/>
                            <Button icon="sap-icon://pdf-attachment" text="Print" press="onAlvExportPdf" type="Transparent"/>
                            <ToolbarSeparator/>
                            <Button icon="sap-icon://table-column" text="Columns"
                                press="onDefectColumnChooser" type="Transparent" tooltip="Show/hide columns"/>
                            <Button icon="sap-icon://refresh" text="Refresh" press="onAlvRefresh" type="Transparent"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="dColNumber" width="160px"><Text text="Defect No."/></Column>
                        <Column id="dColBridge" width="190px"><Text text="Bridge"/></Column>
                        <Column id="dColCategory" width="130px" minScreenWidth="Tablet" demandPopin="true"><Text text="Category"/></Column>
                        <Column id="dColSeverity" width="110px" hAlign="Center"><Text text="Severity"/></Column>
                        <Column id="dColElement" width="120px" minScreenWidth="Tablet" demandPopin="true"><Text text="Element Group"/></Column>
                        <Column id="dColPriority" width="110px" hAlign="Center" minScreenWidth="Tablet" demandPopin="true"><Text text="Priority"/></Column>
                        <Column id="dColStatus" width="110px" hAlign="Center"><Text text="Status"/></Column>
                        <Column id="dColDetected" width="110px" minScreenWidth="Desktop" demandPopin="true"><Text text="Detected"/></Column>
                        <Column id="dColCost" width="130px" hAlign="End" minScreenWidth="Desktop" demandPopin="true"><Text text="Est. Repair (AUD)"/></Column>
                        <Column id="dColActions" width="80px" hAlign="Center"><Text text="Actions"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem
                            highlight="{= ${defects>severity} === 'CRITICAL' ? 'Error' : ${defects>severity} === 'HIGH' ? 'Warning' : 'None'}"
                            press="onDefectPress" type="Navigation" vAlign="Middle">
                            <cells>
                                <VBox>
                                    <Link text="{defects>defectNumber}" press="onDefectNumberPress" wrapping="false"
                                        tooltip="Open defect detail for {defects>defectNumber}"/>
                                    <Text text="{defects>location}" class="sapUiTinyFont nhvrSubText" wrapping="true"/>
                                </VBox>
                                <VBox>
                                    <Text text="{defects>bridgeName}" wrapping="true"/>
                                    <Link text="{defects>bridgeId}" press="onBridgeIdPress"
                                        class="sapUiTinyFont" wrapping="false"
                                        tooltip="Open bridge detail for {defects>bridgeId}"/>
                                </VBox>
                                <ObjectStatus text="{defects>defectCategory}"
                                    state="{= ${defects>defectCategory} === 'STRUCTURAL' ? 'Error' : ${defects>defectCategory} === 'SAFETY' ? 'Warning' : 'None'}"/>
                                <ObjectStatus text="{defects>severity}"
                                    state="{= ${defects>severity} === 'CRITICAL' ? 'Error' : ${defects>severity} === 'HIGH' ? 'Warning' : ${defects>severity} === 'MEDIUM' ? 'Information' : 'None'}"/>
                                <Text text="{defects>elementGroup}" wrapping="true"/>
                                <ObjectStatus text="{defects>priority}"
                                    state="{= ${defects>priority} === 'IMMEDIATE' ? 'Error' : ${defects>priority} === 'HIGH' ? 'Warning' : 'None'}"/>
                                <ObjectStatus text="{defects>status}"
                                    state="{= ${defects>status} === 'CLOSED' ? 'Success' : ${defects>status} === 'OPEN' ? 'Error' : 'Warning'}"/>
                                <Text text="{defects>detectedDate}" wrapping="true"/>
                                <ObjectNumber number="{defects>repairEstimateAUD}" unit="AUD"/>
                                <Button icon="sap-icon://accept" tooltip="Close Defect" type="Transparent"
                                    press="onCloseDefect"
                                    visible="{= ${defects>status} === 'OPEN' || ${defects>status} === 'UNDER_REPAIR' || ${defects>status} === 'REPAIRED'}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>

    <!-- Create Work Order Dialog removed in cut-down BIS variant. -->

    <!-- ── P14: AI Classify Result Dialog ────────────────── -->
    <Dialog id="aiClassifyDialog" title="AI Defect Classification Result" contentWidth="440px">
        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                <Label text="Category" class="sapUiTinyMarginBottom"/>
                <ObjectStatus id="aiResultCategory" text="—" state="None" class="sapUiSmallMarginBottom"/>
                <Label text="Severity" class="sapUiTinyMarginBottom"/>
                <ObjectStatus id="aiResultSeverity" text="—" state="None" class="sapUiSmallMarginBottom"/>
                <Label text="Confidence" class="sapUiTinyMarginBottom"/>
                <Text id="aiResultConfidence" text="—" class="sapUiSmallMarginBottom"/>
                <Label text="AI Notes" class="sapUiTinyMarginBottom"/>
                <Text id="aiResultNotes" text="—" wrapping="true"/>
                <MessageStrip id="aiReviewStrip" text="AI classification requires human review before actioning."
                    type="Information" showIcon="true" class="sapUiSmallMarginTop"/>
            </VBox>
        </content>
        <buttons>
            <Button text="Close" press="onCloseAiDialog" type="Transparent"/>
        </buttons>
    </Dialog>

    <!-- ── Column Chooser Dialog ──────────────────────────── -->
    <Dialog id="defectColumnChooserDialog" title="Show / Hide Columns" contentWidth="300px">
        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <CheckBox id="dglColCategory" text="Category"          selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="dglColElement"  text="Element Group"     selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="dglColPriority" text="Priority"          selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="dglColDetected" text="Detected Date"     selected="true"  class="sapUiTinyMarginBottom"/>
                <CheckBox id="dglColCost"     text="Est. Repair (AUD)" selected="true"  class="sapUiTinyMarginBottom"/>
            </VBox>
        </content>
        <buttons>
            <Button text="Apply" type="Emphasized" press="onApplyDefectColumns"/>
            <Button text="Close" press="onCloseDefectColumnChooser" type="Transparent"/>
        </buttons>
    </Dialog>

</mvc:View>
