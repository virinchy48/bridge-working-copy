<!-- ============================================================
     NHVR Mass Edit — Multi-Entity Editable Grid with Column Picker
     & Bulk Apply.  Table columns are built PROGRAMMATICALLY in the
     controller (_buildTable).  Do not add <columns> here.
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.MassEdit"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">

    <f:DynamicPage id="massEditPage" toggleHeaderOnTitleClick="false">

        <!-- ── Title ── -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Mass Edit" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Mass Edit" level="H2"/>
                </f:snappedHeading>
                <f:actions>
                    <Button text="Home" icon="sap-icon://home" press="onNavHome" type="Transparent"/>
                </f:actions>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Mass Edit"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ── Collapsible Header — Entity Selector + Filters ── -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">

                    <!-- Row 1: Entity type selector -->
                    <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <Label text="Edit Entity:" design="Bold" class="sapUiSmallMarginEnd" width="80px"/>
                        <SegmentedButton id="meEntitySelector" selectionChange="onEntityTypeChange" selectedKey="BRIDGE">
                            <items>
                                <SegmentedButtonItem key="BRIDGE"           text="Bridges"           icon="sap-icon://building"/>
                                <SegmentedButtonItem key="RESTRICTION"      text="Restrictions"      icon="sap-icon://alert"/>
                                <SegmentedButtonItem key="DEFECT"           text="Defects"           icon="sap-icon://message-error"/>
                                <SegmentedButtonItem key="INSPECTION_ORDER" text="Inspections"       icon="sap-icon://checklist"/>
                                <SegmentedButtonItem key="PERMIT"           text="Permits"           icon="sap-icon://document-text"/>
                            </items>
                        </SegmentedButton>
                    </HBox>

                    <!-- Row 2: Filters + action buttons -->
                    <HBox wrap="Wrap" alignItems="Center">
                        <VBox class="sapUiSmallMarginEnd" visible="{massEdit>/showStateFilter}">
                            <Label text="State" design="Bold"/>
                            <Select id="meFilterState" change="onMEFilterChange" width="110px"/>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text="Search" design="Bold"/>
                            <SearchField id="meSearch" width="220px"
                                placeholder="Search records…"
                                liveChange="onMEFilterChange"/>
                        </VBox>
                        <VBox class="sapUiSmallMarginEnd">
                            <Label text=" " design="Bold"/>
                            <Button id="meColumnPickerBtn"
                                text="Columns"
                                icon="sap-icon://table-column"
                                press="onColumnPickerOpen"
                                type="Default"/>
                        </VBox>
                        <VBox>
                            <Label text=" " design="Bold"/>
                            <Button id="meBulkApplyToggleBtn"
                                text="Bulk Apply"
                                icon="sap-icon://multi-edit"
                                press="onBulkApplyToggle"
                                type="Default"/>
                        </VBox>
                    </HBox>

                    <!-- Row 3: Bulk Apply inline bar (hidden until toggled) -->
                    <Panel id="meBulkApplyPanel" visible="false" backgroundDesign="Transparent"
                        class="sapUiTinyMarginTop">
                        <content>
                            <HBox wrap="Wrap" alignItems="Center"
                                class="sapUiTinyPaddingBeginEnd sapUiTinyPaddingTopBottom nhvrMassEditBulkBar">
                                <Label text="Field:" design="Bold" class="sapUiSmallMarginEnd"/>
                                <Select id="meBulkField" change="onBulkApplyFieldChange"
                                    width="200px" class="sapUiSmallMarginEnd">
                                    <core:Item key="" text="— select field —"/>
                                </Select>
                                <Input id="meBulkValueInput" width="180px" class="sapUiSmallMarginEnd"
                                    visible="{= ${massEdit>/bulkInputType} === 'text' || ${massEdit>/bulkInputType} === 'number' || ${massEdit>/bulkInputType} === 'decimal'}"/>
                                <Select id="meBulkValueSelect" width="180px" class="sapUiSmallMarginEnd"
                                    visible="{= ${massEdit>/bulkInputType} === 'select'}"/>
                                <DatePicker id="meBulkValueDate" width="160px"
                                    displayFormat="dd/MM/yyyy" valueFormat="yyyy-MM-dd"
                                    class="sapUiSmallMarginEnd"
                                    visible="{= ${massEdit>/bulkInputType} === 'date'}"/>
                                <CheckBox id="meBulkValueBool"
                                    visible="{= ${massEdit>/bulkInputType} === 'boolean'}"
                                    class="sapUiSmallMarginEnd"/>
                                <Button text="Apply to Selected ({massEdit>/selectedCount})"
                                    icon="sap-icon://accept"
                                    type="Emphasized"
                                    press="onBulkApplyExecute"
                                    enabled="{= ${massEdit>/selectedCount} > 0 &amp;&amp; !!${massEdit>/bulkFieldKey}}"/>
                                <Button text="Close"
                                    icon="sap-icon://decline"
                                    type="Transparent"
                                    press="onBulkApplyToggle"
                                    class="sapUiSmallMarginBegin"/>
                            </HBox>
                        </content>
                    </Panel>

                </VBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ── Content ── -->
        <f:content>
            <VBox class="nhvrApp">

                <MessageStrip id="meBusyStrip"
                    text="Loading data…"
                    type="Information" showIcon="true"
                    visible="true"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>

                <MessageStrip id="meDirtyStrip" text="" type="Warning" showIcon="true"
                    visible="false" class="sapUiSmallMarginBeginEnd"/>

                <MessageStrip id="meCustomAttrStrip"
                    text="{massEdit>/customAttrInfo}"
                    type="Success" showIcon="true"
                    visible="{= !!${massEdit>/customAttrInfo}}"
                    class="sapUiSmallMarginBeginEnd"/>

                <!--
                    Editable Grid Table.
                    Columns and ColumnListItem template are injected
                    PROGRAMMATICALLY by controller._buildTable().
                    Do NOT add <columns> or <items> template here.
                -->
                <Table id="massEditTable"
                    mode="MultiSelect"
                    selectionChange="onTableSelectionChange"
                    fixedLayout="false"
                    growing="true"
                    growingThreshold="100"
                    noDataText="No records found."
                    class="sapUiSmallMarginBeginEnd">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title id="meTableTitle" text="Records" level="H3"/>
                            <ToolbarSpacer/>
                            <Button text="Add Row"
                                icon="sap-icon://add"
                                press="onMEAddRow"
                                type="Default"/>
                            <Button id="meSaveBtn"
                                text="Save Changes"
                                icon="sap-icon://save"
                                press="onMESaveAll"
                                type="Emphasized"
                                enabled="false"/>
                            <Button text="Discard"
                                icon="sap-icon://decline"
                                press="onMEDiscard"
                                type="Transparent"/>
                            <Button text="Export CSV"
                                icon="sap-icon://download"
                                press="onMEExport"
                                type="Transparent"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <!-- columns and items injected by _buildTable() -->
                </Table>

            </VBox>
        </f:content>

    </f:DynamicPage>

</mvc:View>
