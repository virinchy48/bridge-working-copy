<mvc:View
  controllerName="nhvr.bridgemanagement.controller.InspectionCreate"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  displayBlock="true">
  <Page id="inspCreatePage" title="Record Bridge Inspection" showNavButton="true" navButtonPress=".onNavBack">
    <content>
      <f:SimpleForm id="inspForm" editable="true" layout="ResponsiveGridLayout"
        labelSpanL="4" labelSpanM="4" columnsL="2" columnsM="1" class="sapUiSmallMargin">
        <f:title><core:Title text="A. Structure Identification"/></f:title>
        <Label text="Inspection Type" required="true"/>
        <Select id="selInspType" selectedKey="{InspectionForm>/inspectionType}">
          <core:Item key="L1_ROUTINE"   text="Level 1 — Routine General (2yr)"/>
          <core:Item key="L2_PRINCIPAL" text="Level 2 — Principal Inspection (4yr)"/>
          <core:Item key="L3_SPECIAL"   text="Level 3 — Special / Underwater"/>
          <core:Item key="L4_EMERGENCY" text="Level 4 — Emergency"/>
          <core:Item key="RPA_DRONE"    text="RPA / Drone (TS 00119:2024)"/>
          <core:Item key="CULVERT_CDC"  text="Culvert CDC"/>
        </Select>
        <Label text="Standard Applied"/>
        <Select id="selStandard" selectedKey="{InspectionForm>/standardApplied}">
          <core:Item key="AS5100.7:2017"     text="AS 5100.7:2017"/>
          <core:Item key="TfNSW TMC 2012.01" text="TfNSW TMC 2012.01"/>
          <core:Item key="TfNSW TS01630"     text="TfNSW TS 01630"/>
          <core:Item key="NAASRA BMS"        text="NAASRA BMS"/>
          <core:Item key="TfNSW CAMTM 2022"  text="TfNSW Culvert Manual 2022"/>
        </Select>
        <Label text="Inspection Date" required="true"/>
        <DatePicker id="inspDate" value="{InspectionForm>/inspectionDate}" valueFormat="yyyy-MM-dd"/>
        <Label text="Inspector Name" required="true"/>
        <Input id="inspName" value="{InspectionForm>/inspectorName}" placeholder="Full name"/>
        <Label text="Inspector Cert No."/>
        <Input id="inspCert" value="{InspectionForm>/inspectorCertNo}" placeholder="TfNSW cert number"/>
        <Label text="Access Method"/>
        <Select id="selAccess" selectedKey="{InspectionForm>/accessMethod}">
          <core:Item key="VISUAL" text="Visual — Ground / Platform"/>
          <core:Item key="ROPE"   text="Rope / Abseiling"/>
          <core:Item key="BOAT"   text="Boat / Underwater"/>
          <core:Item key="RPA"    text="RPA / Drone"/>
          <core:Item key="UBIV"   text="Under-bridge inspection vehicle"/>
        </Select>

        <f:title><core:Title text="B. Element Condition Ratings (1=Critical to 5=Very Good)"/></f:title>
        <Label text="Deck / Wearing Surface"/>
        <SegmentedButton id="segDeck" selectedKey="{InspectionForm>/deckRating}">
          <items>
            <SegmentedButtonItem key="1" text="1"/>
            <SegmentedButtonItem key="2" text="2"/>
            <SegmentedButtonItem key="3" text="3"/>
            <SegmentedButtonItem key="4" text="4"/>
            <SegmentedButtonItem key="5" text="5"/>
          </items>
        </SegmentedButton>
        <Label text="Superstructure / Girders"/>
        <SegmentedButton id="segSuper" selectedKey="{InspectionForm>/superstructureRating}">
          <items>
            <SegmentedButtonItem key="1" text="1"/>
            <SegmentedButtonItem key="2" text="2"/>
            <SegmentedButtonItem key="3" text="3"/>
            <SegmentedButtonItem key="4" text="4"/>
            <SegmentedButtonItem key="5" text="5"/>
          </items>
        </SegmentedButton>
        <Label text="Substructure / Piers"/>
        <SegmentedButton id="segSub" selectedKey="{InspectionForm>/substructureRating}">
          <items>
            <SegmentedButtonItem key="1" text="1"/>
            <SegmentedButtonItem key="2" text="2"/>
            <SegmentedButtonItem key="3" text="3"/>
            <SegmentedButtonItem key="4" text="4"/>
            <SegmentedButtonItem key="5" text="5"/>
          </items>
        </SegmentedButton>
        <Label text="Bearings"/>
        <SegmentedButton id="segBearing" selectedKey="{InspectionForm>/bearingRating}">
          <items>
            <SegmentedButtonItem key="1" text="1"/>
            <SegmentedButtonItem key="2" text="2"/>
            <SegmentedButtonItem key="3" text="3"/>
            <SegmentedButtonItem key="4" text="4"/>
            <SegmentedButtonItem key="5" text="5"/>
          </items>
        </SegmentedButton>
        <Label text="Expansion Joints"/>
        <SegmentedButton id="segJoint" selectedKey="{InspectionForm>/jointRating}">
          <items>
            <SegmentedButtonItem key="1" text="1"/>
            <SegmentedButtonItem key="2" text="2"/>
            <SegmentedButtonItem key="3" text="3"/>
            <SegmentedButtonItem key="4" text="4"/>
            <SegmentedButtonItem key="5" text="5"/>
          </items>
        </SegmentedButton>

        <f:title><core:Title text="C. Defects and Observations"/></f:title>
        <Label text="Primary Defect Code"/>
        <Select id="selDefect" selectedKey="{InspectionForm>/primaryDefectCode}">
          <core:Item key="NONE" text="None"/>
          <core:Item key="D1"   text="D1 — Cracking / Fracture"/>
          <core:Item key="D2"   text="D2 — Spalling / Delamination"/>
          <core:Item key="D3"   text="D3 — Corrosion / Section Loss"/>
          <core:Item key="D4"   text="D4 — Deformation / Buckling"/>
          <core:Item key="D5"   text="D5 — Joint / Bearing Failure"/>
          <core:Item key="D6"   text="D6 — Settlement / Movement"/>
          <core:Item key="D7"   text="D7 — Biological / Chemical Attack"/>
          <core:Item key="D8"   text="D8 — Impact / Collision Damage"/>
          <core:Item key="D9"   text="D9 — Scour / Undermining"/>
          <core:Item key="CD01" text="CD-01 — Joint Displacement (Culvert)"/>
          <core:Item key="CD02" text="CD-02 — Cracking Longitudinal (Culvert)"/>
          <core:Item key="CD08" text="CD-08 — Blockage (Culvert)"/>
        </Select>
        <Label text="Defect Severity"/>
        <Select id="selSeverity" selectedKey="{InspectionForm>/defectSeverity}">
          <core:Item key="NONE"     text="None"/>
          <core:Item key="MINOR"    text="Minor"/>
          <core:Item key="MODERATE" text="Moderate — Schedule repair"/>
          <core:Item key="SEVERE"   text="Severe — Urgent repair"/>
          <core:Item key="CRITICAL" text="Critical — Immediate action"/>
        </Select>
        <Label text="Inspector Notes"/>
        <TextArea id="inspNotes" value="{InspectionForm>/inspectorNotes}" rows="4" growing="true" width="100%"
          placeholder="Describe observed conditions, element locations, access restrictions..."/>
        <Label text="Estimated Repair Cost (AUD)"/>
        <Input id="repairCost" value="{InspectionForm>/estimatedRepairCost}" type="Number" placeholder="0.00"/>
        <Label text="Next Inspection Due"/>
        <DatePicker id="nextInsp" value="{InspectionForm>/nextInspectionDue}" valueFormat="yyyy-MM-dd"/>
      </f:SimpleForm>
    </content>
    <footer>
      <OverflowToolbar>
        <ToolbarSpacer/>
        <Button text="Cancel"    press=".onNavBack"          type="Default"/>
        <Button text="Save Draft" press=".onSaveDraft"       type="Neutral"/>
        <Button text="Submit Inspection" press=".onSubmitInspection" type="Emphasized"/>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>
