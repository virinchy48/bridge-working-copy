<mvc:View
    controllerName="nhvr.bridgemanagement.controller.FreightRoutes"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    displayBlock="true">

    <f:DynamicPage id="freightRoutesPage" fitContent="true" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Freight Route Corridors" level="H2"/>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Freight Routes"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button id="btnAddRoute" text="Add Route" icon="sap-icon://add"
                        type="Emphasized" press="onAddRoute"/>
                    <Button id="btnAssessCorridor" text="Assess Corridor" icon="sap-icon://detail-view"
                        type="Default" press="onAssessCorridor" enabled="false"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

                <!-- Search + Info Bar -->
                <HBox class="sapUiSmallMarginBottom" alignItems="Center">
                    <SearchField id="routeSearch" placeholder="Search by route code, name or state..."
                        width="24rem" search="onSearch" liveChange="onSearch"/>
                    <!-- Items populated at runtime from Lookup table (ROUTE_CLASS category) -->
                    <Select id="routeClassFilter" width="12rem" change="onClassFilter"
                        class="sapUiSmallMarginBegin"/>
                    <Select id="routeStateFilter" width="8rem" change="onStateFilter"
                        class="sapUiSmallMarginBegin"/>
                    <Text id="routeCount" text="Loading..." class="sapUiSmallMarginBegin sapUiSmallMarginTop"/>
                </HBox>

                <!-- Freight Routes Table -->
                <t:Table id="freightRoutesTable"
                    rows="{freightRoutes>/items}"
                    visibleRowCount="15"
                    selectionMode="Single"
                    rowSelectionChange="onRowSelectionChange"
                    enableSelectAll="false"
                    noData="No freight routes found"
                    class="nhvrTable">
                    <t:toolbar>
                        <OverflowToolbar>
                            <Title text="Routes" level="H4"/>
                            <ToolbarSpacer/>
                            <Button icon="sap-icon://refresh" tooltip="Refresh" press="onRefresh"/>
                        </OverflowToolbar>
                    </t:toolbar>
                    <t:columns>
                        <t:Column width="8rem">
                            <Label text="Route Code" design="Bold"/>
                            <t:template>
                                <Link text="{freightRoutes>routeCode}" press="onOpenRoute" wrapping="false"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="16rem">
                            <Label text="Name" design="Bold"/>
                            <t:template>
                                <Text text="{freightRoutes>name}" wrapping="false"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="5rem">
                            <Label text="State" design="Bold"/>
                            <t:template>
                                <Text text="{freightRoutes>state}"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem">
                            <Label text="Class" design="Bold"/>
                            <t:template>
                                <ObjectStatus text="{freightRoutes>routeClass}"
                                    state="{= ${freightRoutes>routeClass} === 'PBS' ? 'Success' : (${freightRoutes>routeClass} === 'HML' ? 'Warning' : 'None') }"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="End">
                            <Label text="Max Mass (t)" design="Bold"/>
                            <t:template>
                                <ObjectNumber number="{freightRoutes>corridorMaxMass}" unit="t"
                                    state="{= ${freightRoutes>corridorMaxMass} ? (${freightRoutes>corridorMaxMass} >= 50 ? 'Success' : 'Warning') : 'None' }"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="9rem" hAlign="End">
                            <Label text="Max Height (m)" design="Bold"/>
                            <t:template>
                                <Text text="{freightRoutes>corridorMaxHeight}"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="8rem">
                            <Label text="Status" design="Bold"/>
                            <t:template>
                                <ObjectStatus text="{freightRoutes>status}"
                                    state="{= ${freightRoutes>status} === 'ACTIVE' ? 'Success' : (${freightRoutes>status} === 'SUSPENDED' ? 'Error' : 'None') }"/>
                            </t:template>
                        </t:Column>
                        <t:Column width="10rem">
                            <Label text="Last Assessed" design="Bold"/>
                            <t:template>
                                <Text text="{path:'freightRoutes>lastAssessedAt', type:'sap.ui.model.type.DateTime', formatOptions:{style:'medium'}}"/>
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>

            </VBox>
        </f:content>
    </f:DynamicPage>

    <!-- Add/Edit Freight Route Dialog -->
    <Dialog id="addRouteDialog" title="Add Freight Route Corridor" contentWidth="32rem">
        <content>
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout" columnsL="1" columnsM="1">
                <Label text="Route Code *"/>
                <Input id="fRouteCode" placeholder="e.g. NSW-HML-001" maxLength="20"/>
                <Label text="Name"/>
                <Input id="fRouteName" placeholder="e.g. Newell Highway HML Corridor" maxLength="200"/>
                <Label text="State"/>
                <Select id="fRouteState"/>
                <Label text="Route Class"/>
                <!-- Items populated at runtime from Lookup table (ROUTE_CLASS) -->
                <Select id="fRouteClass"/>
                <Label text="Max Height (m)"/>
                <Input id="fCorridorMaxHeight" placeholder="e.g. 4.3" type="Number"/>
                <Label text="Status"/>
                <!-- Items populated at runtime from Lookup table (ROUTE_STATUS) -->
                <Select id="fRouteStatus"/>
            </form:SimpleForm>
        </content>
        <beginButton>
            <Button text="Save Route" type="Emphasized" press="onSaveRoute"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCloseRouteDialog"/>
        </endButton>
    </Dialog>

</mvc:View>
