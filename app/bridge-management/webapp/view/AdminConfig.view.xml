<!-- ============================================================
     NHVR Admin Config View — Attribute Definitions & Audit Logs
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.AdminConfig"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:form="sap.ui.layout.form"
    displayBlock="true">

    <f:DynamicPage id="adminConfigPage" headerExpanded="true" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="BMS Business Admin — Configuration" level="H2"/>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:content>
            <IconTabBar id="adminTabBar" select="onTabSelect" class="sapUiNoContentPadding">
                <items>

                <!-- ── Tab 1: Attribute Definitions ──────────────────── -->
                <IconTabFilter key="attrDefs" icon="sap-icon://tag" text="Attribute Definitions">
                    <VBox class="sapUiMediumMargin">
                        <Toolbar>
                            <Title text="Bridge Attribute Definitions" level="H3"/>
                            <ToolbarSpacer/>
                            <Button id="btnAddAttr" text="Add Attribute" icon="sap-icon://add" type="Emphasized" press="onAddAttribute"/>
                        </Toolbar>
                        <Table id="attrDefsTable"
                            items="{attrDefs>/items}"
                            headerText="Attribute Definitions"
                            growing="true"
                            growingThreshold="20"
                            noDataText="No attribute definitions found"
                            class="sapUiTinyMarginTop">
                            <columns>
                                <Column><Text text="Internal Name"/></Column>
                                <Column><Text text="Display Label"/></Column>
                                <Column><Text text="Data Type"/></Column>
                                <Column><Text text="Target"/></Column>
                                <Column><Text text="Required"/></Column>
                                <Column><Text text="Order"/></Column>
                                <Column><Text text="Active"/></Column>
                                <Column hAlign="End"><Text text="Actions"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{attrDefs>name}"/>
                                        <Text text="{attrDefs>label}"/>
                                        <ObjectStatus text="{attrDefs>dataType}" state="Information"/>
                                        <Text text="{attrDefs>entityTarget}"/>
                                        <CheckBox selected="{attrDefs>isRequired}" enabled="false"/>
                                        <Text text="{attrDefs>displayOrder}"/>
                                        <CheckBox selected="{attrDefs>isActive}" enabled="false"/>
                                        <HBox justifyContent="End">
                                            <Button icon="sap-icon://edit" tooltip="Edit" type="Transparent" press="onEditAttribute"/>
                                            <Button icon="sap-icon://delete" tooltip="Delete" type="Transparent" press="onDeleteAttribute"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ── Tab 2: Lookup Values ──────────────────────────────── -->
                <IconTabFilter key="lookups" icon="sap-icon://list" text="Lookup Values" iconColor="Positive">
                    <VBox class="sapUiMediumMargin">
                        <Toolbar>
                            <Title text="Admin-Managed Lookup Values" level="H3"/>
                            <ToolbarSpacer/>
                            <Label text="Category:" design="Bold" class="sapUiTinyMarginEnd"/>
                            <Select id="lookupCategoryFilter" change="onLookupCategoryChange" width="200px">
                                <core:Item key="ALL" text="All Categories"/>
                            </Select>
                            <Button text="Add Lookup" icon="sap-icon://add" type="Emphasized"
                                press="onAddLookup" class="sapUiTinyMarginBegin"/>
                        </Toolbar>

                        <MessageStrip text="Lookup values power dropdown fields across the application. Changes are effective immediately."
                            type="Information" showIcon="true" class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>

                        <Table id="lookupTable"
                            items="{lookups>/items}"
                            headerText="Lookup Values"
                            growing="true" growingThreshold="30"
                            noDataText="No lookup values found for this category"
                            class="sapUiTinyMarginTop">
                            <columns>
                                <Column width="160px"><Text text="Category"/></Column>
                                <Column width="180px"><Text text="Code"/></Column>
                                <Column><Text text="Description"/></Column>
                                <Column width="80px" hAlign="Center"><Text text="Order"/></Column>
                                <Column width="80px" hAlign="Center"><Text text="Active"/></Column>
                                <Column width="100px" hAlign="End"><Text text="Actions"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <ObjectStatus text="{lookups>category}" state="Information"/>
                                        <Text text="{lookups>code}"/>
                                        <Text text="{lookups>description}" wrapping="false"/>
                                        <Text text="{lookups>displayOrder}"/>
                                        <ObjectStatus
                                            text="{= ${lookups>isActive} ? 'Active' : 'Inactive'}"
                                            state="{= ${lookups>isActive} ? 'Success' : 'Error'}"/>
                                        <HBox justifyContent="End">
                                            <Button icon="sap-icon://edit"   tooltip="Edit"   type="Transparent" press="onEditLookup"/>
                                            <Button icon="sap-icon://delete" tooltip="Delete" type="Transparent" press="onDeleteLookup"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ── Tab 3: Audit Log ───────────────────────────────── -->
                <IconTabFilter key="auditLog" icon="sap-icon://log" text="Audit Log" iconColor="Negative">
                    <VBox class="sapUiMediumMargin">
                        <Toolbar>
                            <Title text="System Audit Log" level="H3"/>
                            <ToolbarSpacer/>
                            <SearchField id="auditSearch" width="20rem" search="onAuditSearch" placeholder="Search action, entity, user..."/>
                            <Button text="Refresh" icon="sap-icon://refresh" press="onRefreshAudit" type="Transparent"/>
                        </Toolbar>
                        <HBox wrap="Wrap" class="sapUiTinyMarginTop sapUiTinyMarginBottom">
                            <Select id="auditActionFilter" change="onAuditFilterChange" class="sapUiTinyMarginEnd" width="12rem">
                                <items>
                                    <core:Item key="ALL"    text="All Actions"/>
                                    <core:Item key="CREATE" text="Create"/>
                                    <core:Item key="UPDATE" text="Update"/>
                                    <core:Item key="DELETE" text="Delete"/>
                                    <core:Item key="ACTION" text="Actions"/>
                                </items>
                            </Select>
                            <Select id="auditEntityFilter" change="onAuditFilterChange" class="sapUiTinyMarginEnd" width="12rem">
                                <items>
                                    <core:Item key="ALL"              text="All Entities"/>
                                    <core:Item key="Bridges"          text="Bridges"/>
                                    <core:Item key="Restrictions"     text="Restrictions"/>
                                    <core:Item key="BridgeAttributes" text="Bridge Attributes"/>
                                </items>
                            </Select>
                        </HBox>
                        <Table id="auditTable"
                            items="{auditLog>/items}"
                            growing="true"
                            growingThreshold="25"
                            noDataText="No audit records found"
                            class="sapUiTinyMarginTop">
                            <columns>
                                <Column minScreenWidth="Tablet"><Text text="Timestamp"/></Column>
                                <Column><Text text="Action"/></Column>
                                <Column><Text text="Entity"/></Column>
                                <Column><Text text="Record"/></Column>
                                <Column><Text text="User"/></Column>
                                <Column><Text text="Role"/></Column>
                                <Column><Text text="Description"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{auditLog>timestamp}"/>
                                        <ObjectStatus text="{auditLog>action}"
                                            state="{= ${auditLog>action} === 'DELETE' ? 'Error' : ${auditLog>action} === 'CREATE' ? 'Success' : 'Warning'}"/>
                                        <Text text="{auditLog>entity}"/>
                                        <VBox>
                                            <Text text="{auditLog>entityName}" wrapping="false"/>
                                        </VBox>
                                        <Text text="{auditLog>userId}"/>
                                        <Text text="{auditLog>userRole}"/>
                                        <Text text="{auditLog>description}" wrapping="false"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ── Tab 3: Role Configuration ─────────────────────── -->
                <IconTabFilter key="roleConfig" icon="sap-icon://role" text="Role Configuration" iconColor="Critical">
                    <VBox class="sapUiMediumMargin">
                        <Toolbar>
                            <Title text="Role-Based Feature Configuration" level="H3"/>
                            <ToolbarSpacer/>
                            <Label text="Role:" design="Bold" class="sapUiTinyMarginEnd"/>
                            <Select id="roleConfigSelector" change="onRoleConfigSelect" width="200px">
                                <core:Item key="ADMIN"          text="🔑 Administrator"/>
                                <core:Item key="BRIDGE_MANAGER" text="🏗 Bridge Manager"/>
                                <core:Item key="INSPECTOR"      text="🔍 Inspector"/>
                                <core:Item key="OPERATOR"       text="🚛 Operator"/>
                                <core:Item key="READ_ONLY"      text="👁 Read Only"/>
                            </Select>
                            <Button text="Save Changes" icon="sap-icon://save" type="Emphasized"
                                press="onSaveRoleConfigs" class="sapUiTinyMarginBegin"/>
                        </Toolbar>

                        <MessageStrip text="Configure which features, tabs, and actions each role can see and edit. Changes take effect immediately on next role switch."
                            type="Information" showIcon="true" class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>

                        <!-- MENU features -->
                        <Title text="Navigation Tiles &amp; Menu Items" level="H4" class="sapUiSmallMarginTop"/>
                        <Table id="roleConfigMenuTable" items="{roleConfig>/menu}" noDataText="Select a role above"
                            class="sapUiTinyMarginTop" growing="false">
                            <columns>
                                <Column width="200px"><Text text="Feature"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="Enabled"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="Visible"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="Editable"/></Column>
                                <Column><Text text="Feature Key"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{roleConfig>label}"/>
                                        <Switch state="{roleConfig>featureEnabled}"
                                            customTextOn="On" customTextOff="Off" change="onRoleFeatureChange"
                                            tooltip="Toggle entire feature on/off for all roles"/>
                                        <Switch state="{roleConfig>visible}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <Switch state="{roleConfig>editable}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <ObjectStatus text="{roleConfig>featureKey}" state="Information"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- TAB features -->
                        <Title text="Bridge Detail Tabs" level="H4" class="sapUiMediumMarginTop"/>
                        <Table id="roleConfigTabTable" items="{roleConfig>/tabs}" noDataText="Select a role above"
                            class="sapUiTinyMarginTop" growing="false">
                            <columns>
                                <Column width="220px"><Text text="Tab"/></Column>
                                <Column width="100px" hAlign="Center"><Text text="Visible"/></Column>
                                <Column width="100px" hAlign="Center"><Text text="Editable"/></Column>
                                <Column><Text text="Feature Key"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{roleConfig>label}"/>
                                        <Switch state="{roleConfig>visible}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <Switch state="{roleConfig>editable}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <ObjectStatus text="{roleConfig>featureKey}" state="Information"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- ACTION features -->
                        <Title text="Actions &amp; Buttons" level="H4" class="sapUiMediumMarginTop"/>
                        <Table id="roleConfigActionTable" items="{roleConfig>/actions}" noDataText="Select a role above"
                            class="sapUiTinyMarginTop" growing="false">
                            <columns>
                                <Column width="220px"><Text text="Action"/></Column>
                                <Column width="100px" hAlign="Center"><Text text="Visible"/></Column>
                                <Column width="100px" hAlign="Center"><Text text="Editable"/></Column>
                                <Column><Text text="Feature Key"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{roleConfig>label}"/>
                                        <Switch state="{roleConfig>visible}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <Switch state="{roleConfig>editable}"
                                            customTextOn="Yes" customTextOff="No" change="onRoleFeatureChange"/>
                                        <ObjectStatus text="{roleConfig>featureKey}" state="Information"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ── Tab 5: Section Tile Config ──────────────────────── -->
                <IconTabFilter key="sectionTiles" icon="sap-icon://grid" text="{i18n>admin.tab.sectionTiles}" iconColor="Positive">
                    <VBox class="sapUiMediumMargin">
                        <Toolbar>
                            <Title text="{i18n>admin.sectionTiles.title}" level="H3"/>
                            <ToolbarSpacer/>
                            <Label text="Role:" design="Bold" class="sapUiTinyMarginEnd"/>
                            <Select id="sectionTileRoleSelector" change="onSectionTileRoleSelect" width="200px">
                                <core:Item key="ADMIN"          text="Administrator"/>
                                <core:Item key="BRIDGE_MANAGER" text="Bridge Manager"/>
                                <core:Item key="INSPECTOR"      text="Inspector"/>
                                <core:Item key="OPERATOR"       text="Operator"/>
                                <core:Item key="READ_ONLY"      text="Read Only"/>
                            </Select>
                            <Button text="Save Changes" icon="sap-icon://save" type="Emphasized"
                                press="onSaveSectionTileConfigs" class="sapUiTinyMarginBegin"/>
                        </Toolbar>

                        <MessageStrip text="{i18n>admin.sectionTiles.info}"
                            type="Information" showIcon="true" class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>

                        <Table id="sectionTileTable"
                            items="{
                                path: 'sectionTileConfig>/tiles',
                                sorter: { path: 'section', group: true }
                            }"
                            noDataText="{i18n>admin.sectionTiles.noData}"
                            growing="false"
                            class="sapUiTinyMarginTop">
                            <columns>
                                <Column width="220px"><Text text="{i18n>admin.sectionTiles.col.tile}"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="{i18n>admin.sectionTiles.col.enabled}"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="{i18n>admin.sectionTiles.col.visible}"/></Column>
                                <Column width="90px" hAlign="Center"><Text text="{i18n>admin.sectionTiles.col.editable}"/></Column>
                                <Column><Text text="{i18n>admin.sectionTiles.col.featureKey}"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Text text="{sectionTileConfig>label}"/>
                                        <Switch state="{sectionTileConfig>featureEnabled}"
                                            customTextOn="On" customTextOff="Off"
                                            tooltip="Toggle entire feature on/off"/>
                                        <Switch state="{sectionTileConfig>visible}"
                                            customTextOn="Yes" customTextOff="No"/>
                                        <Switch state="{sectionTileConfig>editable}"
                                            customTextOn="Yes" customTextOff="No"/>
                                        <ObjectStatus text="{sectionTileConfig>featureKey}" state="Information"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                </IconTabFilter>

                <!-- ── Tab 6: Map Settings (Provider Config) ──────────── -->
                <IconTabFilter key="mapSettings" icon="sap-icon://map" text="Map Settings">
                    <VBox class="sapUiMediumMargin">
                        <Panel headerText="Map Provider Configuration">
                            <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4"
                                xmlns:form="sap.ui.layout.form">
                                <Label text="Map Provider"/>
                                <Select id="mapProviderSelect" selectedKey="{mapProviderConfig>/mapProvider}" change=".onMapProviderConfigChange">
                                    <core:Item key="osm-leaflet" text="OpenStreetMap (Leaflet)"/>
                                    <core:Item key="osm-maplibre" text="OpenStreetMap (MapLibre)"/>
                                    <core:Item key="google" text="Google Maps"/>
                                    <core:Item key="esri" text="Esri ArcGIS"/>
                                </Select>

                                <Label text="Geocoding Provider"/>
                                <Select selectedKey="{mapProviderConfig>/geocodeProvider}" change=".onMapProviderConfigChange">
                                    <core:Item key="nominatim" text="Nominatim (OSM - Free)"/>
                                    <core:Item key="google" text="Google Geocoding"/>
                                    <core:Item key="esri" text="Esri World Geocoder"/>
                                </Select>

                                <Label text="Routing Provider"/>
                                <Select selectedKey="{mapProviderConfig>/routingProvider}" change=".onMapProviderConfigChange">
                                    <core:Item key="osrm" text="OSRM (Free)"/>
                                    <core:Item key="valhalla" text="Valhalla (Free)"/>
                                    <core:Item key="ors" text="OpenRouteService (API key)"/>
                                    <core:Item key="google" text="Google Directions"/>
                                    <core:Item key="esri" text="Esri Route"/>
                                </Select>

                                <Label text="Default Zoom"/>
                                <Slider value="{mapProviderConfig>/defaultZoom}" min="1" max="18" step="1" enableTickmarks="true"/>

                                <Label text="Clustering Enabled"/>
                                <Switch state="{mapProviderConfig>/clusterEnabled}" change=".onMapProviderConfigChange"/>

                                <Label text="Cluster Radius (px)"/>
                                <Input value="{mapProviderConfig>/clusterRadius}" type="Number"/>

                                <Label text="Traffic Layer (Google only)"/>
                                <Switch state="{mapProviderConfig>/trafficLayerEnabled}" change=".onMapProviderConfigChange"/>

                                <Label text="Street View (Google only)"/>
                                <Switch state="{mapProviderConfig>/streetViewEnabled}" change=".onMapProviderConfigChange"/>
                            </form:SimpleForm>
                        </Panel>

                        <Panel headerText="API Key Status" class="sapUiSmallMarginTop">
                            <MessageStrip text="API keys are configured via BTP environment variables, not through this UI."
                                type="Information" showIcon="true" class="sapUiSmallMarginBottom"/>
                            <form:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanL="4" labelSpanM="4"
                                xmlns:form="sap.ui.layout.form">
                                <Label text="Google Maps API"/>
                                <ObjectStatus text="{mapProviderConfig>/googleKeyStatus}"
                                    state="{= ${mapProviderConfig>/googleKeyStatus} === 'Configured' ? 'Success' : 'Warning'}"/>
                                <Label text="Esri API"/>
                                <ObjectStatus text="{mapProviderConfig>/esriKeyStatus}"
                                    state="{= ${mapProviderConfig>/esriKeyStatus} === 'Configured' ? 'Success' : 'Warning'}"/>
                            </form:SimpleForm>
                        </Panel>

                        <Toolbar class="sapUiSmallMarginTop">
                            <ToolbarSpacer/>
                            <Button text="Save Map Settings" type="Emphasized" press=".onSaveMapProviderConfig" icon="sap-icon://save"/>
                            <Button text="Test Connection" press=".onTestMapConnection" icon="sap-icon://connected"/>
                        </Toolbar>
                    </VBox>
                </IconTabFilter>

                <!-- Note: Jurisdiction Access, Standards Profile and Map Config
                     have been moved to BMS Tech Admin → Tech Config. -->

                </items>
            </IconTabBar>
        </f:content>
    </f:DynamicPage>

    <!-- ── P11: Grant Jurisdiction Access Dialog ──────────────── -->
    <!-- Grant Jurisdiction Access dialog kept for backwards compatibility -->
    <Dialog id="grantAccessDialog" title="Grant Jurisdiction Access" contentWidth="640px">
        <content>
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanM="5" emptySpanM="0"
                xmlns:form="sap.ui.layout.form">
                <Label text="User Ref (email/ID)" required="true"/>
                <Input id="jaUserRef" placeholder="e.g. john.smith@nhvr.gov.au" maxLength="100"/>
                <Label text="Jurisdiction" required="true"/>
                <Select id="jaJurisdiction"/>
                <Label text="Access Level" required="true"/>
                <Select id="jaAccessLevel">
                    <items>
                        <core:Item key="READ"  text="READ — View only"/>
                        <core:Item key="WRITE" text="WRITE — Create and edit"/>
                        <core:Item key="ADMIN" text="ADMIN — Full administrative access"/>
                    </items>
                </Select>
                <Label text="Expires At (optional)"/>
                <DateTimePicker id="jaExpiresAt" placeholder="Leave blank for no expiry"/>
            </form:SimpleForm>
        </content>
        <beginButton><Button text="Grant Access" type="Emphasized" press="onGrantJurisdictionAccess"/></beginButton>
        <endButton><Button text="Cancel" press="onCancelGrantAccess"/></endButton>
    </Dialog>

    <!-- ── Add/Edit Lookup Dialog ──────────────────────────── -->
    <Dialog id="lookupDialog" title="Lookup Value" contentWidth="480px">
        <content>
            <form:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanM="4" emptySpanM="0"
                xmlns:form="sap.ui.layout.form">
                <Label text="Category" required="true"/>
                <Input id="lookupCategory" placeholder="e.g. STRUCTURE_TYPE" maxLength="50"/>
                <Label text="Code" required="true"/>
                <Input id="lookupCode" placeholder="e.g. BEAM_CONCRETE" maxLength="200"/>
                <Label text="Description"/>
                <Input id="lookupDescription" placeholder="Display label" maxLength="300"/>
                <Label text="Display Order"/>
                <Input id="lookupOrder" type="Number" placeholder="0" value="0"/>
                <Label text="Active"/>
                <CheckBox id="lookupActive" selected="true"/>
            </form:SimpleForm>
        </content>
        <beginButton><Button text="Save" type="Emphasized" press="onSaveLookup"/></beginButton>
        <endButton><Button text="Cancel" press="onCancelLookup"/></endButton>
    </Dialog>

    <!-- ── Add/Edit Attribute Dialog ────────────────────────── -->
    <Dialog id="attrDialog" title="Attribute Definition" contentWidth="520px">
        <content>
            <form:SimpleForm id="attrForm" editable="true" layout="ResponsiveGridLayout" labelSpanM="4" emptySpanM="0">
                <Label text="Internal Name" required="true"/>
                <Input id="attrName" placeholder="e.g. floodFrequency" maxLength="100"/>
                <Label text="Display Label" required="true"/>
                <Input id="attrLabel" placeholder="e.g. Flood Frequency (years)" maxLength="200"/>
                <Label text="Data Type" required="true"/>
                <Select id="attrDataType">
                    <items>
                        <core:Item key="STRING"  text="Text (String)"/>
                        <core:Item key="INTEGER" text="Integer Number"/>
                        <core:Item key="DECIMAL" text="Decimal Number"/>
                        <core:Item key="BOOLEAN" text="Yes/No (Boolean)"/>
                        <core:Item key="DATE"    text="Date"/>
                        <core:Item key="LOOKUP"  text="Lookup (Dropdown)"/>
                    </items>
                </Select>
                <Label text="Target Entity"/>
                <Select id="attrEntity">
                    <items>
                        <core:Item key="BRIDGE"           text="Bridge"/>
                        <core:Item key="RESTRICTION"      text="Restriction"/>
                        <core:Item key="DEFECT"           text="Defect"/>
                        <core:Item key="INSPECTION_ORDER" text="Inspection Order"/>
                        <core:Item key="PERMIT"           text="Permit"/>
                        <core:Item key="ROUTE"            text="Route"/>
                    </items>
                </Select>
                <Label text="Default Value"/>
                <Input id="attrDefault" placeholder="Optional default value"/>
                <Label text="Display Order"/>
                <Input id="attrOrder" type="Number" placeholder="e.g. 5"/>
                <Label text="Required"/>
                <CheckBox id="attrRequired" text=""/>
                <Label text="Filter Enabled"/>
                <CheckBox id="attrFilterEnabled" selected="true" text=""/>
                <Label text="Report Enabled"/>
                <CheckBox id="attrReportEnabled" selected="true" text=""/>
                <Label text="Mass Edit Enabled"/>
                <CheckBox id="attrMassEditEnabled" text=""/>
                <Label text="Active"/>
                <CheckBox id="attrActive" selected="true" text=""/>
            </form:SimpleForm>

            <!-- Valid Values builder (for LOOKUP type) -->
            <VBox id="attrValidValuesBox" visible="false" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                <Toolbar>
                    <Title text="Valid Values (Dropdown Options)" level="H5"/>
                    <ToolbarSpacer/>
                    <Button text="+ Add Value" icon="sap-icon://add" type="Ghost" press="onAddValidValue"/>
                </Toolbar>
                <Table id="validValuesTable" items="{attrValidValues>/items}" noDataText="No valid values yet"
                    class="sapUiTinyMarginTop" growing="false">
                    <columns>
                        <Column><Text text="Value (stored)"/></Column>
                        <Column><Text text="Label (displayed)"/></Column>
                        <Column width="70px" hAlign="Center"><Text text="Order"/></Column>
                        <Column width="60px" hAlign="End"><Text text=""/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Input value="{attrValidValues>value}" placeholder="stored value" maxLength="200"/>
                                <Input value="{attrValidValues>label}" placeholder="display label" maxLength="300"/>
                                <Input value="{attrValidValues>displayOrder}" type="Number" width="60px"/>
                                <Button icon="sap-icon://decline" type="Transparent" press="onRemoveValidValue" tooltip="Remove this value"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveAttribute"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelAttribute"/>
        </endButton>
    </Dialog>

</mvc:View>
