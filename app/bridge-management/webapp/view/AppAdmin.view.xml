<!-- ============================================================
     App Admin — BTP Setup & Tenant Operations
     Access: Admin role only
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.AppAdmin"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:layout="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="pageAppAdmin"
        title="App Admin — BTP Setup &amp; Tenant Operations"
        showNavButton="true"
        navButtonPress="onNavBack"
        backgroundDesign="List">

        <headerContent>
            <Button text="Refresh" icon="sap-icon://refresh" press="onRefresh" type="Transparent"/>
        </headerContent>

        <content>
            <IconTabBar id="appAdminTabs" expanded="true" class="sapUiSmallMarginTop">

                <!-- ── Tab 1: BTP Environment ─────────────────────── -->
                <items>
                    <IconTabFilter id="tabBTPEnv" icon="sap-icon://cloud" text="BTP Environment">
                        <content>
                            <VBox class="sapUiMediumMargin">
                                <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4"
                                    columnsXL="1" columnsL="1" columnsM="1">
                                    <form:title>
                                        <core:Title text="SAP BTP Environment Details"/>
                                    </form:title>
                                    <Label text="BTP Region"/>
                                    <Text id="txtBtpRegion" text="{appAdmin>/btpRegion}"/>
                                    <Label text="CF Org"/>
                                    <Text id="txtCfOrg" text="{appAdmin>/cfOrg}"/>
                                    <Label text="CF Space"/>
                                    <Text id="txtCfSpace" text="{appAdmin>/cfSpace}"/>
                                    <Label text="App Version"/>
                                    <Text id="txtAppVersion" text="{appAdmin>/appVersion}"/>
                                    <Label text="App Mode"/>
                                    <ObjectStatus id="objAppMode" text="{appAdmin>/appMode}"
                                        state="{= ${appAdmin>/appMode} === 'lite' ? 'Warning' : 'Success' }"/>
                                    <Label text="HANA Service"/>
                                    <Text id="txtHanaService" text="Hanaclouddb (hdi-shared)"/>
                                    <Label text="XSUAA Service"/>
                                    <Text id="txtXsuaaService" text="nhvr-xsuaa"/>
                                    <Label text="Destination Service"/>
                                    <Text id="txtDestService" text="nhvr-destination"/>
                                    <Label text="Health Status"/>
                                    <ObjectStatus id="objHealthStatus"
                                        text="{appAdmin>/healthStatus}"
                                        state="{= ${appAdmin>/healthStatus} === 'UP' ? 'Success' : 'Error' }"/>
                                    <Label text="Database"/>
                                    <ObjectStatus id="objDbStatus"
                                        text="{appAdmin>/dbStatus}"
                                        state="{= ${appAdmin>/dbStatus} === 'CONNECTED' ? 'Success' : 'Error' }"/>
                                    <Label text="Uptime (seconds)"/>
                                    <Text id="txtUptime" text="{appAdmin>/uptime}"/>
                                </form:SimpleForm>

                                <HBox class="sapUiMediumMarginTop" wrap="Wrap">
                                    <Button text="Run Health Check" icon="sap-icon://stethoscope"
                                        press="onRunHealthCheck" type="Emphasized"
                                        class="sapUiSmallMarginEnd"/>
                                    <Button text="View CF Logs" icon="sap-icon://log"
                                        press="onOpenCFLogs" type="Default"
                                        class="sapUiSmallMarginEnd"/>
                                </HBox>
                            </VBox>
                        </content>
                    </IconTabFilter>

                    <!-- ── Tab 2: App Mode ─────────────────────────── -->
                    <IconTabFilter id="tabAppMode" icon="sap-icon://switches" text="App Mode">
                        <content>
                            <VBox class="sapUiMediumMargin">
                                <MessageStrip
                                    text="App Mode controls which feature set is active. 'full' enables all modules. 'lite' hides inspections, defects, work orders, permits, and route assessment."
                                    type="Information" showIcon="true" showCloseButton="false"
                                    class="sapUiMediumMarginBottom"/>

                                <form:SimpleForm editable="true" layout="ResponsiveGridLayout"
                                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4"
                                    columnsXL="1" columnsL="1" columnsM="1">
                                    <form:title>
                                        <core:Title text="Current App Mode"/>
                                    </form:title>
                                    <Label text="Active Mode"/>
                                    <Select id="selAppMode" selectedKey="{appAdmin>/appMode}"
                                        enabled="false"
                                        tooltip="App mode is controlled via NHVR_APP_MODE environment variable in CF">
                                        <core:Item key="full"     text="Full — All modules enabled"/>
                                        <core:Item key="lite"     text="Lite — Core modules only"/>
                                        <core:Item key="demo"     text="Demo / Training — Synthetic data"/>
                                    </Select>
                                    <Label text="Hidden in Lite Mode"/>
                                    <Text text="Defects, Inspections, Inspection Orders, Work Orders, Permits, Route Assessment"/>
                                </form:SimpleForm>

                                <MessageStrip
                                    text="To change App Mode: update the NHVR_APP_MODE CF environment variable and restage the nhvr-bridge-srv application."
                                    type="Warning" showIcon="true" showCloseButton="false"
                                    class="sapUiMediumMarginTop"/>

                                <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4"
                                    columnsXL="1" columnsL="1" columnsM="1">
                                    <form:title>
                                        <core:Title text="CF Deployment Commands"/>
                                    </form:title>
                                    <Label text="Set Full Mode"/>
                                    <Text text="cf set-env nhvr-bridge-srv NHVR_APP_MODE full &amp;&amp; cf restage nhvr-bridge-srv"/>
                                    <Label text="Set Lite Mode"/>
                                    <Text text="cf set-env nhvr-bridge-srv NHVR_APP_MODE lite &amp;&amp; cf restage nhvr-bridge-srv"/>
                                    <Label text="Set Demo Mode"/>
                                    <Text text="cf set-env nhvr-bridge-srv NHVR_APP_MODE demo &amp;&amp; cf restage nhvr-bridge-srv"/>
                                </form:SimpleForm>
                            </VBox>
                        </content>
                    </IconTabFilter>

                    <!-- ── Tab 3: Multi-Tenant Config ─────────────── -->
                    <IconTabFilter id="tabMTConfig" icon="sap-icon://building" text="Tenants">
                        <content>
                            <VBox class="sapUiMediumMargin">
                                <Toolbar>
                                    <Title text="Tenant Registry"/>
                                    <ToolbarSpacer/>
                                    <Button text="Add Tenant" icon="sap-icon://add"
                                        press="onAddTenant" type="Emphasized"/>
                                    <Button text="Refresh" icon="sap-icon://refresh"
                                        press="onRefreshTenants" type="Transparent"/>
                                </Toolbar>

                                <Table id="tenantTable"
                                    items="{appAdmin>/tenants}"
                                    noDataText="No tenants configured"
                                    mode="SingleSelectMaster"
                                    selectionChange="onTenantSelect"
                                    class="sapUiMediumMarginTop">
                                    <columns>
                                        <Column><Text text="Tenant Code"/></Column>
                                        <Column><Text text="Display Name"/></Column>
                                        <Column><Text text="Type"/></Column>
                                        <Column><Text text="State"/></Column>
                                        <Column><Text text="Active"/></Column>
                                        <Column><Text text="Actions"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <ObjectIdentifier title="{appAdmin>tenantCode}" text="{appAdmin>ID}"/>
                                                <Text text="{appAdmin>displayName}"/>
                                                <Text text="{appAdmin>tenantType}"/>
                                                <Text text="{appAdmin>state}"/>
                                                <ObjectStatus
                                                    text="{= ${appAdmin>isActive} ? 'Active' : 'Inactive'}"
                                                    state="{= ${appAdmin>isActive} ? 'Success' : 'None'}"/>
                                                <Button icon="sap-icon://edit" type="Transparent"
                                                    press="onEditTenant" tooltip="Edit tenant"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </content>
                    </IconTabFilter>

                    <!-- ── Tab 5: Work Zone & AD Groups ──────────── -->
                    <IconTabFilter id="tabWorkZone" icon="sap-icon://group" text="Work Zone &amp; AD Groups">
                        <content>
                            <VBox class="sapUiMediumMargin">
                                <MessageStrip
                                    text="SAP Work Zone integration uses standard XSUAA role collections mapped from AD groups (IdP group-to-role mapping). No code changes required — configure in SAP BTP Cockpit."
                                    type="Success" showIcon="true" showCloseButton="false"
                                    class="sapUiMediumMarginBottom"/>

                                <Panel headerText="SAP Work Zone Setup Guide" expandable="true" expanded="true">
                                    <content>
                                        <VBox class="sapUiSmallMargin">
                                            <Title text="Step 1 — Subscribe to SAP Build Work Zone" level="H5" class="sapUiTinyMarginTop"/>
                                            <Text text="In BTP Cockpit → Subscriptions → Search 'SAP Build Work Zone, Standard Edition' → Subscribe"/>
                                            <Title text="Step 2 — Add App to Site" level="H5" class="sapUiSmallMarginTop"/>
                                            <Text text="Open SAP Launchpad Admin → Content Manager → Add this app (nhvr.bridgemanagement) → Assign to a Launchpad Site"/>
                                            <Title text="Step 3 — Map AD Groups to Role Collections" level="H5" class="sapUiSmallMarginTop"/>
                                            <Text text="BTP Cockpit → Security → Role Collections → Select NHVR_Admin / NHVR_BridgeManager / etc. → Add IdP group attribute mapping"/>
                                            <Title text="Step 4 — Configure Trust with IdP" level="H5" class="sapUiSmallMarginTop"/>
                                            <Text text="BTP Cockpit → Security → Trust Configuration → Add your corporate IdP (Azure AD / Okta) as Custom IdP with SAML/OIDC"/>
                                        </VBox>
                                    </content>
                                </Panel>

                                <Panel headerText="Role Collection — AD Group Mapping" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                                    <content>
                                        <Table class="sapUiSmallMargin" inset="false">
                                            <columns>
                                                <Column><Text text="NHVR Role Collection"/></Column>
                                                <Column><Text text="Recommended AD Group"/></Column>
                                                <Column><Text text="Scopes Included"/></Column>
                                                <Column><Text text="Intended Users"/></Column>
                                            </columns>
                                            <items>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_Admin"/>
                                                        <Text text="sg-nhvr-admin (or your IdP group name)"/>
                                                        <Text text="Admin, BridgeManager, Viewer"/>
                                                        <Text text="System administrators"/>
                                                    </cells>
                                                </ColumnListItem>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_BridgeManager"/>
                                                        <Text text="sg-nhvr-bridge-managers"/>
                                                        <Text text="BridgeManager, Viewer"/>
                                                        <Text text="Engineers / Planners"/>
                                                    </cells>
                                                </ColumnListItem>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_Inspector"/>
                                                        <Text text="sg-nhvr-inspectors"/>
                                                        <Text text="Inspector, Viewer"/>
                                                        <Text text="Field Inspectors"/>
                                                    </cells>
                                                </ColumnListItem>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_Operator"/>
                                                        <Text text="sg-nhvr-operators"/>
                                                        <Text text="Operator, Viewer"/>
                                                        <Text text="Permit &amp; Route Operators"/>
                                                    </cells>
                                                </ColumnListItem>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_Executive"/>
                                                        <Text text="sg-nhvr-executives"/>
                                                        <Text text="Executive, Viewer"/>
                                                        <Text text="Senior Management (read + dashboards)"/>
                                                    </cells>
                                                </ColumnListItem>
                                                <ColumnListItem>
                                                    <cells>
                                                        <ObjectIdentifier title="NHVR_Viewer"/>
                                                        <Text text="sg-nhvr-viewers"/>
                                                        <Text text="Viewer"/>
                                                        <Text text="General Staff (read-only)"/>
                                                    </cells>
                                                </ColumnListItem>
                                            </items>
                                        </Table>
                                    </content>
                                </Panel>

                                <Panel headerText="XSUAA Custom IdP Configuration" expandable="true" expanded="false" class="sapUiSmallMarginTop">
                                    <content>
                                        <VBox class="sapUiSmallMargin">
                                            <Title text="xs-security.json attribute mapping" level="H5" class="sapUiTinyMarginTop"/>
                                            <Text class="sapUiTinyMarginBottom"
                                                text="The xs-security.json is already configured with role collections. To map AD groups, add group-to-role mappings in BTP Cockpit under the trust configuration for your IdP."/>
                                            <Title text="SAML / OIDC Attribute to Map" level="H5" class="sapUiSmallMarginTop"/>
                                            <Text text="Attribute name: Groups (or as configured by your corporate IdP)"/>
                                            <Text text="Map each AD group value to the corresponding NHVR Role Collection"/>
                                            <Title text="Azure AD / Entra ID Example" level="H5" class="sapUiSmallMarginTop"/>
                                            <Text text="In Azure AD: create App Registration → add Group Claims → map group ObjectId or sAMAccountName to XSUAA role collections in BTP Cockpit"/>
                                        </VBox>
                                    </content>
                                </Panel>
                            </VBox>
                        </content>
                    </IconTabFilter>

                    <!-- ── Tab 6: XSUAA & Security ───────────────── -->
                    <IconTabFilter id="tabSecurity" icon="sap-icon://shield" text="Security">
                        <content>
                            <VBox class="sapUiMediumMargin">
                                <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4"
                                    columnsXL="1" columnsL="1" columnsM="1">
                                    <form:title>
                                        <core:Title text="XSUAA Configuration"/>
                                    </form:title>
                                    <Label text="XSUAA Service"/>
                                    <Text text="nhvr-xsuaa (application plan)"/>
                                    <Label text="App Name (xsappname)"/>
                                    <Text text="nhvr-bridge-app"/>
                                    <Label text="OAuth Grant Types"/>
                                    <Text text="authorization_code, client_credentials"/>
                                    <Label text="Token Validity"/>
                                    <Text text="43200 seconds (12 hours)"/>
                                    <Label text="Redirect URIs"/>
                                    <Text text="*.hana.ondemand.com/** (BTP trial scope)"/>
                                    <Label text="CSRF Protection"/>
                                    <Text text="Disabled on app-router (CAP handles via fetch-token pattern)"/>
                                </form:SimpleForm>

                                <form:SimpleForm editable="false" layout="ResponsiveGridLayout"
                                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                                    emptySpanXL="4" emptySpanL="4" emptySpanM="4"
                                    columnsXL="1" columnsL="1" columnsM="1"
                                    class="sapUiMediumMarginTop">
                                    <form:title>
                                        <core:Title text="Logged-In User"/>
                                    </form:title>
                                    <Label text="User ID"/>
                                    <Text id="txtCurrentUser" text="{appAdmin>/currentUser}"/>
                                    <Label text="Roles"/>
                                    <Text id="txtCurrentRoles" text="{appAdmin>/currentRoles}"/>
                                </form:SimpleForm>
                            </VBox>
                        </content>
                    </IconTabFilter>

                </items>
            </IconTabBar>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="Back to Home" icon="sap-icon://home"
                    press="onNavBack" type="Transparent"/>
            </OverflowToolbar>
        </footer>

    </Page>
</mvc:View>
