<!-- ============================================================
     NHVR Annual Bridge Condition Report
     Statutory report for Minister / Parliament submission
     AS 5100 / AustRoads BIMM annual summary
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.AnnualConditionReport"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:ui5table="sap.ui.table"
    displayBlock="true">

    <f:DynamicPage id="annualReportPage" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Annual Bridge Condition Report" level="H1"/>
                </f:heading>
                <f:snappedHeading>
                    <Title text="Annual Condition Report" level="H2"/>
                </f:snappedHeading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Reports" press="onNavToReports"/>
                        <Link text="Annual Condition Report"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button text="Export PDF" icon="sap-icon://pdf-attachment" press="onExportPdf" type="Emphasized"
                        tooltip="Export this report as PDF for submission"/>
                    <Button text="Export Excel" icon="sap-icon://excel-attachment" press="onExportExcel" type="Default"
                        tooltip="Export full data to Excel"/>
                    <Button icon="sap-icon://hint" type="Transparent" press="onInfoPress"
                        tooltip="About this report — statutory requirements and data sources"/>
                    <Button text="Reports" icon="sap-icon://nav-back" press="onNavToReports" type="Transparent"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <!-- Report Parameters -->
                <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom" alignItems="Center">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Reporting Year" design="Bold"/>
                        <Select id="reportYear" change="onParameterChange" width="120px"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Jurisdiction" design="Bold"/>
                        <Select id="reportJurisdiction" change="onParameterChange" width="140px"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Route Type" design="Bold"/>
                        <Select id="reportRouteType" change="onParameterChange" width="160px">
                            <core:Item key="ALL" text="All Routes"/>
                            <core:Item key="FREIGHT" text="Freight Routes Only"/>
                            <core:Item key="NHVR_ASSESSED" text="NHVR Assessed Only"/>
                        </Select>
                    </VBox>
                    <VBox alignItems="End" class="sapUiSmallMarginTop">
                        <Button text="Generate Report" icon="sap-icon://bar-chart"
                            press="onGenerateReport" type="Emphasized"/>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="nhvrApp">

                <!-- Report Header Banner -->
                <Panel class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop" expandable="false">
                    <content>
                        <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                            <Title id="reportBannerTitle" text="Annual Bridge Condition Report — Generating…" level="H2"
                                class="sapUiSmallMarginBottom"/>
                            <HBox wrap="Wrap">
                                <VBox class="sapUiLargeMarginEnd">
                                    <Label text="Report Date" design="Bold"/>
                                    <Text id="rptDate" text="—"/>
                                </VBox>
                                <VBox class="sapUiLargeMarginEnd">
                                    <Label text="Prepared By" design="Bold"/>
                                    <Text id="rptPreparedBy" text="NHVR Bridge Asset Management"/>
                                </VBox>
                                <VBox class="sapUiLargeMarginEnd">
                                    <Label text="Data Source" design="Bold"/>
                                    <Text text="NHVR Bridge Management System v3"/>
                                </VBox>
                                <VBox class="sapUiLargeMarginEnd">
                                    <Label text="Standard" design="Bold"/>
                                    <Text text="AS 5100 / AustRoads BIMM 2023"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </content>
                </Panel>

                <!-- Section 1: Network Summary -->
                <Panel headerText="1. Network Summary" expandable="true" expanded="true"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                    <content>
                        <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom" alignItems="Start">
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Total Bridges" level="H4"/>
                                <ObjectStatus id="kpiTotalBridges" text="—" state="None" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Good Condition" level="H4"/>
                                <ObjectStatus id="kpiGood" text="—" state="Success" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Fair Condition" level="H4"/>
                                <ObjectStatus id="kpiFair" text="—" state="None" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Poor Condition" level="H4"/>
                                <ObjectStatus id="kpiPoor" text="—" state="Warning" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Critical Condition" level="H4"/>
                                <ObjectStatus id="kpiCritical" text="—" state="Error" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Inspected This Year" level="H4"/>
                                <ObjectStatus id="kpiInspectedThisYear" text="—" state="Success" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="sapUiSmallMarginEnd nhvrKpiCard">
                                <Title text="Overdue Inspections" level="H4"/>
                                <ObjectStatus id="kpiOverdueInsp" text="—" state="Error" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                            <VBox class="nhvrKpiCard">
                                <Title text="Active Restrictions" level="H4"/>
                                <ObjectStatus id="kpiActiveRestrictions" text="—" state="Warning" inverted="true" class="nhvrBigKpi"/>
                            </VBox>
                        </HBox>
                        <HBox wrap="Wrap" class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom" alignItems="Center">
                            <ObjectStatus id="kpiNetworkScore" text="Network Health Score: —" state="None"
                                inverted="false" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="kpiComplianceRate" text="Inspection Compliance: —" state="None"
                                inverted="false" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="kpiHighRisk" text="High/Critical Risk: —" state="Error"
                                inverted="false"/>
                        </HBox>
                    </content>
                </Panel>

                <!-- Section 2: Condition Distribution by State -->
                <Panel headerText="2. Condition Distribution by State/Territory" expandable="true" expanded="true"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                    <content>
                        <MessageStrip
                            text="Condition ratings per AS 5100.7 — 1 (New) to 10 (Failed). Bands: 1–3 GOOD · 4–6 FAIR · 7–8 POOR · 9–10 CRITICAL."
                            type="Information" showIcon="true" showCloseButton="false"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
                        <ui5table:Table id="conditionByStateTable"
                            rows="{annualReport>/conditionByState}"
                            visibleRowCountMode="Fixed" visibleRowCount="10"
                            alternateRowColors="true"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                            <ui5table:columns>
                                <ui5table:Column width="80px"><Label text="State"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Total"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Good"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Fair"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Poor"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Critical"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="% Compliant"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Avg Rating"/></ui5table:Column>
                            </ui5table:columns>
                        </ui5table:Table>
                    </content>
                </Panel>

                <!-- Section 3: Critical and High-Risk Bridges -->
                <Panel headerText="3. Critical &amp; High-Risk Bridges" expandable="true" expanded="true"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                    <content>
                        <MessageStrip
                            text="Bridges requiring urgent attention. Condition rating CRITICAL (9–10) or Poor (7–8) with HIGH/CRITICAL scour risk."
                            type="Error" showIcon="true" showCloseButton="false"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
                        <ui5table:Table id="criticalBridgesTable"
                            rows="{annualReport>/criticalBridges}"
                            visibleRowCountMode="Fixed" visibleRowCount="15"
                            alternateRowColors="true"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                            <ui5table:columns>
                                <ui5table:Column width="120px"><Label text="Bridge ID"/></ui5table:Column>
                                <ui5table:Column width="200px"><Label text="Bridge Name"/></ui5table:Column>
                                <ui5table:Column width="80px"><Label text="State"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Condition"/></ui5table:Column>
                                <ui5table:Column width="80px"><Label text="Rating"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Scour Risk"/></ui5table:Column>
                                <ui5table:Column width="130px"><Label text="Last Inspection"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Posting Status"/></ui5table:Column>
                                <ui5table:Column width="180px"><Label text="Road Route"/></ui5table:Column>
                            </ui5table:columns>
                        </ui5table:Table>
                    </content>
                </Panel>

                <!-- Section 4: Inspection Compliance -->
                <Panel headerText="4. Inspection Compliance Summary" expandable="true" expanded="false"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">
                    <content>
                        <MessageStrip
                            text="Inspection cycle: Routine = 2 years (AS 5100.7 §6.2). Principal = 6 years. Special = as required. Bridges overdue for inspection are shown below."
                            type="Warning" showIcon="true" showCloseButton="false"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop"/>
                        <ui5table:Table id="inspComplianceTable"
                            rows="{annualReport>/inspectionCompliance}"
                            visibleRowCountMode="Fixed" visibleRowCount="10"
                            alternateRowColors="true"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginBottom">
                            <ui5table:columns>
                                <ui5table:Column width="80px"><Label text="State"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Total"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Inspected (2yr)"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Overdue"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Never Inspected"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Compliance %"/></ui5table:Column>
                            </ui5table:columns>
                        </ui5table:Table>
                    </content>
                </Panel>

                <!-- Section 5: Restrictions Summary -->
                <Panel headerText="5. Active Restrictions Summary" expandable="true" expanded="false"
                    class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
                    <content>
                        <ui5table:Table id="restrictionsSummaryTable"
                            rows="{annualReport>/restrictionsSummary}"
                            visibleRowCountMode="Fixed" visibleRowCount="8"
                            alternateRowColors="true"
                            class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                            <ui5table:columns>
                                <ui5table:Column width="160px"><Label text="Restriction Type"/></ui5table:Column>
                                <ui5table:Column width="100px"><Label text="Count"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Permit Required"/></ui5table:Column>
                                <ui5table:Column width="120px"><Label text="Temporary"/></ui5table:Column>
                                <ui5table:Column width="80px"><Label text="States"/></ui5table:Column>
                            </ui5table:columns>
                        </ui5table:Table>
                    </content>
                </Panel>

            </VBox>
        </f:content>
    </f:DynamicPage>

</mvc:View>
