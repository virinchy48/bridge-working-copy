<!-- ============================================================
     NHVR Freight Route Detail & Assessment View
     • Vehicle configuration panel
     • Full per-bridge assessment with restriction overlay
     • Alternative route finder (internal + OSRM)
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgemanagement.controller.FreightRouteDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    displayBlock="true">

    <f:DynamicPage id="frdPage" fitContent="true" toggleHeaderOnTitleClick="false">

        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <VBox>
                        <Title id="frdTitle" text="Freight Route Assessment" level="H2"/>
                        <HBox alignItems="Center" class="sapUiTinyMarginTop">
                            <ObjectStatus id="frdRouteClass" text="" state="None" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus id="frdStatus" text="" state="None"/>
                        </HBox>
                    </VBox>
                </f:heading>
                <f:breadcrumbs>
                    <Breadcrumbs>
                        <Link text="Home" press="onNavHome"/>
                        <Link text="Freight Routes" press="onNavBack"/>
                        <Link id="frdBreadcrumb" text="Route Detail"/>
                    </Breadcrumbs>
                </f:breadcrumbs>
                <f:actions>
                    <Button icon="sap-icon://refresh" tooltip="Refresh" press="onNavBack" type="Transparent"/>
                </f:actions>
                <f:navigationActions>
                    <Button icon="sap-icon://nav-back" tooltip="Back to Freight Routes" press="onNavBack"/>
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <!-- Route KPI strip + vehicle config -->
                <HBox wrap="Wrap" alignItems="Start" class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

                    <!-- Route Info card -->
                    <VBox class="nhvrFraInfoCard sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <Title text="Route Information" level="H5" class="nhvrFraCardTitle"/>
                        <layout:Grid defaultSpan="XL6 L6 M6 S12" class="sapUiTinyMarginTop">
                            <VBox>
                                <Label text="Route Code" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdRouteCode" text="—"/>
                            </VBox>
                            <VBox>
                                <Label text="Name" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdRouteName" text="—" wrapping="false"/>
                            </VBox>
                            <VBox>
                                <Label text="State" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdState" text="—"/>
                            </VBox>
                            <VBox>
                                <Label text="Total Bridges" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdBridgeCount" text="—"/>
                            </VBox>
                            <VBox>
                                <Label text="Corridor Max Mass" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdCorridorMass" text="—"/>
                            </VBox>
                            <VBox>
                                <Label text="Corridor Max Height" design="Bold" class="nhvrFraLabel"/>
                                <Text id="frdCorridorHeight" text="—"/>
                            </VBox>
                        </layout:Grid>
                    </VBox>

                    <!-- Vehicle Config card -->
                    <VBox class="nhvrFraVehicleCard sapUiSmallMarginBottom">
                        <Title text="Vehicle Configuration" level="H5" class="nhvrFraCardTitle"/>
                        <HBox wrap="Wrap" class="sapUiTinyMarginTop" alignItems="End">
                            <VBox class="nhvrFraInputGroup">
                                <Label text="GVM (t)" required="true"/>
                                <Input id="inGVM" type="Number" value="" placeholder="e.g. 42.5" width="88px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="GCM (t)"/>
                                <Input id="inGCM" type="Number" value="" placeholder="e.g. 68.5" width="88px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="Height (m)" required="true"/>
                                <Input id="inHeight" type="Number" value="" placeholder="e.g. 4.3" width="88px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="Width (m)"/>
                                <Input id="inWidth" type="Number" value="" placeholder="e.g. 2.5" width="88px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="Length (m)"/>
                                <Input id="inLength" type="Number" value="" placeholder="e.g. 19.0" width="88px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="Speed (km/h)"/>
                                <Input id="inSpeed" type="Number" value="80" placeholder="80" width="76px"/>
                            </VBox>
                            <VBox class="nhvrFraInputGroup">
                                <Label text="Vehicle Class"/>
                                <!-- Items populated at runtime from Lookup table (VEHICLE_CLASS) -->
                                <Select id="selVehicleClass" width="130px"/>
                            </VBox>
                        </HBox>
                        <!-- Action buttons — always visible below vehicle inputs -->
                        <HBox class="nhvrFraActionBar sapUiSmallMarginTop" alignItems="Center">
                            <Button id="btnRunAssessment"
                                text="Run Assessment"
                                icon="sap-icon://detail-view"
                                type="Emphasized"
                                press="onRunAssessment"
                                class="sapUiTinyMarginEnd"
                                tooltip="Assess all bridges on this route for the configured vehicle"/>
                            <Button id="btnFindAlternatives"
                                text="Find Alternative Routes"
                                icon="sap-icon://navigation-right-arrow"
                                type="Default"
                                press="onFindAlternatives"
                                class="sapUiTinyMarginEnd"
                                tooltip="Find alternative routes via internal network and OSRM external routing"/>
                            <Button id="btnExportResult"
                                text="Export CSV"
                                icon="sap-icon://download"
                                type="Transparent"
                                press="onExportAssessment"
                                visible="false"
                                tooltip="Export assessment result to CSV"/>
                            <Button id="btnShowRouteMap"
                                text="Show Map"
                                icon="sap-icon://map"
                                type="Default"
                                press="onToggleRouteMap"
                                visible="false"
                                tooltip="Show route and alternative routes on interactive map"
                                class="sapUiTinyMarginBegin"/>
                        </HBox>
                    </VBox>

                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop">

                <!-- ── Assessment Result Banner ──────────────────────── -->
                <VBox id="resultBanner" visible="false" class="nhvrFraResultBanner sapUiSmallMarginBottom">
                    <HBox alignItems="Center" justifyContent="SpaceBetween" wrap="Wrap">

                        <!-- Verdict -->
                        <HBox alignItems="Center" class="nhvrFraVerdictRow">
                            <core:HTML id="verdictIcon" content="&lt;span class='nhvrFraVerdictIcon'&gt;—&lt;/span&gt;"/>
                            <VBox class="sapUiSmallMarginBegin">
                                <Label text="Route Verdict" design="Bold" class="nhvrFraLabel"/>
                                <Title id="verdictText" text="—" level="H3"/>
                                <Text id="limitingInfo" text="" class="nhvrFraLimitingText"/>
                            </VBox>
                        </HBox>

                        <!-- Summary KPIs -->
                        <HBox alignItems="Center" class="nhvrFraKpiRow" wrap="Wrap">
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiTotal">
                                <Title id="kpiTotal" text="—" level="H2"/>
                                <Text text="Total Assets" class="nhvrFraKpiLabel"/>
                            </VBox>
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiPass">
                                <Title id="kpiPass" text="—" level="H2"/>
                                <Text text="Passing" class="nhvrFraKpiLabel"/>
                            </VBox>
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiWarn">
                                <Title id="kpiWarn" text="—" level="H2"/>
                                <Text text="Conditions" class="nhvrFraKpiLabel"/>
                            </VBox>
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiFail">
                                <Title id="kpiFail" text="—" level="H2"/>
                                <Text text="Failing" class="nhvrFraKpiLabel"/>
                            </VBox>
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiMargin">
                                <Title id="kpiMassMargin" text="—" level="H2"/>
                                <Text text="Min Mass Margin (t)" class="nhvrFraKpiLabel"/>
                            </VBox>
                            <VBox alignItems="Center" class="nhvrFraKpi nhvrFraKpiMargin">
                                <Title id="kpiClearMargin" text="—" level="H2"/>
                                <Text text="Min Clearance (mm)" class="nhvrFraKpiLabel"/>
                            </VBox>
                        </HBox>

                    </HBox>
                </VBox>

                <!-- ── Asset Assessment Table ─────────────────────────── -->
                <Panel id="assetPanel" headerText="Route Assets — Bridge Assessment" expandable="false" class="sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Route Assets" level="H4"/>
                            <ToolbarSpacer/>
                            <Text id="assetCount" text="No route selected" class="sapUiSmallMarginEnd nhvrFraAssetCount"/>
                            <ToggleButton id="btnShowAll" text="Show All Columns" press="onToggleColumns" type="Transparent"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <List id="assetList"
                            items="{assessModel>/bridges}"
                            noDataText="Run an assessment to see per-bridge results"
                            showSeparators="Inner"
                            class="nhvrFraBridgeList">
                            <CustomListItem type="Navigation" press="onBridgeRowPress">
                                <VBox class="nhvrFraBridgeRow">
                                    <!-- Row header: seq + ID + name + verdict badge -->
                                    <HBox alignItems="Center" justifyContent="SpaceBetween" class="nhvrFraBridgeRowHeader">
                                        <HBox alignItems="Center">
                                            <Text text="{assessModel>sequence}" class="nhvrFraSeqBadge"/>
                                            <VBox class="sapUiTinyMarginBegin">
                                                <HBox alignItems="Center">
                                                    <Text text="{assessModel>bridgeId}" class="nhvrFraBridgeId"/>
                                                    <core:HTML content="{= ${assessModel>isCritical} ? '&lt;span class=&quot;nhvrFraCriticalBadge&quot;&gt;CRITICAL&lt;/span&gt;' : '' }"/>
                                                    <core:HTML content="{= ${assessModel>isClosed}   ? '&lt;span class=&quot;nhvrFraClosedBadge&quot;&gt;CLOSED&lt;/span&gt;'   : '' }"/>
                                                </HBox>
                                                <Text text="{assessModel>name}" class="nhvrFraBridgeName"/>
                                                <Text text="{= ${assessModel>region} + ' · ' + ${assessModel>state} }" class="nhvrFraBridgeSubtext"/>
                                            </VBox>
                                        </HBox>
                                        <HBox alignItems="Center">
                                            <!-- Verdict chip -->
                                            <core:HTML id="verdictChip"
                                                content="{= '&lt;span class=&quot;nhvrFraVerdictChip nhvrFraVerdict' + ${assessModel>verdict} + '&quot;&gt;' + (${assessModel>verdict} === 'PASS' ? '✓ PASS' : ${assessModel>verdict} === 'CONDITIONS' ? '⚠ CONDITIONS' : ${assessModel>verdict} === 'FAIL' ? '✗ FAIL' : '— PENDING') + '&lt;/span&gt;' }"/>
                                        </HBox>
                                    </HBox>

                                    <!-- Structural attributes strip -->
                                    <HBox wrap="Wrap" class="nhvrFraAttrStrip">
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Mass Limit" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>effectiveMassLimit_t} ? ${assessModel>effectiveMassLimit_t} + ' t' : (${assessModel>grossMassLimit_t} ? ${assessModel>grossMassLimit_t} + ' t' : '—') }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Clearance" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>effectiveClearance_m} ? ${assessModel>effectiveClearance_m} + ' m' : (${assessModel>minVerticalClearance_m} ? ${assessModel>minVerticalClearance_m} + ' m' : (${assessModel>clearanceHeightM} ? ${assessModel>clearanceHeightM} + ' m' : '—')) }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Carriageway" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>effectiveWidth_m} ? ${assessModel>effectiveWidth_m} + ' m' : (${assessModel>trafficableWidth_m} ? ${assessModel>trafficableWidth_m} + ' m' : '—') }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Span" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>spanLengthM} ? ${assessModel>spanLengthM} + ' m' : '—' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Structure" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>structureType} || '—' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Material" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>material} || '—' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Built" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>yearBuilt} || '—' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Condition" class="nhvrFraAttrLabel"/>
                                            <ObjectStatus
                                                text="{= ${assessModel>conditionRating} ? ${assessModel>conditionRating} + '/10' : '—' }"
                                                state="{= ${assessModel>conditionRating} ? (${assessModel>conditionRating} >= 7 ? 'Success' : ${assessModel>conditionRating} >= 5 ? 'Warning' : 'Error') : 'None' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Load Rating" class="nhvrFraAttrLabel"/>
                                            <Text text="{= ${assessModel>loadRatingFactor} ? 'RF ' + ${assessModel>loadRatingFactor} : '—' }"/>
                                        </VBox>
                                        <VBox class="nhvrFraAttr">
                                            <Label text="Posting" class="nhvrFraAttrLabel"/>
                                            <ObjectStatus
                                                text="{assessModel>postingStatus}"
                                                state="{= ${assessModel>postingStatus} === 'UNRESTRICTED' ? 'Success' : ${assessModel>postingStatus} === 'POSTED' ? 'Warning' : 'Error' }"/>
                                        </VBox>
                                    </HBox>

                                    <!-- Active restrictions (if any) -->
                                    <HBox visible="{assessModel>hasRestrictions}" class="nhvrFraRestrRow" wrap="Wrap" alignItems="Center">
                                        <core:HTML content="&lt;span class='nhvrFraRestrLabel'&gt;Active Restrictions:&lt;/span&gt;"/>
                                        <Text text="{assessModel>restrictionsSummary}" class="nhvrFraRestrSummary"/>
                                    </HBox>

                                    <!-- Issues / Warnings -->
                                    <VBox visible="{assessModel>hasAnyFlag}" class="nhvrFraIssueBlock">
                                        <HBox visible="{assessModel>hasIssues}" alignItems="Start" class="sapUiTinyMarginBottom">
                                            <core:HTML content="&lt;span class='nhvrFraIssueRow nhvrFraIssueFail'&gt;✗&lt;/span&gt;"/>
                                            <Text text="{assessModel>issuesText}" class="nhvrFraIssueText nhvrFraIssueFail" wrapping="true"/>
                                        </HBox>
                                        <HBox visible="{assessModel>hasWarnings}" alignItems="Start">
                                            <core:HTML content="&lt;span class='nhvrFraIssueRow nhvrFraIssueWarn'&gt;⚠&lt;/span&gt;"/>
                                            <Text text="{assessModel>warningsText}" class="nhvrFraIssueText nhvrFraIssueWarn" wrapping="true"/>
                                        </HBox>
                                    </VBox>

                                </VBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>

                <!-- ── Alternative Routes Panel ──────────────────────── -->
                <Panel id="altRoutesPanel" headerText="Alternative Routes" visible="false"
                    expandable="true" expanded="true" class="sapUiSmallMarginBottom">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Alternative Routes" level="H4"/>
                            <ToolbarSpacer/>
                            <Text id="altCount" text="" class="sapUiSmallMarginEnd nhvrFraAssetCount"/>
                            <Button icon="sap-icon://refresh" tooltip="Refresh alternatives" press="onFindAlternatives" type="Transparent"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <List id="altRoutesList"
                            items="{altModel>/alternatives}"
                            noDataText="No alternative routes found"
                            showSeparators="Inner"
                            class="nhvrFraAltList">
                            <CustomListItem>
                                <HBox alignItems="Start" justifyContent="SpaceBetween" class="nhvrFraAltRow" wrap="Wrap">
                                    <VBox class="nhvrFraAltInfo">
                                        <HBox alignItems="Center">
                                            <!-- Source badge -->
                                            <core:HTML content="{= '&lt;span class=&quot;nhvrFraSourceBadge nhvrFraSource' + ${altModel>type} + '&quot;&gt;' + (${altModel>type} === 'INTERNAL' ? 'INTERNAL' : ${altModel>type} === 'APPROVED_ROUTE' ? 'APPROVED' : 'OSRM') + '&lt;/span&gt;' }"/>
                                            <VBox class="sapUiTinyMarginBegin">
                                                <Text text="{altModel>routeCode}" class="nhvrFraBridgeId"/>
                                                <Text text="{altModel>name}" class="nhvrFraBridgeName"/>
                                                <Text text="{= (${altModel>state} ? ${altModel>state} : '') + (${altModel>routeClass} ? ' · ' + ${altModel>routeClass} : '') + (${altModel>source} ? ' · ' + ${altModel>source} : '') }" class="nhvrFraBridgeSubtext"/>
                                            </VBox>
                                        </HBox>
                                        <HBox wrap="Wrap" class="nhvrFraAttrStrip">
                                            <VBox class="nhvrFraAttr">
                                                <Label text="Max Mass" class="nhvrFraAttrLabel"/>
                                                <Text text="{= ${altModel>corridorMaxMass} ? ${altModel>corridorMaxMass} + ' t' : '—' }"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr">
                                                <Label text="Max Height" class="nhvrFraAttrLabel"/>
                                                <Text text="{= ${altModel>corridorMaxHeight} ? ${altModel>corridorMaxHeight} + ' m' : '—' }"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr">
                                                <Label text="Bridges" class="nhvrFraAttrLabel"/>
                                                <Text text="{= ${altModel>bridgeCount} ? ${altModel>bridgeCount} + '' : '—' }"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr">
                                                <Label text="Distance" class="nhvrFraAttrLabel"/>
                                                <Text text="{= ${altModel>distanceKm} ? ${altModel>distanceKm} + ' km' : '—' }"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr">
                                                <Label text="Est. Duration" class="nhvrFraAttrLabel"/>
                                                <Text text="{= ${altModel>durationMin} ? ${altModel>durationMin} + ' min' : '—' }"/>
                                            </VBox>
                                            <!-- Asset assessment summary (only for assessed routes) -->
                                            <VBox class="nhvrFraAttr" visible="{= !!${altModel>assetSummary/total}}">
                                                <Label text="✓ Pass" class="nhvrFraAttrLabel"/>
                                                <ObjectStatus
                                                    text="{= ${altModel>assetSummary/passing} + '/' + ${altModel>assetSummary/total} }"
                                                    state="Success"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr" visible="{= !!${altModel>assetSummary/total} &amp;&amp; ${altModel>assetSummary/warned} > 0}">
                                                <Label text="⚠ Conditions" class="nhvrFraAttrLabel"/>
                                                <ObjectStatus
                                                    text="{altModel>assetSummary/warned}"
                                                    state="Warning"/>
                                            </VBox>
                                            <VBox class="nhvrFraAttr" visible="{= !!${altModel>assetSummary/total} &amp;&amp; ${altModel>assetSummary/failing} > 0}">
                                                <Label text="✗ Fail" class="nhvrFraAttrLabel"/>
                                                <ObjectStatus
                                                    text="{altModel>assetSummary/failing}"
                                                    state="Error"/>
                                            </VBox>
                                        </HBox>
                                        <!-- Key bridge findings for assessed routes -->
                                        <HBox visible="{= !!${altModel>assetSummary/keyBridges} &amp;&amp; ${altModel>assetSummary/keyBridges}.length > 0}"
                                            wrap="Wrap" class="sapUiTinyMarginTopBottom" alignItems="Center">
                                            <core:HTML content="&lt;span class='nhvrFraRestrLabel'&gt;Key assets:&lt;/span&gt;"/>
                                            <List items="{altModel>assetSummary/keyBridges}" showSeparators="None"
                                                class="nhvrFraKeyBridgeList" inset="false">
                                                <CustomListItem type="Inactive">
                                                    <HBox alignItems="Center" class="sapUiTinyMarginEnd">
                                                        <ObjectStatus
                                                            text="{= ${altModel>bridgeId} + (${altModel>keyIssue} ? ' — ' + ${altModel>keyIssue} : '') }"
                                                            state="{= ${altModel>verdict} === 'FAIL' ? 'Error' : ${altModel>verdict} === 'CONDITIONS' ? 'Warning' : 'Success' }"/>
                                                    </HBox>
                                                </CustomListItem>
                                            </List>
                                        </HBox>
                                        <Text text="{altModel>reason}" class="nhvrFraAltReason"/>
                                    </VBox>

                                    <!-- Verdict -->
                                    <VBox alignItems="End" justifyContent="Center" class="nhvrFraAltVerdict">
                                        <ObjectStatus
                                            text="{= ${altModel>verdict} === 'VIABLE' ? '✓ Viable' : ${altModel>verdict} === 'UNASSESSED' ? '? Unassessed' : '✗ Not Viable' }"
                                            state="{= ${altModel>verdict} === 'VIABLE' ? 'Success' : ${altModel>verdict} === 'UNASSESSED' ? 'Warning' : 'Error' }"
                                            class="nhvrFraVerdictStatus"/>
                                        <Button text="Assess This Route" icon="sap-icon://detail-view"
                                            press="onAssessAlternative"
                                            type="Transparent"
                                            visible="{= ${altModel>type} === 'INTERNAL' ? true : ${altModel>type} === 'APPROVED_ROUTE' ? true : false }"
                                            class="sapUiTinyMarginTop"/>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>

                <!-- ── Route Map Panel ────────────────────────────────── -->
                <Panel id="frdMapPanel" visible="false" expandable="false"
                    class="sapUiSmallMarginBottom nhvrFraMapPanel">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Route Map" level="H4"/>
                            <ToolbarSpacer/>
                            <!-- Routing engine selector -->
                            <Label text="Engine:" class="sapUiTinyMarginEnd"/>
                            <SegmentedButton id="sbRoutingEngine" selectionChange="onRoutingEngineChange"
                                class="sapUiTinyMarginEnd">
                                <items>
                                    <SegmentedButtonItem key="osrm"     text="OSRM"/>
                                    <SegmentedButtonItem key="valhalla" text="Valhalla"/>
                                </items>
                            </SegmentedButton>
                            <!-- Basemap selector -->
                            <Label text="Map:" class="sapUiTinyMarginEnd"/>
                            <Select id="frdBaseMapSelect" change="onBaseMapChange" width="150px"
                                class="sapUiTinyMarginEnd">
                                <core:Item key="osm"       text="OpenStreetMap"/>
                                <core:Item key="satellite" text="Satellite (Esri)"/>
                                <core:Item key="topo"      text="Topo"/>
                            </Select>
                            <Button icon="sap-icon://zoom-in" tooltip="Fit to route" press="onFitRouteMap"
                                type="Transparent"/>
                            <Button icon="sap-icon://decline" tooltip="Hide map" press="onToggleRouteMap"
                                type="Transparent"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <!-- Layer toggles -->
                        <HBox class="nhvrFraMapLayerRow" alignItems="Center" wrap="Wrap">
                            <CheckBox id="chkFrdLayerRoute"   text="Current Route"      selected="true"  select="onLayerToggle"/>
                            <CheckBox id="chkFrdLayerBridges" text="Assessed Bridges"   selected="true"  select="onLayerToggle" class="sapUiSmallMarginBegin"/>
                            <CheckBox id="chkFrdLayerAlts"    text="Alternative Routes" selected="true"  select="onLayerToggle" class="sapUiSmallMarginBegin"/>
                            <CheckBox id="chkFrdLayerAll"     text="All Area Bridges"   selected="false" select="onLayerToggle" class="sapUiSmallMarginBegin"/>
                            <ToolbarSpacer/>
                            <Text text="OSRM &amp; Valhalla: free open-source routing via OpenStreetMap"
                                class="nhvrFraMapEngineNote"/>
                        </HBox>
                        <!-- Leaflet map container -->
                        <core:HTML id="frdMapHolder"
                            content="&lt;div id='nhvr-route-detail-map' class='nhvrFraMapDiv'&gt;&lt;/div&gt;"
                            afterRendering="onFrdMapHolderRendered"
                            preferDOM="true"/>
                    </content>
                </Panel>

            </VBox>
        </f:content>
    </f:DynamicPage>

</mvc:View>
