<!-- ============================================================
     NHVR Empty State Fragment
     Usage in views: <core:Fragment fragmentName="nhvr.bridgemanagement.fragment.EmptyState" type="XML"/>
     Set custom data on the parent container to configure the message.
     ============================================================ -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:il="sap.f.illustration">

    <VBox id="emptyStateBox" alignItems="Center" class="sapUiLargeMaginTop sapUiLargeMarginBottom" visible="false">
        <core:Icon id="emptyStateIcon" src="sap-icon://database" size="4rem" color="#8396A8"
            class="sapUiMediumMarginBottom"/>
        <Title id="emptyStateTitle" text="No Data Found" level="H3" class="sapUiSmallMarginBottom"/>
        <Text id="emptyStateSubtitle" text="Adjust your filters or add a new record."
            class="nhvrSubText sapUiSmallMarginBottom" textAlign="Center" width="300px"/>
        <Button id="emptyStateAction" text="Clear Filters" icon="sap-icon://clear-filter"
            type="Emphasized" press="onClearFilters" visible="false" class="sapUiSmallMarginTop"/>
    </VBox>

</core:FragmentDefinition>
