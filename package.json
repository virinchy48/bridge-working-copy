{
    "name": "nhvr-bridge-app",
    "version": "3.0.0",
    "description": "NHVR Bridge Asset & Restriction Management - SAP BTP CAP Application",
    "repository": "https://github.com/virinchy48/Bridge-prod-06April",
    "license": "SEE LICENSE IN LICENSE",
    "private": true,
    "scripts": {
        "start": "cds-serve",
        "watch": "cds watch",
        "build": "cds build --production",
        "test": "jest --testPathPattern=test/ --forceExit --passWithNoTests",
        "test:unit": "jest --testPathPattern=test/unit --forceExit",
        "test:integration": "jest --testPathPattern=test/integration --forceExit",
        "test:reports": "jest --testPathPattern=test/reports --forceExit --passWithNoTests",
        "test:security": "jest --testPathPattern=test/security --forceExit --passWithNoTests",
        "test:performance": "jest --testPathPattern='test/(perf|performance)' --forceExit --passWithNoTests",
        "test:uat": "jest --testPathPattern=test/uat --forceExit --passWithNoTests",
        "test:fast": "jest --testPathPattern='test/(unit|integration)' --forceExit",
        "test:all": "jest --passWithNoTests --forceExit",
        "test:projects": "jest --config jest.projects.config.js --passWithNoTests --forceExit",
        "test:supertester": "jest --config test/supertester-v2/jest.config.js",
        "test:supertester:unit": "jest test/supertester-v2/st-unit.test.js --forceExit",
        "lint": "eslint .",
        "sync-ui": "rsync -av --delete --exclude='*.test.js' --exclude='test/' app/bridge-management/webapp/ app-router/resources/nhvr.bridgemanagement/",
        "sync-ui:webapp": "rsync -av --delete --exclude='*.test.js' --exclude='test/' app/bridge-management/webapp/ app-router/resources/webapp/",
        "sync-ui:all": "npm run sync-ui && npm run sync-ui:webapp",
        "verify": "bash scripts/verify-session.sh",
        "verify:mirror": "SKIP_LINT=1 SKIP_CDS=1 SKIP_TESTS=1 bash scripts/verify-session.sh",
        "postdeploy": "bash scripts/post-deploy-rotate-secrets.sh",
        "demo": "NHVR_APP_MODE=demo NODE_ENV=demo cds watch",
        "demo:seed": "node scripts/seed-demo-db.js",
        "audit:check": "npm audit --audit-level=high",
        "openapi": "cds compile srv/service.cds --to openapi -o api-spec.json 2>/dev/null || echo 'OpenAPI export completed'",
        "health": "curl -s http://localhost:4004/bridge-management/ | head -c 100"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@cap-js/hana": "^2",
        "@sap/audit-logging": "^7.0.1",
        "@sap/cds": "^9.0.0",
        "@sap/hana-client": "^2",
        "@sap/xssec": "^4.0.0",
        "express": "^4.21.0",
        "hdb": "^2.0.0",
        "passport": "^0.7.0"
    },
    "devDependencies": {
        "@cap-js/cds-test": "^0.4.1",
        "@cap-js/sqlite": "^2.2.0",
        "@sap/cds-dk": "^9.0.0",
        "@sap/cds-fiori": "^2.0.0",
        "@sap/cds-lsp": "^9.0.0",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/jest-runner": "^9.6.0",
        "eslint": "^10.0.0",
        "fast-check": "^4.6.0",
        "jest": "^29.0.0",
        "sqlite3": "^6.0.1",
        "supertest": "^6.3.4"
    },
    "cds": {
        "requires": {
            "db": {
                "kind": "hana-cloud",
                "[development]": {
                    "kind": "sqlite",
                    "credentials": {
                        "url": ":memory:"
                    }
                }
            }
        },
        "features": {
            "serve_on_root": false
        },
        "query": {
            "limit": {
                "default": 200,
                "max": 5000
            }
        }
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "globalSetup": "./test/root-global-setup.js",
        "testMatch": [
            "**/test/**/*.test.js"
        ]
    }
}
