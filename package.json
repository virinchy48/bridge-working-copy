{
    "name": "nhvr-bridge-app",
    "version": "3.0.0",
    "description": "NHVR Bridge Asset & Restriction Management - SAP BTP CAP Application",
    "repository": "https://github.com/virinchy48/Bridge-prod-06April",
    "license": "SEE LICENSE IN LICENSE",
    "private": true,
    "scripts": {
        "start": "cds-serve",
        "watch": "cds watch",
        "watch:hana": "cds watch --profile local-hana,production",
        "build": "cds build --production",
        "deploy:hana": "cds deploy --profile local-hana,production --to hana",
        "test": "jest --testPathPattern=test/ --forceExit --passWithNoTests",
        "test:unit": "jest --testPathPattern=test/unit --forceExit --passWithNoTests",
        "test:integration": "jest --testPathPattern=test/integration --forceExit --passWithNoTests",
        "test:reports": "jest --testPathPattern=test/reports --forceExit --passWithNoTests",
        "test:security": "jest --testPathPattern=test/security --forceExit --passWithNoTests",
        "test:performance": "jest --testPathPattern='test/(perf|performance)' --forceExit --passWithNoTests",
        "test:uat": "jest --testPathPattern=test/uat --forceExit --passWithNoTests",
        "test:fast": "jest --testPathPattern='test/(unit|integration)' --forceExit --passWithNoTests",
        "test:all": "jest --passWithNoTests --forceExit",
        "test:projects": "jest --config jest.projects.config.js --passWithNoTests --forceExit",
        "lint": "eslint .",
        "verify": "bash scripts/verify-session.sh",
        "postdeploy": "bash scripts/post-deploy-rotate-secrets.sh",
        "demo": "NHVR_APP_MODE=demo NODE_ENV=demo cds watch",
        "audit:check": "npm audit --audit-level=high",
        "openapi": "cds compile srv/service.cds --to openapi -o api-spec.json 2>/dev/null || echo 'OpenAPI export completed'",
        "health": "curl -s http://localhost:4004/bridge-management/ | head -c 100",
        "test:e2e:smoke": "bash scripts/e2e-smoke.sh"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@cap-js/hana": "^2",
        "@sap/audit-logging": "^7.0.1",
        "@sap/cds": "^9.0.0",
        "@sap/hana-client": "^2",
        "@sap/xssec": "^4.0.0",
        "express": "^4.21.0",
        "hdb": "^2.0.0",
        "passport": "^0.7.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@cap-js/cds-test": "^0.4.1",
        "@cap-js/sqlite": "^2.2.0",
        "@sap/cds-dk": "^9.0.0",
        "@sap/cds-fiori": "^2.0.0",
        "@sap/cds-lsp": "^9.0.0",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/jest-runner": "^9.6.0",
        "eslint": "^10.0.0",
        "fast-check": "^4.6.0",
        "jest": "^29.0.0",
        "sqlite3": "^6.0.1",
        "supertest": "^6.3.4"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "testMatch": [
            "**/test/**/*.test.js"
        ],
        "modulePathIgnorePatterns": [
            "<rootDir>/gen/",
            "<rootDir>/app-router/resources/"
        ]
    }
}
