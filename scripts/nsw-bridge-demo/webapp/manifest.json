{
  "_version": "1.59.0",
  "sap.app": {
    "id": "nsw.bridge.demo",
    "type": "application",
    "title": "NSW Bridge Asset & NHVR Permit Assessment",
    "description": "Interactive map and permit checker for NSW bridge assets",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "nsw.bridge.demo.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.ui.table": {}
      }
    },
    "models": {
      "bridges": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/bridges.json"
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "nsw.bridge.demo.i18n.i18n" }
      }
    }
  }
}
