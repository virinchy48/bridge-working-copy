<!-- ============================================================
     NHVR Bridge Lite - Home / Launchpad View — Role-Adaptive Navigation
     Lite edition: Inspections, Defects, Work Orders, Permits, Route Assessment removed
     ============================================================ -->
<mvc:View
    controllerName="nhvr.bridgelite.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    displayBlock="true">

    <Page showHeader="false" class="nhvrApp" backgroundDesign="Solid">
        <content>
            <VBox>

                <!-- ── Training / Demo Environment Banner ─────────── -->
                <HBox id="trainingBanner" visible="false"
                    justifyContent="SpaceBetween" alignItems="Center"
                    class="nhvrTrainingBanner">
                    <HBox alignItems="Center">
                        <core:Icon src="sap-icon://education" size="1.2rem" color="#fff"
                            class="sapUiSmallMarginBeginEnd"/>
                        <VBox>
                            <Title text="TRAINING ENVIRONMENT" level="H4" class="nhvrTrainingBannerTitle"/>
                            <Text text="You are using a demo instance with synthetic data. No production data will be affected."
                                class="nhvrTrainingBannerSub"/>
                        </VBox>
                    </HBox>
                    <HBox alignItems="Center" class="sapUiSmallMarginEnd">
                        <Button text="Open Help Guide" icon="sap-icon://sys-help"
                            type="Transparent" press="onOpenHelp"
                            class="nhvrTrainingHelpBtn sapUiSmallMarginEnd"/>
                        <Text id="trainingModeLabel" text="DEMO" class="nhvrTrainingModeChip"/>
                    </HBox>
                </HBox>

                <!-- ── Offline Banner ──────────────────────────────── -->
                <MessageStrip id="offlineBanner"
                    text="You are offline. Changes are queued and will sync automatically when reconnected."
                    type="Warning" showIcon="true" showCloseButton="false"
                    visible="false" class="sapUiSmallMarginBottom"/>

                <!-- ── SAP Fiori ShellBar (replaces custom HBox header) ── -->
                <f:ShellBar id="nhvrShellBar"
                    title="NHVR Bridge Lite"
                    secondTitle="{ui>/appSubtitle}"
                    showNavButton="false"
                    notificationsNumber="{ui>/notifCount}"
                    showNotifications="true"
                    showSearch="false"
                    showProductSwitcher="false"
                    showCopilotButton="false"
                    homeIconPressed="onNavHome"
                    notificationsPressed="onOpenNotifications"
                    avatarPressed="onAvatarPress"
                    class="nhvrShellBar">
                    <f:profile>
                        <Avatar id="userAvatar"
                            initials="{ui>/userInitials}"
                            displayShape="Circle"
                            size="XS"
                            tooltip="{ui>/userName}"/>
                    </f:profile>
                    <f:additionalContent>
                        <Button id="btnRoleSwitch"
                            icon="sap-icon://user-settings"
                            tooltip="{i18n>tooltip.switchRole}"
                            press="onOpenRoleDialog"
                            type="Transparent"
                            class="nhvrShellBarBtn"/>
                        <Button id="btnThemeToggle"
                            icon="sap-icon://night-mode"
                            tooltip="{i18n>tooltip.toggleTheme}"
                            press="onThemeToggle"
                            type="Transparent"
                            class="nhvrShellBarBtn"/>
                        <Button icon="sap-icon://sys-help"
                            tooltip="{i18n>tooltip.openHelp}"
                            press="onOpenHelp"
                            type="Transparent"
                            class="nhvrShellBarBtn"/>
                    </f:additionalContent>
                </f:ShellBar>

                <!-- ── Role Switch Dialog ──────────────────────────── -->
                <Dialog id="roleSwitchDialog"
                    title="{i18n>dialog.switchRole}"
                    contentWidth="320px">
                    <content>
                        <VBox class="sapUiSmallMargin">
                            <Label text="{i18n>label.selectRole}" design="Bold" class="sapUiTinyMarginBottom"/>
                            <Select id="roleSelector" width="100%" change="onRoleChange"
                                tooltip="{i18n>tooltip.switchRole}">
                                <core:Item key="ADMIN"          text="🔑 {i18n>role.admin}"/>
                                <core:Item key="BRIDGE_MANAGER" text="🏗 {i18n>role.bridgeManager}"/>
                                <core:Item key="READ_ONLY"      text="👁 {i18n>role.readOnly}"/>
                            </Select>
                            <HBox alignItems="Center" class="sapUiSmallMarginTop">
                                <core:Icon src="sap-icon://employee" class="sapUiTinyMarginEnd"/>
                                <Text id="roleChip" text="" class="nhvrRoleBadge"/>
                            </HBox>
                            <HBox alignItems="Center" class="sapUiTinyMarginTop">
                                <Text id="appVersionBadge" text="" class="nhvrVersionBadge sapUiTinyMarginEnd"/>
                                <Text id="appEnvBadge" text="" class="nhvrEnvBadge"/>
                            </HBox>
                        </VBox>
                    </content>
                    <beginButton>
                        <Button text="{i18n>btn.apply}" type="Emphasized" press="onRoleSwitchConfirm"/>
                    </beginButton>
                    <endButton>
                        <Button text="{i18n>btn.cancel}" press="onRoleSwitchCancel"/>
                    </endButton>
                </Dialog>

                <!-- ── Notification Dialog ───────────────────────────── -->
                <Dialog id="notificationDialog" title="Notifications" contentWidth="480px" verticalScrolling="true">
                    <content>
                        <List id="notificationList" noDataText="No pending notifications" mode="None"/>
                    </content>
                    <endButton>
                        <Button text="Close" press="onCloseNotifications"/>
                    </endButton>
                </Dialog>


                <!-- ── Quick Access Rail (role-adaptive) ───────────── -->
                <FlexBox id="quickAccessSection" wrap="Wrap" alignItems="Center"
                    class="nhvrQuickAccessRail" visible="false">
                    <!-- Populated dynamically by Home.controller.js onRoleChange/onInit -->
                    <!-- Items rendered via _renderQuickAccessRail() -->
                </FlexBox>

                <!-- ── Command Palette Dialog ────────────────────────── -->
                <Dialog id="cmdPaletteDialog" title="Quick Actions" contentWidth="480px"
                    class="nhvrCommandPalette">
                    <content>
                        <VBox>
                            <SearchField id="cmdPaletteSearch"
                                placeholder="Search actions, bridges, screens..."
                                liveChange="onCommandSearch"
                                class="sapUiSmallMargin"/>
                            <List id="cmdPaletteList"
                                mode="None"
                                noDataText="No matching actions"
                                itemPress="onCommandSelect">
                                <items>
                                    <!-- Populated dynamically by _renderCommandPalette() -->
                                </items>
                            </List>
                        </VBox>
                    </content>
                    <endButton>
                        <Button text="Close" press="onCmdPaletteClose"/>
                    </endButton>
                </Dialog>

                <!-- ── Section: Operations ───────────────────────────── -->
                <VBox class="nhvrDashSection">
                    <Text text="OPERATIONS" class="nhvrDashSectionTitle"/>
                    <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" class="sapUiTinyMarginTop">

                        <GenericTile id="tileDashboard" class="nhvrLaunchTile tileDashboard sapUiTinyMargin"
                            header="Dashboard"
                            subheader="Portfolio Insights"
                            press="onNavToExecutive"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://home"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileBridges" class="nhvrLaunchTile tileBridges sapUiTinyMargin"
                            header="Bridges"
                            subheader="Asset Registry"
                            press="onNavToBridges"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://journey-arrive"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileRestrictions" class="nhvrLaunchTile tileRestrict sapUiTinyMargin"
                            header="Restrictions"
                            subheader="Active &amp; Scheduled"
                            press="onNavToRestrictions"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://alert"/>
                            </TileContent>
                        </GenericTile>

                    </FlexBox>
                </VBox>

                <!-- ── Section: Analytics ────────────────────────────── -->
                <VBox class="nhvrDashSection sapUiMediumMarginTop">
                    <Text text="ANALYTICS" class="nhvrDashSectionTitle"/>
                    <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" class="sapUiTinyMarginTop">

                        <GenericTile id="tileMapview" class="nhvrLaunchTile tileMap sapUiTinyMargin"
                            header="Map View"
                            subheader="Geographic Explorer"
                            press="onNavToMap"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://map-2"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileReports" class="nhvrLaunchTile tileReports sapUiTinyMargin"
                            header="Reports"
                            subheader="Compliance &amp; Export"
                            press="onNavToReports"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://bar-chart"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileVehicleAccess" class="nhvrLaunchTile tileVehicle sapUiTinyMargin"
                            header="Vehicle Access"
                            subheader="Combinations &amp; Routes"
                            press="onNavToVehicleCombinations"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://travel-itinerary"/>
                            </TileContent>
                        </GenericTile>

                    </FlexBox>
                </VBox>

                <!-- ── Inline Alert Strips (overdue / expiring) ──────────── -->
                <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTop" id="alertStripsBox">
                    <MessageStrip id="overdueInspStrip"
                        text="Loading inspection status…"
                        type="Error" showIcon="true" showCloseButton="false"
                        visible="false" class="nhvrAlertStrip sapUiTinyMarginBottom"/>
                    <MessageStrip id="expiringRestrictStrip"
                        text="Loading restriction status…"
                        type="Warning" showIcon="true" showCloseButton="false"
                        visible="false" class="nhvrAlertStrip"/>
                </VBox>

                <!-- ── Condition Distribution Bar ────────────────────────── -->
                <VBox id="conditionDistBox" class="nhvrDashSection sapUiSmallMarginTop" visible="false">
                    <Text text="NETWORK CONDITION" class="nhvrDashSectionTitle"/>
                    <HBox alignItems="Center" class="sapUiTinyMarginTop nhvrCondDistRow">
                        <VBox class="nhvrCondDistItem sapUiSmallMarginEnd" alignItems="Center">
                            <Text id="condGoodCount"  text="—" class="nhvrCondDistCount nhvrCondGood"/>
                            <Text text="GOOD"     class="nhvrCondDistLabel"/>
                        </VBox>
                        <VBox class="nhvrCondDistItem sapUiSmallMarginEnd" alignItems="Center">
                            <Text id="condFairCount"  text="—" class="nhvrCondDistCount nhvrCondFair"/>
                            <Text text="FAIR"     class="nhvrCondDistLabel"/>
                        </VBox>
                        <VBox class="nhvrCondDistItem sapUiSmallMarginEnd" alignItems="Center">
                            <Text id="condPoorCount"  text="—" class="nhvrCondDistCount nhvrCondPoor"/>
                            <Text text="POOR"     class="nhvrCondDistLabel"/>
                        </VBox>
                        <VBox class="nhvrCondDistItem sapUiSmallMarginEnd" alignItems="Center">
                            <Text id="condCritCount"  text="—" class="nhvrCondDistCount nhvrCondCritical"/>
                            <Text text="CRITICAL" class="nhvrCondDistLabel"/>
                        </VBox>
                        <VBox class="sapUiSmallMarginBegin nhvrFlexGrow1">
                            <HBox id="condDistBar" class="nhvrCondDistBar" alignItems="Stretch">
                                <!-- Segments injected by controller -->
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── Section: Live KPI Summary ─────────────────────── -->
                <VBox class="nhvrDashSection sapUiMediumMarginTop">
                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                        <Text text="LIVE SUMMARY" class="nhvrDashSectionTitle"/>
                        <Button text="Refresh" icon="sap-icon://refresh" press="onRefresh"
                            type="Transparent" class="sapUiTinyMarginTop"/>
                    </HBox>
                    <HBox wrap="Wrap" class="sapUiTinyMarginTop">
                        <GenericTile class="nhvrKpiTile sapUiTinyMargin"
                            header="Total Bridges" subheader="In registry"
                            press="onNavToBridges">
                            <TileContent>
                                <NumericContent id="homeTotalBridges" value="—"
                                    valueColor="Neutral" icon="sap-icon://journey-arrive"/>
                            </TileContent>
                        </GenericTile>
                        <GenericTile class="nhvrKpiTile sapUiTinyMargin"
                            header="Active Restrictions" subheader="Currently active"
                            press="onNavToRestrictions">
                            <TileContent>
                                <NumericContent id="homeActiveRestrictions" value="—"
                                    valueColor="Critical" icon="sap-icon://alert"/>
                            </TileContent>
                        </GenericTile>
                        <GenericTile class="nhvrKpiTile sapUiTinyMargin"
                            header="Closed Bridges" subheader="Requires action"
                            press="onNavToClosedBridges">
                            <TileContent>
                                <NumericContent id="homeClosedBridges" value="—"
                                    valueColor="Error" icon="sap-icon://decline"/>
                            </TileContent>
                        </GenericTile>
                        <GenericTile class="nhvrKpiTile sapUiTinyMargin"
                            header="Permit Required" subheader="Active permits"
                            press="onNavToPermitRestrictions">
                            <TileContent>
                                <NumericContent id="homePermitRequired" value="—"
                                    valueColor="Critical" icon="sap-icon://document"/>
                            </TileContent>
                        </GenericTile>
                    </HBox>
                </VBox>

                <!-- ── Section: Administration (Admin only) ──────────── -->
                <VBox id="sectionAdmin" class="nhvrDashSection sapUiMediumMarginTop" visible="false">
                    <Text text="ADMINISTRATION" class="nhvrDashSectionTitle"/>
                    <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" class="sapUiTinyMarginTop">

                        <GenericTile id="massUploadTile" class="nhvrLaunchTile tileUpload sapUiTinyMargin"
                            header="Mass Upload"
                            subheader="CSV Drag &amp; Drop"
                            press="onNavToMassUpload"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://upload-to-cloud"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="adminConfigTile" class="nhvrLaunchTile tileAdmin sapUiTinyMargin"
                            header="Admin Config"
                            subheader="Attributes &amp; Lookups"
                            press="onNavToAdmin"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://settings"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileLicenseConfig" class="nhvrLaunchTile tileAdmin sapUiTinyMargin"
                            header="Client Licensing"
                            subheader="Orgs, Features &amp; Roles"
                            press="onNavToLicenseConfig"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://key-user-settings"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="integrationHubTile" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Integration Hub"
                            subheader="S/4HANA · BANC · ESRI"
                            press="onNavToIntegrationHub"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://it-system"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="restrictionTypesTile" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Restriction Types" subheader="Configure Types"
                            press="onNavToRestrictionTypes" frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://category"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="massEditTile" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Mass Edit" subheader="In-App Grid Editor"
                            press="onNavToMassEdit" frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://edit-outside"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="vehicleTypesTile" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Vehicle Types" subheader="NHVR Vehicle Classes"
                            press="onNavToVehicleTypes" frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://bus-public-transport"/>
                            </TileContent>
                        </GenericTile>

                    </FlexBox>
                </VBox>

                <!-- ── Section: Intelligence Platform ───────────────── -->
                <VBox id="sectionIntelligence" class="nhvrDashSection sapUiMediumMarginTop">
                    <Text text="INTELLIGENCE PLATFORM" class="nhvrDashSectionTitle"/>
                    <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" class="sapUiTinyMarginTop">

                        <GenericTile id="tileBridgeIQ"
                            class="nhvrLaunchTile nhvrBridgeIQTile sapUiTinyMargin"
                            header="BridgeIQ"
                            subheader="Asset Intelligence Dashboard"
                            press="onNavToBridgeIQ"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://it-system"/>
                            </TileContent>
                        </GenericTile>

                    </FlexBox>
                </VBox>

                <!-- ── Section: Network Tools ──────────────────────── -->
                <VBox id="sectionNetworkTools" class="nhvrDashSection sapUiMediumMarginTop">
                    <Text text="NETWORK TOOLS" class="nhvrDashSectionTitle"/>
                    <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" class="sapUiTinyMarginTop">

                        <GenericTile id="tileBridgeMap" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Bridge Map"
                            subheader="GIS Spatial View"
                            press="onNavToMap"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://map"/>
                            </TileContent>
                        </GenericTile>

                        <GenericTile id="tileFreightCorridors" class="nhvrLaunchTile sapUiTinyMargin"
                            header="Freight Corridors"
                            subheader="PBS / HML Routes"
                            press="onNavToFreightRoutes"
                            frameType="OneByOne">
                            <TileContent>
                                <ImageContent src="sap-icon://shipping-status"/>
                            </TileContent>
                        </GenericTile>

                    </FlexBox>
                </VBox>

            </VBox>
        </content>
    </Page>
</mvc:View>
